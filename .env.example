# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Configuración de Base de Datos (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=punto_venta
DB_USER=root
DB_PASSWORD=

# Configuración de Sesiones
SESSION_SECRET=cambiar_este_secreto_en_produccion

# Configuración de WebAuthn (Biometría)
WEBAUTHN_RP_NAME="RG Simple POS"
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Compresión de imágenes de productos (Web Workers / Multer)
IMG_MAX_PX=1200
IMG_QUALITY=0.8
