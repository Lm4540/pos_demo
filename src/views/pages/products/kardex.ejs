<%- include('../../partials/head', { title: title }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/products" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Kardex de Inventario</span>
        <span class="text-xs block text-neutral-400 font-medium">Producto: <strong class="text-blue-400"><%= product.name %></strong></span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <!-- Date Range Filters -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <form method="GET" class="flex flex-col md:flex-row md:items-end gap-4">
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fecha de Inicio</label>
          <input 
            type="date" 
            name="startDate" 
            value="<%= startDate %>" 
            class="px-4 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm font-mono">
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fecha de Cierre</label>
          <input 
            type="date" 
            name="endDate" 
            value="<%= endDate %>" 
            class="px-4 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm font-mono">
        </div>
        <div class="flex gap-2">
          <button type="submit" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl text-xs transition-all shadow-md shadow-blue-500/10 cursor-pointer">
            Filtrar Historial
          </button>
          <% if (startDate || endDate) { %>
            <a href="/products/<%= product.id %>/kardex" class="px-5 py-2.5 bg-neutral-800 hover:bg-neutral-750 text-neutral-300 font-bold rounded-xl text-xs transition-all border border-neutral-700 cursor-pointer flex items-center justify-center">
              Limpiar
            </a>
          <% } %>
        </div>
      </form>
    </div>

    <!-- Ledger Table -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <h2 class="text-base font-bold text-white mb-4">Movimientos del Artículo</h2>

      <% if (logs.length === 0) { %>
        <p class="text-xs text-neutral-500 py-12 text-center">No hay registros de movimientos en el rango de fechas seleccionado.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
            <thead>
              <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-[10px]">
                <th class="py-2.5 px-3">Fecha y Hora</th>
                <th class="py-2.5 px-3">Sucursal</th>
                <th class="py-2.5 px-3">Usuario</th>
                <th class="py-2.5 px-3">Tipo Mov.</th>
                <th class="py-2.5 px-3 text-center">Cantidad</th>
                <th class="py-2.5 px-3 text-center">Stock Sucursal</th>
                <th class="py-2.5 px-3 text-center">Stock Global</th>
                <th class="py-2.5 px-3">Concepto / Referencia</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-800">
              <% logs.forEach(log => { %>
                <% const changeSign = log.isInput ? '+' : '-'; %>
                <% const newBranchStock = log.previousBranchStock + (log.isInput ? log.quantity : -log.quantity); %>
                <% const newGlobalStock = log.previousGlobalStock + (log.isInput ? log.quantity : -log.quantity); %>
                <tr class="hover:bg-neutral-950/20 text-xs">
                  <td class="py-3 px-3 font-mono text-neutral-500"><%= new Date(log.createdAt).toLocaleString('es-SV') %></td>
                  <td class="py-3 px-3 font-semibold text-neutral-300"><%= log.branch ? log.branch.name : 'N/A' %></td>
                  <td class="py-3 px-3 text-neutral-400"><%= log.user ? log.user.fullName : 'N/A' %></td>
                  <td class="py-3 px-3">
                    <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase 
                      <%= log.type === 'purchase' || log.type === 'transfer_in' || log.type === 'void_sale' ? 'bg-emerald-950 text-emerald-400 border border-emerald-900/60' : 'bg-red-950 text-red-400 border border-red-900/60' %>">
                      <%= log.type === 'purchase' ? 'Compra' : 
                          log.type === 'sale' ? 'Venta' : 
                          log.type === 'adjustment' ? 'Merma' : 
                          log.type === 'transfer_out' ? 'Traslado Salida' : 
                          log.type === 'transfer_in' ? 'Traslado Entrada' : 
                          log.type === 'void_sale' ? 'Anulación Venta' : log.type %>
                    </span>
                  </td>
                  <td class="py-3 px-3 text-center font-mono font-bold <%= log.isInput ? 'text-emerald-400' : 'text-red-400' %>">
                    <%= changeSign %><%= log.quantity %>
                  </td>
                  <td class="py-3 px-3 text-center font-mono">
                    <span class="text-neutral-500"><%= log.previousBranchStock %></span>
                    <span class="text-neutral-400 mx-1">→</span>
                    <span class="text-neutral-200 font-bold"><%= newBranchStock %></span>
                  </td>
                  <td class="py-3 px-3 text-center font-mono">
                    <span class="text-neutral-500"><%= log.previousGlobalStock %></span>
                    <span class="text-neutral-400 mx-1">→</span>
                    <span class="text-neutral-200 font-bold"><%= newGlobalStock %></span>
                  </td>
                  <td class="py-3 px-3 text-neutral-400 font-medium"><%= log.description %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>
</div>

<%- include('../../partials/foot') %>
