<%- include('../../partials/head', { title: 'Arqueo Detallado de Caja' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/cashier/history" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Arqueo Detallado: Turno #<%= turn.id %></span>
        <span class="text-xs block text-neutral-400 font-medium">
          Caja: <strong class="text-amber-400 font-mono"><%= turn.boxName %></strong> | 
          Cajero: <strong class="text-indigo-400"><%= turn.user ? turn.user.fullName : 'N/A' %></strong> | 
          Sucursal: <span class="text-neutral-300 font-semibold"><%= turn.branch ? turn.branch.name : 'N/A' %></span>
        </span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-8">
    <!-- Meta Info Box -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div class="space-y-1">
        <span class="text-xs text-neutral-500 font-bold uppercase tracking-wider block">Tiempos de Ejecución</span>
        <div class="text-sm text-neutral-300">
          <p><strong>Apertura:</strong> <%= new Date(turn.openedAt).toLocaleString('es-SV') %></p>
          <p><strong>Cierre:</strong> <%= turn.closedAt ? new Date(turn.closedAt).toLocaleString('es-SV') : 'Aún abierto' %></p>
        </div>
      </div>
      <div>
        <span class="text-xs text-neutral-500 font-bold uppercase tracking-wider block mb-1">Estado de Caja</span>
        <span class="px-3 py-1 rounded-full text-xs font-bold uppercase <%= turn.status === 'open' ? 'bg-emerald-950/60 text-emerald-400 border border-emerald-900/60' : 'bg-neutral-800 text-neutral-400 border border-neutral-700/60' %>">
          <%= turn.status === 'open' ? 'Abierta (En Curso)' : 'Cerrada y Auditada' %>
        </span>
      </div>
    </div>

    <!-- Cards Summary -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-4">
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-[10px] font-semibold text-neutral-500 uppercase tracking-wider">Apertura</span>
        <span class="text-lg font-bold text-white mt-2">$<%= parseFloat(turn.openingAmount).toFixed(2) %></span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-[10px] font-semibold text-neutral-500 uppercase tracking-wider">Ventas Cash</span>
        <span class="text-lg font-bold text-emerald-400 mt-2">+$<%= parseFloat(totalCashSales).toFixed(2) %></span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-[10px] font-semibold text-neutral-500 uppercase tracking-wider">Abonos CxC</span>
        <span class="text-lg font-bold text-emerald-400 mt-2">+$<%= parseFloat(totalCreditPayments).toFixed(2) %></span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-[10px] font-semibold text-neutral-500 uppercase tracking-wider">Reintegros</span>
        <span class="text-lg font-bold text-blue-400 mt-2">+$<%= parseFloat(totalDeposits).toFixed(2) %></span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-[10px] font-semibold text-neutral-500 uppercase tracking-wider">Retiros</span>
        <span class="text-lg font-bold text-red-400 mt-2">-$<%= parseFloat(totalWithdrawals).toFixed(2) %></span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-[10px] font-semibold text-neutral-500 uppercase tracking-wider">Esperado</span>
        <span class="text-lg font-bold text-white mt-2">$<%= parseFloat(expectedCash).toFixed(2) %></span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-[10px] font-semibold text-neutral-500 uppercase tracking-wider">Declarado (Contado)</span>
        <span class="text-lg font-bold text-white mt-2">
          <%= turn.declaredAmount !== null ? '$' + parseFloat(turn.declaredAmount).toFixed(2) : 'N/A' %>
        </span>
      </div>
      <div class="bg-neutral-900 border p-4 rounded-2xl flex flex-col justify-between <%= turn.status === 'open' ? 'border-neutral-800' : (difference === 0 ? 'border-emerald-800' : (difference < 0 ? 'border-red-800' : 'border-blue-800')) %>">
        <span class="text-[10px] font-semibold text-neutral-500 uppercase tracking-wider">Diferencia</span>
        <span class="text-lg font-black mt-2 <%= turn.status === 'open' ? 'text-neutral-400' : (difference === 0 ? 'text-emerald-400' : (difference < 0 ? 'text-red-400' : 'text-blue-400')) %>">
          <%= turn.status === 'open' ? '-' : (difference >= 0 ? '+$' + difference.toFixed(2) : '-$' + Math.abs(difference).toFixed(2)) %>
        </span>
      </div>
    </div>

    <!-- Difference Banner -->
    <% if (turn.status === 'closed') { %>
      <% if (difference === 0) { %>
        <div class="bg-emerald-950/40 border border-emerald-800 text-emerald-400 px-4 py-3 rounded-2xl text-sm font-semibold flex items-center gap-2">
          <span>✓</span>
          <span>Caja cuadrada con éxito. No se registraron diferencias de efectivo.</span>
        </div>
      <% } else if (difference < 0) { %>
        <div class="bg-red-950/40 border border-red-800 text-red-400 px-4 py-3 rounded-2xl text-sm font-semibold flex items-center gap-2">
          <span>⚠️ FALTANTE DETECTADO:</span>
          <span>Existe un faltante de caja de $<%= Math.abs(difference).toFixed(2) %> USD. El efectivo físico contado en arqueo fue menor que el esperado del sistema.</span>
        </div>
      <% } else { %>
        <div class="bg-blue-950/40 border border-blue-800 text-blue-400 px-4 py-3 rounded-2xl text-sm font-semibold flex items-center gap-2">
          <span>ℹ️ SOBRANTE DETECTADO:</span>
          <span>Existe un sobrante de caja de $<%= difference.toFixed(2) %> USD. El efectivo físico contado en arqueo fue mayor que el esperado del sistema.</span>
        </div>
      <% } %>
    <% } %>

    <!-- Movements, Sales, Payments audit details -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Left side (Movements) (2/3 width) -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Movements table -->
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
          <h2 class="text-base font-bold text-white mb-4">Reintegros y Retiros Efectuados</h2>
          <% if (movements.length === 0) { %>
            <p class="text-xs text-neutral-500 py-6 text-center">No se registraron movimientos manuales durante este turno.</p>
          <% } else { %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
                <thead>
                  <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                    <th class="py-2.5 px-3">Hora</th>
                    <th class="py-2.5 px-3">Tipo</th>
                    <th class="py-2.5 px-3">Monto</th>
                    <th class="py-2.5 px-3">Concepto</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-neutral-800">
                  <% movements.forEach(m => { %>
                    <tr class="hover:bg-neutral-950/40">
                      <td class="py-3 px-3 text-xs text-neutral-400"><%= new Date(m.createdAt).toLocaleTimeString('es-SV') %></td>
                      <td class="py-3 px-3">
                        <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase <%= m.type === 'deposit' ? 'bg-blue-950 text-blue-400 border border-blue-900/60' : 'bg-red-950 text-red-400 border border-red-900/60' %>">
                          <%= m.type === 'deposit' ? 'Reintegro' : 'Retiro' %>
                        </span>
                      </td>
                      <td class="py-3 px-3 font-semibold text-white">$<%= parseFloat(m.amount).toFixed(2) %></td>
                      <td class="py-3 px-3 text-neutral-400"><%= m.reason %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Right side (Sales & Payments list) -->
      <div class="space-y-8">
        <!-- Sales list -->
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
          <h2 class="text-base font-bold text-white mb-3">Ventas Efectivo</h2>
          <% if (cashSales.length === 0) { %>
            <p class="text-xs text-neutral-500 py-4 text-center">No hay ventas registradas en efectivo.</p>
          <% } else { %>
            <div class="max-h-60 overflow-y-auto space-y-2">
              <% cashSales.forEach(s => { %>
                <div class="flex items-center justify-between p-2.5 bg-neutral-950 border border-neutral-800 rounded-xl">
                  <div>
                    <span class="text-xs font-bold text-white block"><%= s.ticketNumber %></span>
                    <span class="text-[10px] text-neutral-500"><%= new Date(s.createdAt).toLocaleTimeString('es-SV') %></span>
                  </div>
                  <span class="text-sm font-semibold text-emerald-400">$<%= parseFloat(s.totalAmount).toFixed(2) %></span>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <!-- Payments list -->
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
          <h2 class="text-base font-bold text-white mb-3">Abonos de Créditos CxC</h2>
          <% if (creditPayments.length === 0) { %>
            <p class="text-xs text-neutral-500 py-4 text-center">No se recibieron abonos de crédito durante este turno.</p>
          <% } else { %>
            <div class="max-h-60 overflow-y-auto space-y-2">
              <% creditPayments.forEach(p => { %>
                <div class="flex items-center justify-between p-2.5 bg-neutral-950 border border-neutral-800 rounded-xl">
                  <div>
                    <span class="text-xs font-bold text-white block"><%= p.client ? p.client.name : 'Cliente' %></span>
                    <span class="text-[10px] text-neutral-500">Recibo: <%= p.receiptNumber %></span>
                  </div>
                  <span class="text-sm font-semibold text-emerald-400">+$<%= parseFloat(p.amountPaid).toFixed(2) %></span>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<%- include('../../partials/foot') %>
