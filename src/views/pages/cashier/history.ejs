<%- include('../../partials/head', { title: 'Historial de Cortes y Arqueos' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Historial de Cortes y Arqueos</span>
        <span class="text-xs block text-neutral-400 font-medium">Historial y Auditoría de Turnos de Caja</span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold text-white">Turnos Registrados</h2>
        <span class="text-xs text-neutral-400 font-semibold bg-neutral-950 px-3 py-1.5 border border-neutral-800 rounded-lg">
          Muestra todos los turnos para <%= user.roleId === 'admin' ? 'todas las sucursales' : 'tu sucursal' %>
        </span>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
          <thead>
            <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
              <th class="py-3 px-4">ID</th>
              <th class="py-3 px-4">Sucursal</th>
              <th class="py-3 px-4">Caja</th>
              <th class="py-3 px-4">Cajero</th>
              <th class="py-3 px-4">Apertura</th>
              <th class="py-3 px-4">Cierre</th>
              <th class="py-3 px-4">Inicial</th>
              <th class="py-3 px-4">Final Contado</th>
              <th class="py-3 px-4">Estado</th>
              <th class="py-3 px-4 text-right">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-800">
            <% turns.forEach(t => { %>
              <tr class="hover:bg-neutral-950/40 transition-colors">
                <td class="py-4 px-4 font-mono font-bold text-indigo-400">#<%= t.id %></td>
                <td class="py-4 px-4 text-neutral-300 font-semibold"><%= t.branch ? t.branch.name : 'N/A' %></td>
                <td class="py-4 px-4 font-mono text-xs text-amber-400 font-bold"><%= t.boxName %></td>
                <td class="py-4 px-4"><%= t.user ? t.user.fullName : 'Usuario' %></td>
                <td class="py-4 px-4 text-xs text-neutral-400"><%= new Date(t.openedAt).toLocaleString('es-SV') %></td>
                <td class="py-4 px-4 text-xs text-neutral-400">
                  <%= t.closedAt ? new Date(t.closedAt).toLocaleString('es-SV') : '-' %>
                </td>
                <td class="py-4 px-4 font-mono">$<%= parseFloat(t.openingAmount).toFixed(2) %></td>
                <td class="py-4 px-4 font-mono">
                  <%= t.declaredAmount !== null ? '$' + parseFloat(t.declaredAmount).toFixed(2) : '-' %>
                </td>
                <td class="py-4 px-4">
                  <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase <%= t.status === 'open' ? 'bg-emerald-950/60 text-emerald-400 border border-emerald-900/60 animate-pulse' : 'bg-neutral-800 text-neutral-400 border border-neutral-700/60' %>">
                    <%= t.status === 'open' ? 'Abierta' : 'Cerrada' %>
                  </span>
                </td>
                <td class="py-4 px-4 text-right space-x-3 text-xs">
                  <a href="/cashier/history/<%= t.id %>" class="text-indigo-400 hover:text-indigo-300 font-bold hover:underline cursor-pointer">
                    Ver Arqueo
                  </a>
                  <% if (t.status === 'open' && (user.roleId === 'admin' || user.roleId === 'supervisor') && t.userId !== user.id) { %>
                    <button 
                      onclick="forceCloseTurn(<%= t.id %>, '<%= t.user ? t.user.fullName : 'Usuario' %>')"
                      class="text-red-500 hover:text-red-400 font-bold hover:underline cursor-pointer">
                      Cierre Forzado
                    </button>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- Force Close Modal Overlay -->
<div id="force-close-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-sm p-6 rounded-2xl shadow-2xl relative">
    <h2 class="text-xl font-bold text-white mb-2 text-red-500">Cierre Forzado de Turno</h2>
    <p class="text-xs text-neutral-400 mb-4">Vas a forzar el cierre del turno de caja del usuario: <strong id="force-user-name" class="text-white"></strong>. Ingresa el dinero final estimado contado.</p>
    
    <form id="force-close-form" class="space-y-4">
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Monto de Cierre ($ USD) *</label>
        <input type="number" step="0.01" min="0" id="force-closingAmount" name="closingAmount" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-red-500 text-sm font-mono" placeholder="0.00">
      </div>
      
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closeForceModal()" class="px-4 py-2 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" class="px-5 py-2.5 text-sm font-bold text-white bg-red-600 hover:bg-red-500 rounded-xl transition-all cursor-pointer shadow-md shadow-red-500/10">
          Forzar Cierre
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  let activeForceTurnId = null;

  function forceCloseTurn(turnId, userName) {
    activeForceTurnId = turnId;
    document.getElementById('force-user-name').innerText = userName;
    document.getElementById('force-closingAmount').value = '';
    document.getElementById('force-close-modal').classList.remove('hidden');
  }

  function closeForceModal() {
    document.getElementById('force-close-modal').classList.add('hidden');
    activeForceTurnId = null;
  }

  document.getElementById('force-close-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!activeForceTurnId) return;

    const closingAmount = document.getElementById('force-closingAmount').value;
    const submitBtn = e.target.querySelector('button[type="submit"]');

    showConfirm('¿Estás seguro de que deseas forzar el cierre de esta caja de forma remota? El cajero será desconectado de su sesión activa de POS.', async () => {
      submitBtn.disabled = true;
      submitBtn.innerText = 'Procesando...';
      try {
        const resp = await fetch(`/cashier/force-close/${activeForceTurnId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ closingAmount })
        });
        const resData = await resp.json();
        if (resp.ok && resData.success) {
          showToast(resData.message, 'success');
          closeForceModal();
          setTimeout(() => {
            window.location.reload();
          }, 800);
        } else {
          showToast(resData.message || 'Error al forzar el cierre.', 'error');
          submitBtn.disabled = false;
          submitBtn.innerText = 'Forzar Cierre';
        }
      } catch (err) {
        console.error(err);
        showToast('Error de red al realizar el cierre forzado.', 'error');
        submitBtn.disabled = false;
        submitBtn.innerText = 'Forzar Cierre';
      }
    });
  });
</script>

<%- include('../../partials/foot') %>
