<%- include('../../partials/head', { title: 'Apertura de Turno' }) %>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-neutral-950 via-neutral-900 to-indigo-950 px-4 py-12 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8 bg-neutral-900/60 backdrop-blur-xl border border-neutral-800 p-8 rounded-2xl shadow-2xl">
    <div>
      <div class="flex justify-center">
        <div class="h-16 w-16 bg-indigo-600 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-500/20">
          <svg class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
      </div>
      <h2 class="mt-6 text-center text-3xl font-extrabold text-white tracking-tight">Iniciar Turno de Caja</h2>
      <p class="mt-2 text-center text-sm text-neutral-400">Sucursal: <strong class="text-indigo-400"><%= user.branch ? user.branch.name : 'Ninguna' %></strong></p>
    </div>

    <% if (error) { %>
      <div class="bg-red-950/40 border border-red-800/80 text-red-200 px-4 py-3 rounded-lg text-sm text-center">
        <%= error %>
      </div>
    <% } %>

    <form class="mt-8 space-y-6" action="/cashier/open" method="POST" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Abriendo...';">
      <div class="rounded-md shadow-sm space-y-4">
        <div>
          <label for="boxName" class="block text-sm font-semibold text-neutral-300 mb-1">Caja Registradora / Terminal *</label>
          <select 
            name="boxName" 
            id="boxName" 
            required 
            class="appearance-none block w-full px-3 py-3 border border-neutral-800 text-white bg-neutral-950/80 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm transition-all">
            <option value="Caja 1">Caja 1 (Frente)</option>
            <option value="Caja 2">Caja 2 (Rápida)</option>
            <option value="Caja 3">Caja 3 (Atrás)</option>
            <option value="Caja Principal">Caja Principal / Servicio</option>
          </select>
        </div>
        <div>
          <label for="openingAmount" class="block text-sm font-semibold text-neutral-400 mb-1">Monto de Apertura ($ USD) [Solo Lectura]</label>
          <div class="relative mt-1 rounded-xl shadow-sm">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <span class="text-neutral-600 sm:text-sm">$</span>
            </div>
            <input 
              type="number" 
              step="0.01" 
              name="openingAmount" 
              id="openingAmount" 
              value="<%= suggestedAmount.toFixed(2) %>"
              readonly
              required 
              class="appearance-none block w-full pl-8 pr-3 py-3 border border-neutral-800 placeholder-neutral-600 text-neutral-400 bg-neutral-950/40 rounded-xl focus:outline-none sm:text-sm transition-all select-none cursor-not-allowed" 
              placeholder="0.00">
          </div>
          <p class="mt-2 text-xs text-neutral-500">Monto sugerido automáticamente por el sistema basado en el saldo final de la última sesión cerrada de esta caja.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <a href="/dashboard" class="w-1/2 text-center py-3 border border-neutral-800 text-sm font-medium rounded-xl text-neutral-400 bg-neutral-950 hover:bg-neutral-900 transition-all cursor-pointer">
          Volver al Panel
        </a>
        <button type="submit" class="w-1/2 py-3 px-4 border border-transparent text-sm font-semibold rounded-xl text-white bg-indigo-600 hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-neutral-900 focus:ring-indigo-500 transition-all cursor-pointer shadow-lg shadow-indigo-500/20">
          Abrir Caja
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  const boxSelect = document.getElementById('boxName');
  const amountInput = document.getElementById('openingAmount');

  const updateBalance = async () => {
    const selectedBox = boxSelect.value;
    try {
      const resp = await fetch(`/cashier/api/box-last-balance?boxName=${encodeURIComponent(selectedBox)}`);
      const resData = await resp.json();
      if (resData.success) {
        amountInput.value = parseFloat(resData.balance).toFixed(2);
      }
    } catch (err) {
      console.error('Error fetching last balance:', err);
    }
  };

  boxSelect.addEventListener('change', updateBalance);
  
  // Set initial balance on load
  window.addEventListener('DOMContentLoaded', updateBalance);
</script>

<%- include('../../partials/foot') %>
