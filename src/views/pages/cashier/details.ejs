<%- include('../../partials/head', { title: 'Control de Caja' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Caja Activa</span>
        <span class="text-xs block text-neutral-400 font-medium">
          Caja: <strong class="text-amber-400 font-mono"><%= turn.boxName %></strong> | 
          Cajero: <strong class="text-indigo-400"><%= user.fullName %></strong> | 
          Abierto: <span class="text-neutral-300 font-semibold"><%= new Date(turn.openedAt).toLocaleString('es-SV') %></span>
        </span>
      </div>
    </div>
    
    <% if (user.roleId === 'admin' || user.roleId === 'supervisor') { %>
      <div class="flex items-center gap-3">
        <a href="/cashier/history" class="bg-neutral-800 border border-neutral-700 hover:bg-neutral-750 px-4 py-2 rounded-xl text-xs font-semibold text-neutral-300 transition-all flex items-center gap-2">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
          </svg>
          <span>Historial de Cortes</span>
        </a>
      </div>
    <% } %>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-8">
    <% if (error) { %>
      <div class="bg-red-950/40 border border-red-800 text-red-200 px-4 py-3 rounded-xl text-sm">
        <%= error %>
      </div>
    <% } %>

    <!-- Cards Summary -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      <!-- Apertura -->
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Apertura</span>
        <span class="text-xl font-bold text-white mt-2">$<%= parseFloat(turn.openingAmount).toFixed(2) %></span>
      </div>
      <!-- Ventas Efectivo -->
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Ventas Cash</span>
        <span class="text-xl font-bold text-emerald-400 mt-2">+$<%= parseFloat(totalCashSales).toFixed(2) %></span>
      </div>
      <!-- Abonos CxC -->
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Abonos CxC</span>
        <span class="text-xl font-bold text-emerald-400 mt-2">+$<%= parseFloat(totalCreditPayments).toFixed(2) %></span>
      </div>
      <!-- Reintegros -->
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Reintegros</span>
        <span class="text-xl font-bold text-blue-400 mt-2">+$<%= parseFloat(totalDeposits).toFixed(2) %></span>
      </div>
      <!-- Retiros -->
      <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Retiros</span>
        <span class="text-xl font-bold text-red-400 mt-2">-$<%= parseFloat(totalWithdrawals).toFixed(2) %></span>
      </div>
      <!-- Esperado en Caja (Oculto para cajeros - Arqueo Ciego) -->
      <% if (user.roleId !== 'cashier') { %>
        <div class="bg-neutral-900 border-2 border-indigo-900 p-4 rounded-2xl flex flex-col justify-between shadow-lg shadow-indigo-500/5">
          <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">Efectivo Esperado</span>
          <span class="text-2xl font-black text-white mt-2">$<%= parseFloat(expectedCash).toFixed(2) %></span>
        </div>
      <% } else { %>
        <div class="bg-neutral-900 border border-neutral-800 p-4 rounded-2xl flex flex-col justify-between">
          <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Estado de Caja</span>
          <span class="text-xl font-bold text-indigo-400 mt-2">Turno Abierto</span>
        </div>
      <% } %>
    </div>

    <!-- Forms & Actions Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Left Forms Area -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Movements list -->
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
          <h2 class="text-lg font-bold text-white mb-4">Movimientos del Turno (Retiros / Entradas)</h2>
          <% if (movements.length === 0) { %>
            <p class="text-sm text-neutral-500 py-4 text-center">No se han registrado retiros ni entradas en este turno.</p>
          <% } else { %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
                <thead>
                  <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                    <th class="py-2.5 px-3">Hora</th>
                    <th class="py-2.5 px-3">Tipo</th>
                    <th class="py-2.5 px-3">Monto</th>
                    <th class="py-2.5 px-3">Razón / Concepto</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-neutral-800">
                  <% movements.forEach(m => { %>
                    <tr class="hover:bg-neutral-950/40">
                      <td class="py-3 px-3 text-xs text-neutral-400"><%= new Date(m.createdAt).toLocaleTimeString('es-SV', { hour: '2-digit', minute: '2-digit' }) %></td>
                      <td class="py-3 px-3">
                        <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase <%= m.type === 'deposit' ? 'bg-blue-950 text-blue-400 border border-blue-900/60' : 'bg-red-950 text-red-400 border border-red-900/60' %>">
                          <%= m.type === 'deposit' ? 'Reintegro' : 'Retiro' %>
                        </span>
                      </td>
                      <td class="py-3 px-3 font-semibold text-white">$<%= parseFloat(m.amount).toFixed(2) %></td>
                      <td class="py-3 px-3 text-neutral-400"><%= m.reason %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <!-- Sales / Payments history in this turn -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Ventas en este Turno -->
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
            <h2 class="text-base font-bold text-white mb-3">Ventas Efectivo</h2>
            <% if (cashSales.length === 0) { %>
              <p class="text-xs text-neutral-500 py-3 text-center">No hay ventas registradas en efectivo.</p>
            <% } else { %>
              <div class="max-h-60 overflow-y-auto space-y-2.5">
                <% cashSales.forEach(s => { %>
                  <div class="flex items-center justify-between p-2.5 bg-neutral-950 border border-neutral-800 rounded-xl">
                    <div>
                      <span class="text-xs font-bold text-white block"><%= s.ticketNumber %></span>
                      <span class="text-[10px] text-neutral-500"><%= new Date(s.createdAt).toLocaleTimeString('es-SV') %></span>
                    </div>
                    <span class="text-sm font-semibold text-emerald-400">$<%= parseFloat(s.totalAmount).toFixed(2) %></span>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>

          <!-- Abonos CxC en este Turno -->
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
            <h2 class="text-base font-bold text-white mb-3">Abonos CxC recibidos</h2>
            <% if (creditPayments.length === 0) { %>
              <p class="text-xs text-neutral-500 py-3 text-center">No se han recibido abonos a cuentas en este turno.</p>
            <% } else { %>
              <div class="max-h-60 overflow-y-auto space-y-2.5">
                <% creditPayments.forEach(p => { %>
                  <div class="flex items-center justify-between p-2.5 bg-neutral-950 border border-neutral-800 rounded-xl">
                    <div>
                      <span class="text-xs font-bold text-white block"><%= p.client ? p.client.name : 'Cliente' %></span>
                      <span class="text-[10px] text-neutral-400 block">Recibo: <%= p.receiptNumber %></span>
                    </div>
                    <span class="text-sm font-semibold text-emerald-400">+$<%= parseFloat(p.amountPaid).toFixed(2) %></span>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Right Action Area (Close & Movements Forms) -->
      <div class="space-y-6">
        <!-- Registrar Movimiento -->
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
          <h2 class="text-lg font-bold text-white mb-4">Registrar Movimiento</h2>
          <form action="/cashier/movement" method="POST" class="space-y-4" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Registrando...';">
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Tipo de Movimiento *</label>
              <select name="type" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all text-sm">
                <option value="withdrawal">Retiro / Extracción (Ej. Corte parcial)</option>
                <option value="deposit">Reintegro / Ingreso (Ej. Sencillo/Cambio)</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Monto ($ USD) *</label>
              <input type="number" step="0.01" min="0.01" name="amount" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all text-sm" placeholder="0.00">
            </div>
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Concepto / Razón *</label>
              <input type="text" name="reason" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all text-sm" placeholder="Remesa a banco, fondo de vuelto...">
            </div>
            <button type="submit" class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl text-sm transition-all shadow-md shadow-indigo-500/10 cursor-pointer">
              Registrar Movimiento
            </button>
          </form>
        </div>

        <!-- Cerrar Turno -->
        <div class="bg-neutral-900 border-2 border-red-900/60 rounded-2xl p-6 shadow-sm">
          <h2 class="text-lg font-bold text-white mb-2">Cierre de Caja</h2>
          <p class="text-xs text-neutral-400 mb-4">Para cerrar el turno, ingresa el dinero físico real que tienes en caja contado. Se guardará tu declaración para arqueo del supervisor.</p>
          
          <form action="/cashier/close" method="POST" class="space-y-4" id="close-turn-form" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Cerrando caja...';">
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Efectivo Real en Caja ($) *</label>
              <input type="number" step="0.01" name="closingAmount" id="closingAmount" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-red-500 transition-all text-sm" placeholder="Monto contado">
            </div>
            
            <% if (user.roleId !== 'cashier') { %>
              <div class="bg-neutral-950 border border-neutral-800 p-3 rounded-xl space-y-1">
                <div class="flex justify-between text-xs">
                  <span class="text-neutral-500">Monto Esperado:</span>
                  <span class="text-neutral-300 font-bold">$<%= parseFloat(expectedCash).toFixed(2) %></span>
                </div>
                <div class="flex justify-between text-xs border-t border-neutral-800 pt-1">
                  <span class="text-neutral-500">Diferencia / Sobrante:</span>
                  <span id="cash-diff" class="font-bold text-neutral-400">$0.00</span>
                </div>
              </div>
            <% } %>

            <button type="submit" class="w-full py-3 bg-red-600 hover:bg-red-500 text-white font-bold rounded-xl text-sm transition-all shadow-md shadow-red-500/10 cursor-pointer">
              Cerrar Turno / Archivar Caja
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
  // Calculate cash difference dynamically
  const userRole = "<%= user.roleId %>";
  const expectedCash = parseFloat("<%= expectedCash %>");
  const closingInput = document.getElementById('closingAmount');
  const diffSpan = document.getElementById('cash-diff');

  if (userRole !== 'cashier' && diffSpan) {
    closingInput.addEventListener('input', () => {
      const val = parseFloat(closingInput.value);
      if (isNaN(val)) {
        diffSpan.innerText = "$0.00";
        diffSpan.className = "font-bold text-neutral-400";
        return;
      }
      const diff = val - expectedCash;
      if (diff === 0) {
        diffSpan.innerText = "$0.00 (Completo)";
        diffSpan.className = "font-bold text-emerald-400";
      } else if (diff > 0) {
        diffSpan.innerText = "+$" + diff.toFixed(2) + " (Sobrante)";
        diffSpan.className = "font-bold text-blue-400";
      } else {
        diffSpan.innerText = "-$" + Math.abs(diff).toFixed(2) + " (Faltante)";
        diffSpan.className = "font-bold text-red-400";
      }
    });
  }

  // Verify submit
  document.getElementById('close-turn-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const val = parseFloat(closingInput.value);
    
    let confirmMsg = '¿Estás seguro de que deseas cerrar tu turno de caja?';
    if (userRole !== 'cashier') {
      const diff = val - expectedCash;
      if (diff !== 0) {
        confirmMsg += ` Se ha detectado una diferencia de $${diff.toFixed(2)} (${diff > 0 ? 'sobrante' : 'faltante'}).`;
      }
    } else {
      confirmMsg = `¿Estás seguro de que deseas declarar un saldo físico de $${val.toFixed(2)} y proceder con el cierre ciego de caja?`;
    }
    
    showConfirm(confirmMsg, () => {
      const submitBtn = e.target.querySelector('button[type="submit"]');
      submitBtn.disabled = true;
      submitBtn.innerText = 'Cerrando...';
      e.target.submit();
    });
  });
</script>

<%- include('../../partials/foot') %>
