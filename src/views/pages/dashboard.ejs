        <% if (user.roleId === 'admin' || user.roleId === 'supervisor') { %>
        <a href="/suppliers" class="group bg-neutral-900 border border-neutral-800 hover:border-emerald-500 p-6 rounded-2xl transition-all shadow-sm hover:shadow-lg hover:shadow-emerald-500/5 hover:-translate-y-1 block">
