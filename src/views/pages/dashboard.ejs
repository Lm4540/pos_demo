            <svg class="h-6 w-6 text-sky-400 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mt-4">Sucursales</h3>
          <p class="text-neutral-400 text-sm mt-1">Registra y administra las ubicaciones físicas del minimarket.</p>
        </a>
        <% } %>

        <!-- Usuarios (Solo Admin) -->
        <% if (user.roleId === 'admin') { %>
        <a href="/users" class="group bg-neutral-900 border border-neutral-800 hover:border-indigo-500 p-6 rounded-2xl transition-all shadow-sm hover:shadow-lg hover:shadow-indigo-500/5 hover:-translate-y-1 block">
          <div class="h-12 w-12 bg-indigo-950 border border-indigo-800 rounded-xl flex items-center justify-center group-hover:bg-indigo-600 transition-colors">
            <svg class="h-6 w-6 text-indigo-400 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mt-4">Usuarios y Roles</h3>
          <p class="text-neutral-400 text-sm mt-1">Administra cuentas, roles (`supervisor`, `cashier`) y accesos especiales.</p>
        </a>
        <% } %>

        <!-- Auditoría (Solo Admin) -->
        <% if (user.roleId === 'admin') { %>
        <a href="/users/audit" class="group bg-neutral-900 border border-neutral-800 hover:border-violet-500 p-6 rounded-2xl transition-all shadow-sm hover:shadow-lg hover:shadow-violet-500/5 hover:-translate-y-1 block">
          <div class="h-12 w-12 bg-violet-950 border border-violet-800 rounded-xl flex items-center justify-center group-hover:bg-violet-600 transition-colors">
            <svg class="h-6 w-6 text-violet-400 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mt-4">Bitácora de Auditoría</h3>
          <p class="text-neutral-400 text-sm mt-1">Revisa el historial detallado de acciones, accesos y operaciones críticas.</p>
        </a>
        <% } %>

        <!-- Manual de Ayuda -->
        <a href="/help" class="group bg-neutral-900 border border-neutral-800 hover:border-indigo-500 p-6 rounded-2xl transition-all shadow-sm hover:shadow-lg hover:shadow-indigo-500/5 hover:-translate-y-1 block">
