<%- include('../../partials/head', { title: 'Reporte de Inventario' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/reports" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Reporte de Stock Completo</span>
        <span class="text-xs block text-neutral-400 font-medium">Análisis de existencias y valoración de inventario</span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <!-- Header metrics -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-neutral-900 border border-neutral-800 p-5 rounded-2xl flex flex-col justify-between shadow-sm">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Productos con Stock</span>
        <span class="text-2xl font-black text-white mt-2"><%= totalGlobalItemsCount %></span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-5 rounded-2xl flex flex-col justify-between shadow-sm">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Unidades Totales</span>
        <span class="text-2xl font-black text-white mt-2"><%= totalGlobalStock %> uds</span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-5 rounded-2xl flex flex-col justify-between shadow-sm">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Valoración a Costo</span>
        <span class="text-2xl font-black text-blue-400 mt-2"><%= formatMoney(totalGlobalCostValuation) %> USD</span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-5 rounded-2xl flex flex-col justify-between shadow-sm">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Valoración Estimada Venta</span>
        <span class="text-2xl font-black text-emerald-400 mt-2"><%= formatMoney(totalGlobalSaleValuation) %> USD</span>
      </div>
    </div>

    <!-- Interactive Navigation Tabs -->
    <div class="flex border-b border-neutral-800">
      <button onclick="switchTab('global')" id="tab-global-btn" class="px-6 py-3 text-sm font-bold border-b-2 border-blue-500 text-blue-400 transition-all cursor-pointer">
        Consolidado Global
      </button>
      <button onclick="switchTab('branch')" id="tab-branch-btn" class="px-6 py-3 text-sm font-bold border-b-2 border-transparent text-neutral-400 hover:text-white transition-all cursor-pointer">
        Detalle por Sucursal
      </button>
    </div>

    <!-- Search Input for both tabs -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 bg-neutral-900 p-4 border border-neutral-800 rounded-2xl shadow-sm">
      <div class="flex flex-wrap items-center gap-4 w-full max-w-xl">
        <input 
          type="text" 
          id="stock-search" 
          onkeyup="filterStockTables()" 
          class="w-full sm:max-w-sm px-4 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" 
          placeholder="Buscar por nombre o código de barras...">
        
        <label class="flex items-center gap-2 text-xs font-semibold text-neutral-400 whitespace-nowrap cursor-pointer select-none">
          <input type="checkbox" id="filter-no-stock" onchange="filterStockTables()" class="h-4 w-4 rounded border-neutral-800 bg-neutral-950 text-blue-600 focus:ring-blue-500 cursor-pointer">
          <span>Ocultar sin stock</span>
        </label>
      </div>
      
      <div id="branch-filter-container" class="hidden flex items-center gap-2">
        <label class="text-xs text-neutral-400 font-semibold whitespace-nowrap">Filtrar Sucursal:</label>
        <select id="branch-filter-select" onchange="filterBranchStock()" class="px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs">
          <% if (user.roleId === 'admin') { %>
            <option value="all">Todas las Sucursales</option>
          <% } %>
          <% branches.forEach(b => { %>
            <% if (user.roleId === 'admin' || user.branchId === b.id) { %>
              <option value="<%= b.id %>" <%= user.branchId === b.id ? 'selected' : '' %>><%= b.name %></option>
            <% } %>
          <% }) %>
        </select>
      </div>
    </div>

    <!-- Global Tab Content -->
    <div id="tab-global" class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-white mb-4">Stock Consolidado Global</h2>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300" id="global-stock-table">
          <thead>
            <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
              <th class="py-3 px-4">Artículo</th>
              <th class="py-3 px-4">Código Barras</th>
              <th class="py-3 px-4 text-center">Stock Global</th>
              <th class="py-3 px-4 text-right">Costo Promedio (W.A.)</th>
              <th class="py-3 px-4 text-right">Inversión Costo</th>
              <th class="py-3 px-4 text-right">Proyección Venta</th>
              <th class="py-3 px-4 text-center">Estados Stock</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-800">
            <% consolidatedStock.forEach(s => { %>
              <% 
                let hasCriticalStock = false;
                s.branchDetails.forEach(bp => {
                  if (bp.minStock > 0 && bp.totalStock <= bp.minStock) {
                    hasCriticalStock = true;
                  }
                });
              %>
              <tr class="hover:bg-neutral-950/40 transition-colors global-row" data-stock="<%= s.totalStock %>" data-search-name="<%= s.name.toLowerCase() %>" data-search-barcode="<%= (s.barCode || '').toLowerCase() %>">
                <td class="py-4 px-4 flex items-center gap-3">
                  <div class="h-10 w-10 rounded-lg bg-neutral-800 border border-neutral-750 overflow-hidden flex items-center justify-center flex-shrink-0">
                    <% if (s.imagePath) { %>
                      <img src="<%= s.imagePath %>" class="h-full w-full object-cover">
                    <% } else { %>
                      <svg class="h-5 w-5 text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                      </svg>
                    <% } %>
                  </div>
                  <span class="font-bold text-white"><%= s.name %></span>
                </td>
                <td class="py-4 px-4 font-mono text-xs text-neutral-400"><%= s.barCode || '-' %></td>
                <td class="py-4 px-4 text-center font-mono font-bold"><%= s.totalStock %></td>
                <td class="py-4 px-4 text-right font-mono"><%= formatMoney(s.averageCost) %></td>
                <td class="py-4 px-4 text-right font-mono text-blue-400"><%= formatMoney(s.totalCostValue) %></td>
                <td class="py-4 px-4 text-right font-mono text-emerald-400"><%= formatMoney(s.totalSaleValue) %></td>
                <td class="py-4 px-4 text-center">
                  <% if (hasCriticalStock) { %>
                    <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase bg-red-950 text-red-400 border border-red-900/60 animate-pulse">
                      Stock Crítico
                    </span>
                  <% } else { %>
                    <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase bg-neutral-800 text-neutral-500 border border-neutral-750/60">
                      Óptimo
                    </span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Branch Tab Content (Filtered) -->
    <div id="tab-branch" class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm hidden">
      <h2 class="text-lg font-bold text-white mb-4">Stock por Sucursal y Alertas</h2>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300" id="branch-stock-table">
          <thead>
            <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
              <th class="py-3 px-4">Artículo</th>
              <th class="py-3 px-4">Sucursal</th>
              <th class="py-3 px-4 text-center">Stock Actual</th>
              <th class="py-3 px-4 text-center">Stock Mínimo</th>
              <th class="py-3 px-4 text-right">Costo Promedio</th>
              <th class="py-3 px-4 text-right">Precio Venta</th>
              <th class="py-3 px-4 text-right">Val. Costo</th>
              <th class="py-3 px-4 text-center">Estado</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-800">
            <% consolidatedStock.forEach(s => { %>
              <% s.branchDetails.forEach(bp => { %>
                <% 
                  const isCrit = bp.minStock > 0 && bp.totalStock <= bp.minStock;
                  const qty = parseInt(bp.totalStock, 10);
                %>
                <tr 
                  class="hover:bg-neutral-950/40 transition-colors branch-row" 
                  data-branch-id="<%= bp.branchId %>"
                  data-stock="<%= qty %>"
                  data-search-name="<%= s.name.toLowerCase() %>" 
                  data-search-barcode="<%= (s.barCode || '').toLowerCase() %>">
                  <td class="py-4 px-4 font-bold text-white"><%= s.name %></td>
                  <td class="py-4 px-4 text-neutral-300 font-semibold"><%= bp.branch ? bp.branch.name : 'N/A' %></td>
                  <td class="py-4 px-4 text-center font-mono font-bold <%= isCrit ? 'text-red-400' : 'text-neutral-300' %>">
                    <%= qty %>
                  </td>
                  <td class="py-4 px-4 text-center font-mono text-neutral-500"><%= bp.minStock %></td>
                  <td class="py-4 px-4 text-right font-mono text-neutral-400"><%= formatMoney(bp.averageCost) %></td>
                  <td class="py-4 px-4 text-right font-mono text-emerald-400"><%= formatMoney(bp.salePrice) %></td>
                  <td class="py-4 px-4 text-right font-mono text-blue-400"><%= formatMoney(qty * bp.averageCost) %></td>
                  <td class="py-4 px-4 text-center">
                    <% if (isCrit) { %>
                      <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase bg-red-950 text-red-400 border border-red-900/60">
                        Bajo
                      </span>
                    <% } else { %>
                      <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase bg-emerald-950 text-emerald-400 border border-emerald-900/60">
                        Normal
                      </span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<script>
  let activeTab = 'global';

  function switchTab(tab) {
    activeTab = tab;
    const tabGlobalBtn = document.getElementById('tab-global-btn');
    const tabBranchBtn = document.getElementById('tab-branch-btn');
    const tabGlobal = document.getElementById('tab-global');
    const tabBranch = document.getElementById('tab-branch');
    const branchFilter = document.getElementById('branch-filter-container');

    const activeBtnClass = "px-6 py-3 text-sm font-bold border-b-2 border-blue-500 text-blue-400 transition-all cursor-pointer";
    const inactiveBtnClass = "px-6 py-3 text-sm font-bold border-b-2 border-transparent text-neutral-400 hover:text-white transition-all cursor-pointer";

    if (tab === 'global') {
      tabGlobalBtn.className = activeBtnClass;
      tabBranchBtn.className = inactiveBtnClass;
      tabGlobal.classList.remove('hidden');
      tabBranch.classList.add('hidden');
      branchFilter.classList.add('hidden');
    } else {
      tabBranchBtn.className = activeBtnClass;
      tabGlobalBtn.className = inactiveBtnClass;
      tabGlobal.classList.add('hidden');
      tabBranch.classList.remove('hidden');
      branchFilter.classList.remove('hidden');
      filterBranchStock(); // run filter
    }
  }

  function filterStockTables() {
    const query = document.getElementById('stock-search').value.toLowerCase();
    const hideZeroStock = document.getElementById('filter-no-stock').checked;
    
    if (activeTab === 'global') {
      const rows = document.querySelectorAll('.global-row');
      rows.forEach(r => {
        const name = r.dataset.searchName;
        const barcode = r.dataset.searchBarcode;
        const stock = parseInt(r.dataset.stock || '0', 10);
        
        const matchesSearch = name.includes(query) || barcode.includes(query);
        const matchesStock = !hideZeroStock || stock > 0;
        
        if (matchesSearch && matchesStock) {
          r.classList.remove('hidden');
        } else {
          r.classList.add('hidden');
        }
      });
    } else {
      filterBranchStock(); // Branch filtering incorporates both search string & selected branch
    }
  }

  function filterBranchStock() {
    const query = document.getElementById('stock-search').value.toLowerCase();
    const branchFilter = document.getElementById('branch-filter-select').value;
    const hideZeroStock = document.getElementById('filter-no-stock').checked;
    const rows = document.querySelectorAll('.branch-row');

    rows.forEach(r => {
      const name = r.dataset.searchName;
      const barcode = r.dataset.searchBarcode;
      const branchId = r.dataset.branchId;
      const stock = parseInt(r.dataset.stock || '0', 10);

      const matchesSearch = name.includes(query) || barcode.includes(query);
      const matchesBranch = (branchFilter === 'all' || branchId === branchFilter);
      const matchesStock = !hideZeroStock || stock > 0;

      if (matchesSearch && matchesBranch && matchesStock) {
        r.classList.remove('hidden');
      } else {
        r.classList.add('hidden');
      }
    });
  }

  // Set default initial tab state according to user sucursal filter
  window.onload = function() {
    const branchFilterSelect = document.getElementById('branch-filter-select');
    if (branchFilterSelect && branchFilterSelect.value !== 'all') {
      // If user is restricted to a branch, auto switch to Branch tab
      switchTab('branch');
    }
  }
</script>

<%- include('../../partials/foot') %>
