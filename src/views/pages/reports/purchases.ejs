<%- include('../../partials/head', { title: title }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/reports" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Reporte de Compras</span>
        <span class="text-xs block text-neutral-400 font-medium">Análisis de facturas y egresos a proveedores</span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <!-- Filters -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 shadow-sm">
      <form method="GET" action="/reports/purchases" class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1.5">Seleccionar Mes</label>
          <input type="month" name="month" value="<%= month %>" class="w-full px-3 py-2.5 bg-neutral-950 border border-neutral-800 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 font-medium text-sm">
        </div>
        
        <% if (user.roleId === 'admin') { %>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1.5">Sucursal</label>
            <select name="branchId" class="w-full px-3 py-2.5 bg-neutral-950 border border-neutral-800 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
              <option value="all" <%= selectedBranchId === 'all' ? 'selected' : '' %>>Todas las Sucursales</option>
              <% branches.forEach(b => { %>
                <option value="<%= b.id %>" <%= String(selectedBranchId) === String(b.id) ? 'selected' : '' %>><%= b.name %></option>
              <% }) %>
            </select>
          </div>
        <% } %>

        <div>
          <button type="submit" class="w-full py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl text-sm transition-all shadow-md shadow-blue-500/10 cursor-pointer text-center">
            Generar Reporte
          </button>
        </div>
      </form>
    </div>

    <!-- Summary Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex items-center justify-between">
        <div>
          <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider block">Total Comprado</span>
          <span class="text-3xl font-black text-white block mt-1 font-mono">$<%= totalAmount.toFixed(2) %></span>
        </div>
        <div class="p-3.5 bg-blue-950/40 border border-blue-900/60 text-blue-400 rounded-2xl">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
        </div>
      </div>

      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex items-center justify-between">
        <div>
          <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider block">Monto Pagado</span>
          <span class="text-3xl font-black text-emerald-450 block mt-1 font-mono">$<%= totalPaid.toFixed(2) %></span>
        </div>
        <div class="p-3.5 bg-emerald-950/40 border border-emerald-900/60 text-emerald-400 rounded-2xl">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>

      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex items-center justify-between">
        <div>
          <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider block">Saldo Pendiente (CxP)</span>
          <span class="text-3xl font-black text-red-450 block mt-1 font-mono">$<%= totalPending.toFixed(2) %></span>
        </div>
        <div class="p-3.5 bg-red-950/40 border border-red-900/60 text-red-400 rounded-2xl">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Main Purchases List (2/3 width) -->
      <div class="lg:col-span-2 bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
        <h2 class="text-lg font-bold text-white mb-4">Listado de Compras del Mes (<%= branchName %>)</h2>
        
        <% if (purchases.length === 0) { %>
          <p class="text-sm text-neutral-500 py-12 text-center">No se encontraron facturas registradas en este período.</p>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
              <thead>
                <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                  <th class="py-3 px-3">Fecha</th>
                  <th class="py-3 px-3">Factura</th>
                  <th class="py-3 px-3">Proveedor</th>
                  <th class="py-3 px-3 text-right">Monto</th>
                  <th class="py-3 px-3 text-center">Estado</th>
                  <th class="py-3 px-3 text-right">Detalle</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-800">
                <% purchases.forEach(p => { %>
                  <tr class="hover:bg-neutral-950/40 transition-colors">
                    <td class="py-3 px-3 font-mono text-xs text-neutral-400"><%= new Date(p.createdAt).toLocaleDateString('es-SV') %></td>
                    <td class="py-3 px-3 font-bold text-white"><%= p.invoiceNumber %></td>
                    <td class="py-3 px-3 text-neutral-300"><%= p.supplier ? p.supplier.name : 'N/A' %></td>
                    <td class="py-3 px-3 text-right font-bold text-white font-mono">$<%= parseFloat(p.totalAmount).toFixed(2) %></td>
                    <td class="py-3 px-3 text-center">
                      <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase <%= p.paymentStatus === 'paid' ? 'bg-emerald-950 text-emerald-400 border border-emerald-900/60' : 'bg-red-950 text-red-400 border border-red-900/60 animate-pulse' %>">
                        <%= p.paymentStatus === 'paid' ? 'Pagado' : 'Pendiente' %>
                      </span>
                    </td>
                    <td class="py-3 px-3 text-right">
                      <a href="/purchases/<%= p.id %>" class="text-blue-500 hover:text-blue-450 font-semibold hover:underline">
                        Ver
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <!-- Top Suppliers Breakdown (1/3 width) -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm space-y-4">
        <h2 class="text-lg font-bold text-white">Egresos por Proveedor</h2>
        
        <% if (supplierSummary.length === 0) { %>
          <p class="text-xs text-neutral-500 py-6 text-center">No hay datos de proveedores para este período.</p>
        <% } else { %>
          <div class="space-y-4">
            <% supplierSummary.forEach((sup, idx) => { %>
              <div class="flex items-center justify-between border-b border-neutral-800/50 pb-3 last:border-b-0 last:pb-0">
                <div class="flex-grow">
                  <div class="flex items-center gap-2">
                    <span class="text-xs font-bold text-neutral-500"><%= idx + 1 %>.</span>
                    <span class="text-sm font-bold text-white"><%= sup.name %></span>
                  </div>
                  <span class="text-xs text-neutral-450 block mt-0.5"><%= sup.count %> compras registradas</span>
                </div>
                <span class="text-sm font-black text-emerald-400 font-mono">$<%= sup.total.toFixed(2) %></span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</div>

<%- include('../../partials/foot') %>
