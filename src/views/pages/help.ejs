<!-- Lightbox Image Modal -->
<div id="image-lightbox" class="fixed inset-0 bg-neutral-950/90 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 p-4">
  <button id="lightbox-close" class="absolute top-4 right-4 text-white hover:text-neutral-300 text-4xl font-bold transition-colors cursor-pointer select-none focus:outline-none" aria-label="Cerrar modal">&times;</button>
  <div class="max-w-5xl max-h-[90vh] w-full flex items-center justify-center scale-95 transition-transform duration-300" id="lightbox-content">
    <img id="lightbox-image" src="" alt="Vista ampliada" class="max-w-full max-h-[85vh] rounded-xl object-contain shadow-2xl border border-neutral-800">
  </div>
</div>

<script src="/js/escpos-printer.js"></script>
<script>
  // Initialize printer client helper
  const printerClient = new WebPOSPrinterLocalServer('wss://localhost:4567');
  printerClient.connect();

  let activeCategory = 'all';

  function filterCategory(category) {
    activeCategory = category;
    
    // Update active tab styling
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.className = "tab-btn w-full text-left px-4 py-3 rounded-xl text-xs font-bold transition-all text-neutral-400 hover:text-white hover:bg-neutral-800 border border-transparent";
    });

    const activeTabBtn = document.getElementById(`tab-${category}`);
    if (activeTabBtn) {
      activeTabBtn.className = "tab-btn w-full text-left px-4 py-3 rounded-xl text-xs font-bold transition-all bg-blue-600 text-white shadow-md shadow-blue-500/10";
    }

    applyFilters();
  }

  function applyFilters() {
    const searchQuery = document.getElementById('search-manual').value.toLowerCase().trim();
    const normalizedQuery = removeAccents(searchQuery);

    document.querySelectorAll('.guide-card').forEach(card => {
      const cardCategory = card.getAttribute('data-category');
      const titleEl = card.querySelector('.guide-title');
      const contentEl = card.querySelector('.guide-content');
      
      const originalTitle = titleEl.textContent || '';
      const originalContent = contentEl.textContent || '';

      const normalizedTitle = removeAccents(originalTitle.toLowerCase());
      const normalizedContent = removeAccents(originalContent.toLowerCase());

      const matchesCategory = (activeCategory === 'all' || cardCategory === activeCategory);
      const matchesSearch = (!searchQuery || normalizedTitle.includes(normalizedQuery) || normalizedContent.includes(normalizedQuery));

      if (matchesCategory && matchesSearch) {
        card.classList.remove('hidden');
        // Simple highlighting inside titles and descriptions if searched
        if (searchQuery) {
          highlightText(titleEl, searchQuery);
          highlightText(contentEl, searchQuery);
        } else {
          // Restore original values
          titleEl.innerHTML = originalTitle;
          contentEl.innerHTML = contentEl.innerHTML.replace(/<mark class="bg-yellow-500\/30 text-yellow-250 py-0.5 px-1 rounded">/g, '').replace(/<\/mark>/g, '');
        }
      } else {
        card.classList.add('hidden');
      }
    });
  }

  function removeAccents(str) {
    return str.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
  }

  function highlightText(element, query) {
    const innerHTML = element.innerHTML;
    // We regex match the query ignoring html tags to prevent layout breakages
    const textNodes = [];
    
    function getTextNodes(node) {
      if (node.nodeType === 3) {
        textNodes.push(node);
      } else {
        for (let i = 0; i < node.childNodes.length; i++) {
          getTextNodes(node.childNodes[i]);
        }
      }
    }
    getTextNodes(element);

    textNodes.forEach(node => {
      const parent = node.parentNode;
      if (parent.tagName === 'MARK' || parent.tagName === 'SCRIPT' || parent.tagName === 'STYLE') return;

      const text = node.textContent;
      const normalizedText = removeAccents(text.toLowerCase());
      const queryIdx = normalizedText.indexOf(removeAccents(query.toLowerCase()));

      if (queryIdx > -1) {
        const matches = text.substr(queryIdx, query.length);
        const replacement = `<mark class="bg-yellow-500/35 text-yellow-100 py-0.5 rounded px-0.5">${matches}</mark>`;
        
        const wrapper = document.createElement('span');
        wrapper.innerHTML = text.replace(new RegExp(matches, 'i'), replacement);
        parent.replaceChild(wrapper, node);
      }
    });
  }

  // Bind live search
  document.getElementById('search-manual').addEventListener('input', applyFilters);

  // Lightbox Modal logic
  const lightbox = document.getElementById('image-lightbox');
  const lightboxImg = document.getElementById('lightbox-image');
  const lightboxContent = document.getElementById('lightbox-content');
  const lightboxClose = document.getElementById('lightbox-close');

  document.querySelectorAll('.guide-card img').forEach(img => {
    img.addEventListener('click', () => {
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightbox.classList.remove('pointer-events-none', 'opacity-0');
      lightbox.classList.add('opacity-100');
      setTimeout(() => {
        lightboxContent.classList.remove('scale-95');
        lightboxContent.classList.add('scale-100');
      }, 50);
    });
  });

  function closeLightbox() {
    lightboxContent.classList.remove('scale-100');
    lightboxContent.classList.add('scale-95');
    setTimeout(() => {
      lightbox.classList.remove('opacity-100');
      lightbox.classList.add('opacity-0', 'pointer-events-none');
    }, 200);
  }

  lightboxClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target === lightboxContent) {
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !lightbox.classList.contains('pointer-events-none')) {
      closeLightbox();
    }
  });
</script>

