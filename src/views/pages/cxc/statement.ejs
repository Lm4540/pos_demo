<%- include('../../partials/head', { title: 'Estado de Cuenta - ' + clientData.name }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col print:bg-white print:text-black">
  <!-- Nav Bar (Hidden in Print and PDF) -->
  <% if (typeof isPdf === 'undefined' || !isPdf) { %>
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md print:hidden">
    <div class="flex items-center gap-3">
      <a href="/clients" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Estado de Cuenta</span>
        <span class="text-xs block text-neutral-400 font-medium">Historial detallado de créditos y abonos del cliente</span>
      </div>
    </div>
    
    <div class="flex gap-3">
      <a href="/reports/statement/<%= clientData.id %>/pdf" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-all shadow-md shadow-blue-500/10 flex items-center gap-2 cursor-pointer">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <span>Descargar PDF</span>
      </a>
      <button onclick="window.print()" class="bg-neutral-850 hover:bg-neutral-800 text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-all border border-neutral-800 flex items-center gap-2 cursor-pointer">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        <span>Imprimir Estado</span>
      </button>
    </div>
  </nav>
  <% } %>

  <!-- Print Header (Only visible in Print or PDF mode) -->
  <div class="<%= (typeof isPdf !== 'undefined' && isPdf) ? 'block' : 'hidden print:block' %> p-6 border-b border-neutral-300">
    <div class="flex justify-between items-start">
      <div>
        <h1 class="text-2xl font-bold tracking-wide">RG Simple POS</h1>
        <p class="text-xs text-neutral-600">Sucursal: <%= clientData.branch ? clientData.branch.name : 'Central' %></p>
        <p class="text-xs text-neutral-600">Teléfono sucursal: <%= clientData.branch ? clientData.branch.phone : 'N/A' %></p>
      </div>
      <div class="text-right">
        <h2 class="text-xl font-bold text-neutral-800">Estado de Cuenta CxC</h2>
        <p class="text-xs text-neutral-600">Fecha de Impresión: <%= new Date().toLocaleString('es-SV') %></p>
      </div>
    </div>
  </div>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    
    <!-- Client Info Resume -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 print:grid-cols-4 print:gap-4">
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm print:border-neutral-300 print:bg-neutral-50 print:p-4">
        <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider print:text-neutral-600">Cliente</span>
        <h3 class="text-lg font-bold text-white mt-1 print:text-black leading-tight"><%= clientData.name %></h3>
        <span class="text-xs text-neutral-400 print:text-neutral-600 block mt-1 font-mono"><%= clientData.phone || 'Sin teléfono' %></span>
      </div>
      
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm print:border-neutral-300 print:bg-neutral-50 print:p-4">
        <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider print:text-neutral-600">Límite de Crédito</span>
        <h3 class="text-2xl font-extrabold text-blue-400 mt-1 print:text-black">$<%= parseFloat(clientData.creditLimit).toFixed(2) %></h3>
        <span class="text-xs text-neutral-400 print:text-neutral-600 block mt-1"><%= clientData.creditDays %> días plazo</span>
      </div>

      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm print:border-neutral-300 print:bg-neutral-50 print:p-4">
        <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider print:text-neutral-600">Saldo Pendiente (Deuda)</span>
        <h3 class="text-2xl font-extrabold text-amber-500 mt-1 print:text-black">$<%= parseFloat(clientData.currentBalance).toFixed(2) %></h3>
        <span class="text-xs text-neutral-400 print:text-neutral-600 block mt-1">Acumulado en compras</span>
      </div>

      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm print:border-neutral-300 print:bg-neutral-50 print:p-4">
        <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider print:text-neutral-600">Cupo Disponible</span>
        <% const available = parseFloat(clientData.creditLimit) - parseFloat(clientData.currentBalance) %>
        <h3 class="text-2xl font-extrabold text-emerald-400 mt-1 print:text-black">$<%= Math.max(0, available).toFixed(2) %></h3>
        <span class="text-xs text-neutral-400 print:text-neutral-600 block mt-1">Crédito libre para compras</span>
      </div>
    </div>

    <!-- Chronological Transactions Table -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm print:border-neutral-300 print:bg-white print:p-0">
      <h2 class="text-lg font-bold text-white mb-4 print:text-black print:text-base print:font-semibold print:mb-2 print:hidden">Historial de Transacciones</h2>
      
      <% if (transactions.length === 0) { %>
        <p class="text-sm text-neutral-500 py-8 text-center print:text-black">No se registran movimientos en la cuenta corriente de este cliente.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300 print:divide-neutral-300 print:text-black">
            <thead>
              <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs print:text-neutral-700">
                <th class="py-3 px-4 print:py-2">Fecha / Hora</th>
                <th class="py-3 px-4 print:py-2">Transacción</th>
                <th class="py-3 px-4 print:py-2">Referencia</th>
                <th class="py-3 px-4 text-right print:py-2">Cargo (+)</th>
                <th class="py-3 px-4 text-right print:py-2">Abono (-)</th>
                <th class="py-3 px-4 text-right print:py-2">Balance Deuda</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-800 print:divide-neutral-300">
              <% transactions.forEach(t => { %>
                <tr class="hover:bg-neutral-950/40 transition-colors hover:print:bg-transparent">
                  <td class="py-4 px-4 font-mono text-xs text-neutral-400 print:text-black print:py-2"><%= new Date(t.date).toLocaleString('es-SV') %></td>
                  <td class="py-4 px-4 print:py-2">
                    <% if (t.type === 'charge') { %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-red-950 text-red-400 border border-red-900/50 print:bg-transparent print:text-black print:border-0 print:p-0">Compra Crédito</span>
                    <% } else { %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-emerald-950 text-emerald-400 border border-emerald-900/50 print:bg-transparent print:text-black print:border-0 print:p-0">Abono Recibido</span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 font-mono text-xs text-neutral-300 print:text-black print:py-2"><%= t.reference %></td>
                  <td class="py-4 px-4 text-right font-mono font-semibold text-neutral-200 print:text-black print:py-2">
                    <%= t.type === 'charge' ? '+$' + t.amount.toFixed(2) : '-' %>
                  </td>
                  <td class="py-4 px-4 text-right font-mono font-semibold text-emerald-400 print:text-black print:py-2">
                    <%= t.type === 'payment' ? '-$' + t.amount.toFixed(2) : '-' %>
                  </td>
                  <td class="py-4 px-4 text-right font-mono font-bold text-white print:text-black print:py-2">
                    $<%= t.balance.toFixed(2) %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Print Footer Signature Area -->
    <div class="hidden print:flex justify-between items-center pt-24">
      <div class="w-1/3 border-t border-neutral-400 text-center text-xs text-neutral-600 pt-2">
        Entregado por (Firma Encargado)
      </div>
      <div class="w-1/3 border-t border-neutral-400 text-center text-xs text-neutral-600 pt-2">
        Recibido conforme (Firma Cliente)
      </div>
    </div>

  </main>
</div>

<%- include('../../partials/foot') %>
