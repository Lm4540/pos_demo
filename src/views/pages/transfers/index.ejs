<%- include('../../partials/head', { title: 'Traslados de Inventario' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Traslados de Inventario</span>
        <span class="text-xs block text-neutral-400 font-medium">Movimientos de Stock entre Sucursales</span>
      </div>
    </div>

    <div>
      <a href="/transfers/new" class="bg-blue-600 hover:bg-blue-500 px-4 py-2.5 rounded-xl text-xs font-bold text-white transition-all shadow-md shadow-blue-500/10 flex items-center gap-1.5 cursor-pointer">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        <span>Nuevo Traslado</span>
      </a>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-white mb-4">Registro de Traslados</h2>

      <% if (transfers.length === 0) { %>
        <div class="text-center py-12 text-neutral-500">
          <svg class="h-12 w-12 mx-auto text-neutral-700 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
          </svg>
          <p class="text-sm">No se han registrado traslados de inventario en tu sucursal.</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
            <thead>
              <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                <th class="py-3 px-4">Documento</th>
                <th class="py-3 px-4">Origen</th>
                <th class="py-3 px-4">Destino</th>
                <th class="py-3 px-4">Responsable</th>
                <th class="py-3 px-4">Fecha</th>
                <th class="py-3 px-4">Estado</th>
                <th class="py-3 px-4 text-right">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-800">
              <% transfers.forEach(t => { %>
                <tr class="hover:bg-neutral-950/40 transition-colors">
                  <td class="py-4 px-4 font-mono font-bold text-white"><%= t.transferNumber %></td>
                  <td class="py-4 px-4">
                    <span class="font-semibold text-neutral-200"><%= t.fromBranch ? t.fromBranch.name : 'N/A' %></span>
                  </td>
                  <td class="py-4 px-4">
                    <span class="font-semibold text-neutral-200"><%= t.toBranch ? t.toBranch.name : 'N/A' %></span>
                  </td>
                  <td class="py-4 px-4 text-neutral-400"><%= t.user ? t.user.fullName : 'Usuario' %></td>
                  <td class="py-4 px-4 text-xs text-neutral-500"><%= new Date(t.createdAt).toLocaleString('es-SV') %></td>
                  <td class="py-4 px-4">
                    <% if (t.status === 'transit') { %>
                      <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase bg-amber-950 text-amber-400 border border-amber-900/60">
                        En Tránsito
                      </span>
                    <% } else if (t.status === 'completed') { %>
                      <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase bg-emerald-950 text-emerald-400 border border-emerald-900/60">
                        Completado
                      </span>
                    <% } else { %>
                      <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase bg-red-950 text-red-400 border border-red-900/60">
                        Cancelado
                      </span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 text-right flex items-center justify-end gap-3.5">
                    <a href="/transfers/<%= t.id %>" class="text-indigo-400 hover:text-indigo-300 font-bold hover:underline cursor-pointer text-xs">
                      Ver Detalles
                    </a>
                    <% if (t.status === 'transit') { %>
                      <% if (user.roleId === 'admin' || user.branchId === t.toBranchId) { %>
                        <a href="/transfers/<%= t.id %>/receive" class="text-emerald-400 hover:text-emerald-300 font-bold hover:underline cursor-pointer text-xs">
                          Recibir
                        </a>
                      <% } %>
                      <% if (user.roleId === 'admin' || user.branchId === t.fromBranchId) { %>
                        <button onclick="cancelTransfer(<%= t.id %>, '<%= t.transferNumber %>')" class="text-red-500 hover:text-red-400 font-bold hover:underline cursor-pointer text-xs bg-transparent border-0 p-0">
                          Cancelar
                        </button>
                      <% } %>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>
</div>

<script>
  async function cancelTransfer(id, number) {
    showConfirm(`¿Estás seguro de que deseas cancelar el traslado ${number}? La mercadería será devuelta al stock de tu sucursal.`, async () => {
      try {
        const resp = await fetch(`/transfers/${id}/cancel`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const resData = await resp.json();
        if (resp.ok && resData.success) {
          showToast(resData.message, 'success');
          setTimeout(() => {
            window.location.reload();
          }, 800);
        } else {
          showToast(resData.message || 'Error al cancelar el traslado.', 'error');
        }
      } catch (err) {
        console.error(err);
        showToast('Error de red al cancelar el traslado.', 'error');
      }
    });
  }
</script>

<%- include('../../partials/foot') %>
