<%- include('../../partials/head', { title: 'Módulo de Gastos' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Módulo de Gastos</span>
        <span class="text-xs block text-neutral-400 font-medium">Registro de egresos y control de caja chica</span>
      </div>
    </div>
    
    <div>
      <button id="btn-open-modal" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-all shadow-md shadow-blue-500/10 flex items-center gap-2 cursor-pointer">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        <span>Registrar Gasto</span>
      </button>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    
    <!-- Resumen KPI -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
        <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider">Total de Gastos Registrados</span>
        <span class="text-3xl font-extrabold text-white mt-2">
          $<%= expenses.reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %>
        </span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
        <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider">Servicios</span>
        <span class="text-2xl font-extrabold text-blue-400 mt-2">
          $<%= expenses.filter(e => e.category === 'services').reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %>
        </span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
        <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider">Suministros</span>
        <span class="text-2xl font-extrabold text-indigo-400 mt-2">
          $<%= expenses.filter(e => e.category === 'supplies').reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %>
        </span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
        <span class="text-xs font-bold text-neutral-500 uppercase tracking-wider">Mantenimiento y Otros</span>
        <span class="text-2xl font-extrabold text-amber-400 mt-2">
          $<%= expenses.filter(e => e.category === 'maintenance' || e.category === 'other').reduce((sum, e) => sum + parseFloat(e.amount), 0).toFixed(2) %>
        </span>
      </div>
    </div>

    <!-- Tabla de Gastos -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-white mb-4">Historial de Egresos</h2>
      
      <% if (expenses.length === 0) { %>
        <p class="text-sm text-neutral-500 py-8 text-center">No se han registrado egresos o gastos en el sistema.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
            <thead>
              <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                <th class="py-3 px-4">Fecha Gasto</th>
                <th class="py-3 px-4">Categoría</th>
                <th class="py-3 px-4">Descripción</th>
                <th class="py-3 px-4">Sucursal</th>
                <th class="py-3 px-4 text-right">Monto</th>
                <th class="py-3 px-4 text-center">Evidencia</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-800">
              <% expenses.forEach(e => { %>
                <tr class="hover:bg-neutral-950/40 transition-colors">
                  <td class="py-4 px-4 font-mono text-xs text-neutral-400"><%= e.expenseDate %></td>
                  <td class="py-4 px-4">
                    <% if (e.category === 'services') { %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-950 text-blue-400 border border-blue-800/50">Servicios</span>
                    <% } else if (e.category === 'supplies') { %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-950 text-indigo-400 border border-indigo-800/50">Suministros</span>
                    <% } else if (e.category === 'maintenance') { %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-950 text-amber-400 border border-amber-800/50">Mantenimiento</span>
                    <% } else { %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-neutral-850 text-neutral-400 border border-neutral-700/50">Otro</span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 text-neutral-200"><%= e.description %></td>
                  <td class="py-4 px-4 text-neutral-400"><%= e.branch ? e.branch.name : 'N/A' %></td>
                  <td class="py-4 px-4 font-bold text-red-400 text-right font-mono">$<%= parseFloat(e.amount).toFixed(2) %></td>
                  <td class="py-4 px-4 text-center">
                    <% if (e.receiptPath) { %>
                      <a href="<%= e.receiptPath %>" target="_blank" class="inline-flex items-center gap-1 text-xs text-blue-400 hover:text-blue-300 font-semibold cursor-pointer">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        <span>Ver recibo</span>
                      </a>
                    <% } else { %>
                      <span class="text-xs text-neutral-600">Sin recibo</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>
</div>

<!-- Modal para Registrar Gasto -->
<div id="modal-expense" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50 transition-opacity duration-300">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-lg p-6 rounded-2xl shadow-2xl relative transform scale-95 opacity-0 transition-all duration-300" id="modal-card">
    <div class="flex items-center justify-between border-b border-neutral-800 pb-4 mb-4">
      <h3 class="text-lg font-bold text-white">Registrar Nuevo Gasto</h3>
      <button id="btn-close-modal" class="text-neutral-500 hover:text-white cursor-pointer transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <form id="form-expense" class="space-y-4">
      <div>
        <label for="description" class="block text-xs font-semibold text-neutral-400 uppercase mb-1">Descripción del Gasto *</label>
        <input type="text" id="description" name="description" required placeholder="Ej. Pago de energía eléctrica de la sucursal" class="w-full bg-neutral-950 border border-neutral-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-blue-500 focus:outline-none transition-all">
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="category" class="block text-xs font-semibold text-neutral-400 uppercase mb-1">Categoría *</label>
          <select id="category" name="category" required class="w-full bg-neutral-950 border border-neutral-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-blue-500 focus:outline-none transition-all">
            <option value="services">Servicios básicos</option>
            <option value="supplies">Insumos/Suministros</option>
            <option value="maintenance">Mantenimiento</option>
            <option value="other">Otro egreso</option>
          </select>
        </div>

        <div>
          <label for="amount" class="block text-xs font-semibold text-neutral-400 uppercase mb-1">Monto ($ USD) *</label>
          <input type="number" id="amount" name="amount" required step="0.01" min="0.01" placeholder="0.00" class="w-full bg-neutral-950 border border-neutral-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-blue-500 focus:outline-none transition-all font-mono">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="expenseDate" class="block text-xs font-semibold text-neutral-400 uppercase mb-1">Fecha del Gasto *</label>
          <input type="date" id="expenseDate" name="expenseDate" required class="w-full bg-neutral-950 border border-neutral-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-blue-500 focus:outline-none transition-all">
        </div>

        <div>
          <label for="receipt" class="block text-xs font-semibold text-neutral-400 uppercase mb-1">Evidencia (Recibo/Factura)</label>
          <input type="file" id="receipt" name="receipt" accept="image/jpeg,image/png,image/webp" class="w-full text-neutral-400 text-xs file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-neutral-800 file:text-white file:cursor-pointer hover:file:bg-neutral-700 transition-all">
        </div>
      </div>

      <!-- Selector de Origen de Pago / Caja -->
      <div class="border-t border-neutral-800 pt-4">
        <label for="turnId" class="block text-xs font-semibold text-neutral-400 uppercase mb-1">Origen de Pago / Descontar de *</label>
        <div id="turn-selector-container">
          <div id="turn-loading" class="flex items-center gap-2 text-neutral-500 text-sm py-2">
            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Cargando cajas disponibles...
          </div>
          <select id="turnId" name="turnId" required class="w-full bg-neutral-950 border border-neutral-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-blue-500 focus:outline-none transition-all hidden">
          </select>
          <div id="turn-no-options" class="hidden bg-amber-950/30 border border-amber-800/40 text-amber-300 text-xs rounded-xl px-4 py-3 mt-1">
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.268 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
              <span>No hay cajas abiertas con saldo disponible. Abra un turno de caja primero.</span>
            </div>
          </div>
        </div>
        <p id="turn-balance-hint" class="text-[11px] text-neutral-500 mt-1.5 hidden">
          Saldo disponible: <span id="turn-balance-value" class="font-mono font-semibold text-emerald-400">$0.00</span>
        </p>
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-neutral-800 mt-6">
        <button type="button" id="btn-cancel-modal" class="px-4 py-2.5 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" id="btn-submit-expense" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer shadow-md shadow-blue-500/10">
          Guardar Gasto
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  const modal = document.getElementById('modal-expense');
  const card = document.getElementById('modal-card');
  const btnOpen = document.getElementById('btn-open-modal');
  const btnClose = document.getElementById('btn-close-modal');
  const btnCancel = document.getElementById('btn-cancel-modal');
  const formExpense = document.getElementById('form-expense');
  const expenseDateInput = document.getElementById('expenseDate');
  const turnSelect = document.getElementById('turnId');
  const turnLoading = document.getElementById('turn-loading');
  const turnNoOptions = document.getElementById('turn-no-options');
  const turnBalanceHint = document.getElementById('turn-balance-hint');
  const turnBalanceValue = document.getElementById('turn-balance-value');
  const btnSubmit = document.getElementById('btn-submit-expense');

  // Track loaded turns data for balance hint
  let turnsData = [];

  // Set default date to today
  const today = new Date();
  const year = today.getFullYear();
  const month = String(today.getMonth() + 1).padStart(2, '0');
  const day = String(today.getDate()).padStart(2, '0');
  expenseDateInput.value = `${year}-${month}-${day}`;

  /**
   * Load available cashier turns from the API and populate the selector.
   */
  const loadAvailableTurns = async () => {
    turnSelect.classList.add('hidden');
    turnNoOptions.classList.add('hidden');
    turnBalanceHint.classList.add('hidden');
    turnLoading.classList.remove('hidden');
    turnSelect.innerHTML = '';
    turnsData = [];

    try {
      const resp = await fetch('/expenses/available-turns', {
        headers: { 'Accept': 'application/json' }
      });
      const result = await resp.json();

      if (result.success && result.turns.length > 0) {
        turnsData = result.turns;

      result.turns.forEach(turn => {
          const opt = document.createElement('option');
          opt.value = turn.id;
          const ownLabel = turn.isOwn ? ' ★ Mi caja' : '';
          opt.textContent = `${turn.boxName} - ${turn.userName} (Saldo: $${turn.balance.toFixed(2)})${ownLabel}`;
          opt.dataset.balance = turn.balance;
          opt.dataset.type = 'cashier';
          turnSelect.appendChild(opt);
        });

        // Always add the external payment option at the end
        const noneOpt = document.createElement('option');
        noneOpt.value = 'none';
        noneOpt.textContent = '💳 No descontar de caja (pago externo / banco)';
        noneOpt.dataset.balance = '-1';
        noneOpt.dataset.type = 'external';
        turnSelect.appendChild(noneOpt);

        turnLoading.classList.add('hidden');
        turnSelect.classList.remove('hidden');
        btnSubmit.disabled = false;

        // Show balance hint for the first selected option
        updateBalanceHint();
      } else {
        // No open turns, but still allow external payment
        const noneOpt = document.createElement('option');
        noneOpt.value = 'none';
        noneOpt.textContent = '💳 No descontar de caja (pago externo / banco)';
        noneOpt.dataset.balance = '-1';
        noneOpt.dataset.type = 'external';
        turnSelect.appendChild(noneOpt);

        turnLoading.classList.add('hidden');
        turnSelect.classList.remove('hidden');
        btnSubmit.disabled = false;

        // Show info that no cash registers are open
        turnNoOptions.classList.remove('hidden');
        turnNoOptions.querySelector('span').textContent = 'No hay cajas abiertas. Solo puede registrar gastos con pago externo (banco).';

        updateBalanceHint();
      }
    } catch (err) {
      console.error('Error loading turns:', err);
      turnLoading.classList.add('hidden');
      turnNoOptions.classList.remove('hidden');
      turnNoOptions.querySelector('span').textContent = 'Error al cargar las cajas disponibles.';
      btnSubmit.disabled = true;
    }
  };

  /**
   * Update the balance hint below the selector
   */
  const updateBalanceHint = () => {
    const selectedOption = turnSelect.options[turnSelect.selectedIndex];
    if (selectedOption && selectedOption.dataset.type === 'external') {
      // External payment: show a different hint
      turnBalanceValue.textContent = 'Pago externo (no afecta caja)';
      turnBalanceValue.className = 'font-mono font-semibold text-blue-400';
      turnBalanceHint.classList.remove('hidden');
      return;
    }
    if (selectedOption && selectedOption.dataset.balance !== undefined) {
      const balance = parseFloat(selectedOption.dataset.balance);
      turnBalanceValue.textContent = `$${balance.toFixed(2)}`;
      turnBalanceHint.classList.remove('hidden');

      // Color code based on balance
      if (balance <= 0) {
        turnBalanceValue.className = 'font-mono font-semibold text-red-400';
      } else if (balance < 50) {
        turnBalanceValue.className = 'font-mono font-semibold text-amber-400';
      } else {
        turnBalanceValue.className = 'font-mono font-semibold text-emerald-400';
      }
    } else {
      turnBalanceHint.classList.add('hidden');
    }
  };

  turnSelect.addEventListener('change', updateBalanceHint);

  const openModal = () => {
    modal.classList.remove('hidden');
    setTimeout(() => {
      card.classList.remove('scale-95', 'opacity-0');
    }, 10);
    // Load available turns every time the modal opens
    loadAvailableTurns();
  };

  const closeModal = () => {
    card.classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
      modal.classList.add('hidden');
    }, 200);
  };

  btnOpen.addEventListener('click', openModal);
  btnClose.addEventListener('click', closeModal);
  btnCancel.addEventListener('click', closeModal);

  formExpense.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = e.target.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    submitBtn.innerText = 'Guardando...';

    const formData = new FormData(formExpense);

    try {
      const response = await fetch('/expenses', {
        method: 'POST',
        body: formData
      });

      const result = await response.json();

      if (response.ok && result.success) {
        showToast(result.message, 'success');
        closeModal();
        // Recargar la página para ver el nuevo gasto reflejado
        setTimeout(() => {
          window.location.reload();
        }, 1000);
      } else {
        submitBtn.disabled = false;
        submitBtn.innerText = 'Guardar Gasto';
        showToast(result.message || 'Error al guardar el gasto.', 'error');
      }
    } catch (err) {
      console.error(err);
      showToast('Error de red al intentar registrar el gasto.', 'error');
      submitBtn.disabled = false;
      submitBtn.innerText = 'Guardar Gasto';
    }
  });
</script>

<%- include('../../partials/foot') %>
