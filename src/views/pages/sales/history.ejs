<%- include('../../partials/head', { title: 'Historial de Ventas' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/sales/pos-touch" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Historial de Ventas</span>
        <span class="text-xs block text-neutral-400 font-medium">Historial y reimpresión de comprobantes</span>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <!-- Contenedor de estado de impresora -->
      <div id="printer-status-container" class="flex items-center gap-2 mr-2"></div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-white mb-4">Tickets Emitidos</h2>

      <% if (sales.length === 0) { %>
      <p class="text-sm text-neutral-500 py-8 text-center">No se han emitido tickets en esta sucursal.</p>
      <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
          <thead>
            <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
              <th class="py-3 px-4">Fecha</th>
              <th class="py-3 px-4">Ticket</th>
              <th class="py-3 px-4">Cliente</th>
              <th class="py-3 px-4">Método Pago</th>
              <th class="py-3 px-4">Total</th>
              <th class="py-3 px-4 text-right">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-800">
            <% sales.forEach(s => { %>
            <tr class="hover:bg-neutral-950/40 transition-colors">
              <td class="py-4 px-4 font-mono text-xs text-neutral-400"><%= new Date(s.createdAt).toLocaleString('es-SV') %></td>
              <td class="py-4 px-4 font-bold text-white"><%= s.ticketNumber %></td>
              <td class="py-4 px-4 text-neutral-300"><%= s.client ? s.client.name : 'Consumidor Final' %></td>
              <td class="py-4 px-4">
                <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase <%= s.paymentMethod === 'cash' ? 'bg-emerald-950 text-emerald-400 border border-emerald-900/60' : 'bg-amber-950 text-amber-400 border border-amber-900/60' %>">
                  <%= s.paymentMethod === 'cash' ? 'Efectivo' : 'Crédito' %>
                </span>
              </td>
              <td class="py-4 px-4 font-bold text-white">$<%= parseFloat(s.totalAmount).toFixed(2) %></td>
              <td class="py-4 px-4 text-right space-x-3">
                <button onclick="reprintTicket(<%= JSON.stringify(s) %>)" class="text-blue-500 hover:text-blue-400 text-xs font-semibold hover:underline cursor-pointer">
                  Reimprimir
                </button>

                <!-- Void sale (allowed for supervisors/admins or trusted cashier with override) -->
                <button onclick="voidTicket(<%= s.id %>)" class="text-red-500 hover:text-red-400 text-xs font-semibold hover:underline cursor-pointer">
                  Anular
                </button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </main>
</div>

<script src="/js/escpos-printer.js"></script>
<script>
  const printerClient = new WebPOSPrinterLocalServer('wss://localhost:4567');
  printerClient.connect();

  async function reprintTicket(sale) {
    if (!sale) return;

    if (printerClient.status !== 'connected') {
      showToast('La ticketera de impresión está fuera de línea. Verifique la conexión.', 'error');
      return;
    }

    const sep = '----------------------------------------';
    try {
      const logoImgData = await window.loadImageData('/images/logo.png').catch(() => null);
      const builder = new ESCPOSBuilder();
      builder.initialize().setFont('A');

      // ── Encabezado ──
      builder.align('center');
      if (logoImgData) {
        builder.image(logoImgData).newLine();
      }
      builder.bold(true).doubleHeightWidth(true);
      builder.text('TIENDA EL KINDER').newLine();
      builder.doubleHeightWidth(false);
      builder.text('HACIENDA SAN CARLOS, CASA SAN CARLOS,').newLine();
      builder.text('CANTON EL SUNCITA, ACAJUTLA.').newLine();
      builder.text('TELÉFONO: 6314 0051').newLine();
      builder.text('PROPIETARIO').newLine();
      builder.text('ANTONIO CAMPOS').newLine();
      builder.bold(true);
      builder.text('** DUPLICADO REIMPRESO **').newLine();
      builder.bold(false);
      builder.text(sep).newLine();

      // ── Info del ticket ──
      builder.align('left');
      builder.text(`Ticket #: ${sale.ticketNumber}`).newLine();
      builder.text(`Fecha Emision: ${new Date(sale.createdAt).toLocaleString('es-SV')}`).newLine();
      builder.text(`Fecha Reimpr: ${new Date().toLocaleString('es-SV')}`).newLine();

      const clientName = sale.client ? sale.client.name : 'Consumidor Final';
      builder.text(`Cliente: ${clientName}`).newLine();
      builder.text(sep).newLine();

      // ── Encabezado de artículos ──
      builder.bold(true);
      builder.itemLine('Articulo', 'Cant', 'Precio', 'Total');
      builder.bold(false);
      builder.newLine();

      // ── Líneas de artículos ──
      sale.details.forEach(d => {
        const qty = parseInt(d.quantity, 10);
        const price = parseFloat(d.unitPrice);
        const net = qty * price;
        const name = d.customDescription || (d.product ? d.product.name : 'Artículo');
        builder.itemLine(name, qty, price, net);
        builder.newLine();
      });

      builder.text(sep).newLine();

      // ── Totales ──
      builder.align('right');
      builder.bold(true);
      builder.text(`TOTAL: $${parseFloat(sale.totalAmount).toFixed(2)}`);
      builder.bold(false).newLine();

      // ── Detalle de pago ──
      builder.text(sep).newLine();
      builder.align('left');
      let payLabel = 'Efectivo';
      if (sale.paymentMethod === 'card') payLabel = 'Tarjeta';
      if (sale.paymentMethod === 'credit') payLabel = 'Crédito';
      if (sale.paymentMethod === 'split') payLabel = 'Mixto';
      builder.text(`Forma de pago: ${payLabel}`).newLine();

      // ── Pie ──
      builder.newLine();
      builder.align('center');
      builder.text('¡Gracias por su compra!').newLine();
      builder.newLine();
      builder.align('center');
      builder.text('El Señor te bendiga y te guarde;').newLine();
      builder.text('el Señor haga resplandecer su rostro').newLine();
      builder.text('sobre ti, y tenga misericordia;').newLine();
      builder.text('el Señor alce sobre ti su rostro,').newLine();
      builder.text('y ponga en ti paz.').newLine();
      builder.newLine();
      builder.align('right').bold(true);
      builder.text('Números 6:24-26').newLine();
      builder.bold(false);
      builder.newLineN(4);
      builder.cut(false);

      await printerClient.sendCommands(builder.build());
      showToast('Ticket reimpreso con éxito vía térmica.', 'success');
    } catch (err) {
      console.error('Error al imprimir ticket por WebSocket:', err);
      showToast('Error al enviar el ticket a la impresora local.', 'error');
    }
  }

  async function voidTicket(id) {
    showConfirm('¿Estás seguro de que deseas anular esta venta? Esta acción revertirá el stock de los productos correspondientes y el saldo del cliente.', async () => {
      try {
        const resp = await fetch(`/sales/${id}`, {
          method: 'DELETE'
        });
        const resData = await resp.json();

        if (resData.success) {
          showToast('Venta anulada con éxito.', 'success');
          setTimeout(() => {
            window.location.reload();
          }, 1500);
        } else {
          showToast('Error: ' + resData.message, 'error');
        }
      } catch (err) {
        console.error(err);
        showToast('Ocurrió un error al anular la venta.', 'error');
      }
    });
  }
</script>

<%- include('../../partials/foot') %>