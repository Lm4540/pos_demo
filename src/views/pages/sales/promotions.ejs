<%- include('../../partials/head', { title: 'Promociones y Descuentos' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Promociones</span>
        <span class="text-xs block text-neutral-400 font-medium">Gestión de Ofertas y Descuentos Activos</span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <!-- List Area -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
        <h2 class="text-lg font-bold text-white">Promociones Registradas</h2>
        <div class="flex items-center gap-3">
          <!-- Search input -->
          <input 
            type="text" 
            id="promotion-search" 
            onkeyup="filterPromotions()" 
            class="px-4 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm w-64" 
            placeholder="Buscar promoción...">
          
          <% if (user.roleId === 'admin') { %>
            <button onclick="openCreateModal()" class="bg-blue-600 hover:bg-blue-500 px-4 py-2.5 rounded-xl text-xs font-bold text-white transition-all shadow-md shadow-blue-500/10 flex items-center gap-1.5 cursor-pointer">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              <span>Nueva Promoción</span>
            </button>
          <% } %>
        </div>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6" id="promotions-list-grid">
        <% promotions.forEach(p => { %>
          <% 
            const today = new Date().toISOString().slice(0, 10);
            let isExpired = false;
            if (p.endDate && p.endDate < today) {
              isExpired = true;
            }
          %>
          <div class="promotion-item bg-neutral-950 border border-neutral-800 rounded-2xl p-5 flex flex-col justify-between hover:border-neutral-700 transition-colors" data-name="<%= p.name.toLowerCase() %>">
            <div>
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-white leading-tight text-lg"><%= p.name %></h3>
                <div>
                  <% if (!p.isActive) { %>
                    <span class="px-2 py-0.5 text-[9px] font-bold uppercase rounded bg-neutral-800 text-neutral-400 border border-neutral-700">Inactiva</span>
                  <% } else if (isExpired) { %>
                    <span class="px-2 py-0.5 text-[9px] font-bold uppercase rounded bg-red-950/60 text-red-400 border border-red-900/60">Vencida</span>
                  <% } else { %>
                    <span class="px-2 py-0.5 text-[9px] font-bold uppercase rounded bg-emerald-950/60 text-emerald-400 border border-emerald-900/60">Activa</span>
                  <% } %>
                </div>
              </div>
              <p class="text-xs text-neutral-400 line-clamp-2 mb-4"><%= p.description || 'Sin descripción' %></p>
              
              <div class="space-y-2 text-xs">
                <div class="flex justify-between border-b border-neutral-900/60 pb-1.5">
                  <span class="text-neutral-500">Aplica a:</span>
                  <span class="font-bold text-white">
                    <%= p.product ? 'Producto: ' + p.product.name : (p.category ? 'Categoría: ' + p.category.name : 'Todo') %>
                  </span>
                </div>
                <div class="flex justify-between border-b border-neutral-900/60 pb-1.5">
                  <span class="text-neutral-500">Tipo:</span>
                  <span class="font-semibold text-blue-400 capitalize">
                    <%= p.type === 'percentage' ? 'Porcentaje' : (p.type === 'fixed_price' ? 'Precio Promocional' : 'Volumen (Bulk)') %>
                  </span>
                </div>
                <div class="flex justify-between border-b border-neutral-900/60 pb-1.5">
                  <span class="text-neutral-500">Detalle:</span>
                  <span class="font-bold text-white font-mono">
                    <%= p.type === 'percentage' ? p.value + '%' : (p.type === 'fixed_price' ? '$' + p.value : 'Lleva ' + p.buyQty + ' Paga ' + p.payQty) %>
                  </span>
                </div>
                <div class="flex justify-between">
                  <span class="text-neutral-500">Vigencia:</span>
                  <span class="text-neutral-400 font-mono text-[10px]">
                    <%= p.startDate ? new Date(p.startDate).toLocaleDateString('es-SV') : '∞' %> al 
                    <%= p.endDate ? new Date(p.endDate).toLocaleDateString('es-SV') : '∞' %>
                  </span>
                </div>
              </div>
            </div>
            
            <div class="flex justify-end gap-3 text-xs font-semibold mt-5 pt-3 border-t border-neutral-900">
              <% if (user.roleId === 'admin') { %>
                <button 
                  onclick="openEditModal(<%= JSON.stringify(p) %>)"
                  class="text-blue-500 hover:text-blue-400 hover:underline cursor-pointer">
                  Editar
                </button>
                <button 
                  onclick="deletePromotion(<%= p.id %>)"
                  class="text-red-500 hover:text-red-400 hover:underline cursor-pointer">
                  Eliminar
                </button>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </main>
</div>

<!-- Create Modal Overlay -->
<div id="create-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-lg p-6 rounded-2xl shadow-2xl relative max-h-[95vh] flex flex-col">
    <div class="flex justify-between items-center pb-3 border-b border-neutral-800 mb-4">
      <h2 class="text-xl font-bold text-white">Registrar Nueva Promoción</h2>
      <button onclick="closeCreateModal()" class="text-neutral-500 hover:text-white cursor-pointer transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <% if (error) { %>
      <div class="bg-red-950/40 border border-red-800 text-red-200 px-4 py-2 rounded-lg text-xs mb-4">
        <%= error %>
      </div>
    <% } %>

    <form id="create-promotion-form" action="/promotions" method="POST" class="space-y-4 overflow-y-auto flex-grow pr-1" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Guardando...';">
      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Nombre de la Promoción *</label>
          <input type="text" name="name" required class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-xs" placeholder="Ej. Oferta Fin de Año o Coca Cola 3x2">
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Descripción</label>
          <input type="text" name="description" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-xs" placeholder="Opcional...">
        </div>
        
        <div class="relative">
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Aplica a Producto</label>
          <div class="flex gap-2">
            <input type="text" id="create-productSearch" placeholder="Buscar por nombre o código..." class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs">
            <button type="button" onclick="clearSelectedProduct('create')" class="px-3 py-2 bg-neutral-800 hover:bg-neutral-750 text-neutral-300 rounded-xl text-xs border border-neutral-750">✕</button>
          </div>
          <input type="hidden" name="productId" id="create-productId">
          <div id="create-productDropdown" class="hidden absolute bg-neutral-950 border border-neutral-850 rounded-xl mt-1 max-h-48 overflow-y-auto z-50 text-xs w-full shadow-lg divide-y divide-neutral-800/60"></div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Aplica a Categoría</label>
          <select name="categoryId" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs">
            <option value="">-- No aplicar por categoría --</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Tipo de Promoción *</label>
          <select name="type" id="create-type" onchange="toggleFormFields('create')" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs">
            <option value="percentage">Porcentaje (%) de Descuento</option>
            <option value="fixed_price">Precio Promocional Fijo ($)</option>
            <option value="bulk">Volumen (Lleva X, Paga Y)</option>
          </select>
        </div>

        <div id="create-value-container">
          <label id="create-value-label" class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Porcentaje de Descuento *</label>
          <input type="number" step="0.01" name="value" id="create-value" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono" placeholder="10.00">
        </div>

        <div id="create-bulk-container" class="col-span-2 grid grid-cols-2 gap-4 hidden">
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Lleva (Cantidad) *</label>
            <input type="number" name="buyQty" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono" placeholder="3">
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Paga (Cantidad) *</label>
            <input type="number" name="payQty" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono" placeholder="2">
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fecha Inicio Vigencia</label>
          <input type="date" name="startDate" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono">
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fecha Fin Vigencia</label>
          <input type="date" name="endDate" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono">
        </div>
        
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Estado</label>
          <select name="isActive" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs">
            <option value="true">Activa</option>
            <option value="false">Inactiva</option>
          </select>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-3 border-t border-neutral-800">
        <button type="button" onclick="closeCreateModal()" class="px-4 py-2.5 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer shadow-md shadow-blue-500/10">
          Guardar Promoción
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal Overlay -->
<div id="edit-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-lg p-6 rounded-2xl shadow-2xl relative max-h-[95vh] flex flex-col">
    <div class="flex justify-between items-center pb-3 border-b border-neutral-800 mb-4">
      <h2 class="text-xl font-bold text-white">Editar Promoción</h2>
      <button onclick="closeEditModal()" class="text-neutral-500 hover:text-white cursor-pointer transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <form id="edit-form" method="POST" class="space-y-4 overflow-y-auto flex-grow pr-1" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Guardando...';">
      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Nombre de la Promoción *</label>
          <input type="text" id="edit-name" name="name" required class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-xs">
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Descripción</label>
          <input type="text" id="edit-description" name="description" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-xs">
        </div>
        
        <div class="relative">
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Aplica a Producto</label>
          <div class="flex gap-2">
            <input type="text" id="edit-productSearch" placeholder="Buscar por nombre o código..." class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs">
            <button type="button" onclick="clearSelectedProduct('edit')" class="px-3 py-2 bg-neutral-800 hover:bg-neutral-750 text-neutral-300 rounded-xl text-xs border border-neutral-750">✕</button>
          </div>
          <input type="hidden" name="productId" id="edit-productId">
          <div id="edit-productDropdown" class="hidden absolute bg-neutral-950 border border-neutral-850 rounded-xl mt-1 max-h-48 overflow-y-auto z-50 text-xs w-full shadow-lg divide-y divide-neutral-800/60"></div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Aplica a Categoría</label>
          <select id="edit-categoryId" name="categoryId" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs">
            <option value="">-- No aplicar por categoría --</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Tipo de Promoción *</label>
          <select id="edit-type" name="type" onchange="toggleFormFields('edit')" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs">
            <option value="percentage">Porcentaje (%) de Descuento</option>
            <option value="fixed_price">Precio Promocional Fijo ($)</option>
            <option value="bulk">Volumen (Lleva X, Paga Y)</option>
          </select>
        </div>

        <div id="edit-value-container">
          <label id="edit-value-label" class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Porcentaje de Descuento *</label>
          <input type="number" step="0.01" name="value" id="edit-value" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono">
        </div>

        <div id="edit-bulk-container" class="col-span-2 grid grid-cols-2 gap-4 hidden">
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Lleva (Cantidad) *</label>
            <input type="number" id="edit-buyQty" name="buyQty" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono">
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Paga (Cantidad) *</label>
            <input type="number" id="edit-payQty" name="payQty" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono">
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fecha Inicio Vigencia</label>
          <input type="date" id="edit-startDate" name="startDate" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono">
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fecha Fin Vigencia</label>
          <input type="date" id="edit-endDate" name="endDate" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs font-mono">
        </div>
        
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Estado</label>
          <select id="edit-isActive" name="isActive" class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs">
            <option value="true">Activa</option>
            <option value="false">Inactiva</option>
          </select>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-3 border-t border-neutral-800">
        <button type="button" onclick="closeEditModal()" class="px-4 py-2.5 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer shadow-md shadow-blue-500/10">
          Guardar Cambios
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function filterPromotions() {
    const query = document.getElementById('promotion-search').value.toLowerCase();
    const items = document.querySelectorAll('.promotion-item');
    items.forEach(item => {
      const name = item.dataset.name;
      if (name.includes(query)) {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
      }
    });
  }

  function toggleFormFields(prefix) {
    const type = document.getElementById(`${prefix}-type`).value;
    const valContainer = document.getElementById(`${prefix}-value-container`);
    const valLabel = document.getElementById(`${prefix}-value-label`);
    const valInput = document.getElementById(`${prefix}-value`);
    const bulkContainer = document.getElementById(`${prefix}-bulk-container`);

    if (type === 'bulk') {
      valContainer.classList.add('hidden');
      valInput.required = false;
      bulkContainer.classList.remove('hidden');
    } else {
      bulkContainer.classList.add('hidden');
      valContainer.classList.remove('hidden');
      valInput.required = true;
      
      if (type === 'percentage') {
        valLabel.innerText = 'Porcentaje de Descuento *';
        valInput.placeholder = '10.00';
      } else {
        valLabel.innerText = 'Precio Promocional Fijo ($) *';
        valInput.placeholder = '1.50';
      }
    }
  }

  const productsList = <%- JSON.stringify(products) %>;

  function setupProductSearch(prefix) {
    const searchInput = document.getElementById(`${prefix}-productSearch`);
    const idInput = document.getElementById(`${prefix}-productId`);
    const dropdown = document.getElementById(`${prefix}-productDropdown`);
    if (!searchInput || !dropdown) return;

    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      if (!query) {
        dropdown.classList.add('hidden');
        return;
      }

      const matches = productsList.filter(p => 
        p.name.toLowerCase().includes(query) || 
        (p.barCode && p.barCode.toLowerCase().includes(query))
      ).slice(0, 10);

      if (matches.length === 0) {
        dropdown.innerHTML = `<div class="p-3 text-neutral-500 text-center">No se encontraron productos</div>`;
      } else {
        dropdown.innerHTML = matches.map(p => `
          <div onclick="selectProductForPromo('${prefix}', ${p.id}, '${p.name.replace(/'/g, "\\'")}', '${p.barCode || ''}')" class="p-2.5 hover:bg-neutral-800 cursor-pointer text-white flex justify-between gap-2 transition-colors">
            <span class="font-bold text-xs">${p.name}</span>
            <span class="font-mono text-[10px] text-neutral-450">${p.barCode || 'Sin código'}</span>
          </div>
        `).join('');
      }
      dropdown.classList.remove('hidden');
    });

    // Close dropdown on click outside
    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.classList.add('hidden');
      }
    });
  }

  function selectProductForPromo(prefix, id, name, barcode) {
    document.getElementById(`${prefix}-productId`).value = id;
    document.getElementById(`${prefix}-productSearch`).value = `${name} (${barcode || 'Sin código'})`;
    document.getElementById(`${prefix}-productDropdown`).classList.add('hidden');
  }

  function clearSelectedProduct(prefix) {
    document.getElementById(`${prefix}-productId`).value = '';
    document.getElementById(`${prefix}-productSearch`).value = '';
    document.getElementById(`${prefix}-productDropdown`).classList.add('hidden');
  }

  function openCreateModal() {
    document.getElementById('create-modal').classList.remove('hidden');
    clearSelectedProduct('create');
    toggleFormFields('create');
  }

  function closeCreateModal() {
    document.getElementById('create-modal').classList.add('hidden');
  }

  function openEditModal(promo) {
    document.getElementById('edit-form').action = `/promotions/${promo.id}/edit`;
    document.getElementById('edit-name').value = promo.name;
    document.getElementById('edit-description').value = promo.description || '';
    
    document.getElementById('edit-productId').value = promo.productId || '';
    if (promo.productId) {
      const prod = productsList.find(p => p.id === promo.productId);
      document.getElementById('edit-productSearch').value = prod ? `${prod.name} (${prod.barCode || 'Sin código'})` : '';
    } else {
      document.getElementById('edit-productSearch').value = '';
    }

    document.getElementById('edit-categoryId').value = promo.categoryId || '';
    document.getElementById('edit-type').value = promo.type;
    
    if (promo.type === 'bulk') {
      document.getElementById('edit-buyQty').value = promo.buyQty || '';
      document.getElementById('edit-payQty').value = promo.payQty || '';
      document.getElementById('edit-value').value = '';
    } else {
      document.getElementById('edit-value').value = promo.value || '';
      document.getElementById('edit-buyQty').value = '';
      document.getElementById('edit-payQty').value = '';
    }

    document.getElementById('edit-startDate').value = promo.startDate || '';
    document.getElementById('edit-endDate').value = promo.endDate || '';
    document.getElementById('edit-isActive').value = promo.isActive ? 'true' : 'false';
    
    document.getElementById('edit-modal').classList.remove('hidden');
    toggleFormFields('edit');
  }

  function closeEditModal() {
    document.getElementById('edit-modal').classList.add('hidden');
  }

  async function deletePromotion(id) {
    showConfirm('¿Estás seguro de que deseas eliminar esta promoción?', async () => {
      try {
        const resp = await fetch(`/promotions/${id}`, { method: 'DELETE' });
        const resData = await resp.json();
        if (resData.success) {
          window.location.reload();
        } else {
          showToast('Error: ' + resData.message, 'error');
        }
      } catch (err) {
        console.error(err);
        showToast('Ocurrió un error al eliminar la promoción.', 'error');
      }
    });
  }

  // Auto-open create modal if error exists
  <% if (error) { %>
    window.onload = function() {
      openCreateModal();
    }
  <% } %>

  // Success indicator toast
  window.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('success')) {
      showToast('Operación realizada con éxito.', 'success');
      window.history.replaceState({}, document.title, window.location.pathname);
    }
    setupProductSearch('create');
    setupProductSearch('edit');
  });
</script>

<%- include('../../partials/foot') %>
