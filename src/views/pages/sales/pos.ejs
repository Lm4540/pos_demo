<script>
  const promotions = <%- JSON.stringify(promotions) %>;
  let cart = [];
  let paymentMethod = 'cash'; // Default method
  let lastCompletedCart = [];
  let lastCompletedPaymentMethod = 'cash';

  function getCartTotals() {
    let totalGross = 0;
    let totalDiscount = 0;
    
    cart.forEach(item => {
      const price = parseFloat(item.price);
      let promo = promotions.find(p => p.productId === item.productId);
      if (!promo && item.categoryId) {
        promo = promotions.find(p => p.categoryId === item.categoryId);
      }
      
      let discount = 0;
      if (promo) {
        if (promo.type === 'percentage') {
          discount = price * (parseFloat(promo.value) / 100) * item.quantity;
        } else if (promo.type === 'fixed_price') {
          const promoPrice = parseFloat(promo.value);
          if (promoPrice < price) {
            discount = (price - promoPrice) * item.quantity;
          }
        } else if (promo.type === 'bulk') {
          const buyQty = promo.buyQty;
          const payQty = promo.payQty;
          if (item.quantity >= buyQty) {
            const groups = Math.floor(item.quantity / buyQty);
            const freeUnits = groups * (buyQty - payQty);
            discount = freeUnits * price;
          }
        }
      }
      totalGross += price * item.quantity;
      totalDiscount += discount;
    });
    
    return {
      gross: totalGross,
      discount: totalDiscount,
      net: totalGross - totalDiscount
    };
  }

  function getLastCompletedCartTotals() {
    let totalGross = 0;
    let totalDiscount = 0;
    
    lastCompletedCart.forEach(item => {
      const price = parseFloat(item.price);
      let promo = promotions.find(p => p.productId === item.productId);
      if (!promo && item.categoryId) {
        promo = promotions.find(p => p.categoryId === item.categoryId);
      }
      
      let discount = 0;
      if (promo) {
        if (promo.type === 'percentage') {
          discount = price * (parseFloat(promo.value) / 100) * item.quantity;
        } else if (promo.type === 'fixed_price') {
          const promoPrice = parseFloat(promo.value);
          if (promoPrice < price) {
            discount = (price - promoPrice) * item.quantity;
          }
        } else if (promo.type === 'bulk') {
          const buyQty = promo.buyQty;
          const payQty = promo.payQty;
          if (item.quantity >= buyQty) {
            const groups = Math.floor(item.quantity / buyQty);
            const freeUnits = groups * (buyQty - payQty);
            discount = freeUnits * price;
          }
        }
      }
      totalGross += price * item.quantity;
      totalDiscount += discount;
    });
    
    return {
      gross: totalGross,
      discount: totalDiscount,
      net: totalGross - totalDiscount
    };
  }

  function filterFrequentByCategory(catId) {
    // Cambiar clases de los botones de pestañas
    document.querySelectorAll('.cat-tab-btn').forEach(btn => {
      btn.className = "cat-tab-btn py-1.5 px-3 rounded-lg text-xs font-bold bg-neutral-950 text-neutral-400 hover:text-white border border-neutral-850 hover:border-neutral-700 transition-all cursor-pointer whitespace-nowrap";
    });
    
    const activeTab = document.getElementById(catId === 'all' ? 'tab-cat-all' : `tab-cat-${catId}`);
    if (activeTab) {
      activeTab.className = "cat-tab-btn py-1.5 px-3 rounded-lg text-xs font-bold bg-blue-600 text-white transition-all cursor-pointer whitespace-nowrap shadow-md";
    }

    // Ocultar/Mostrar productos
    document.querySelectorAll('.frequent-product-card').forEach(card => {
      const cardCatId = card.dataset.categoryId;
      if (catId === 'all' || cardCatId === String(catId)) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  }

  // Unified Barcode Scanner Processing Function
  async function processScannerCode(code) {
    try {
      const resp = await fetch(`/sales/api/products?q=${encodeURIComponent(code)}`);
      const results = await resp.json();
      if (results && results.length > 0) {
        const bp = results[0];
        addToCart(bp.id, bp.name, bp.salePrice, bp.totalStock, bp.categoryId);
        showToast(`Agregado: ${bp.name} (Cant: 1)`, 'success');
      } else {
        showToast(`Código de barras "${code}" no encontrado o sin existencias.`, 'error');
      }
    } catch (err) {
      console.error(err);
      showToast('Error al procesar el código de barras.', 'error');
    }
  }

  // Manual Barcode Input Search
  document.getElementById('barcode-input').addEventListener('keypress', async (e) => {
    if (e.key === 'Enter') {
      const code = e.target.value.trim();
      if (code === '') return;
      e.target.value = '';
      await processScannerCode(code);
    }
  });

  // Global Barcode Keypress Interception (Document level)
  let scannerBuffer = '';
  let lastKeyTime = Date.now();

  document.addEventListener('keydown', (e) => {
    const activeEl = document.activeElement;
    if (activeEl.tagName === 'INPUT' || activeEl.tagName === 'SELECT' || activeEl.tagName === 'TEXTAREA') {
      return;
    }

    if (e.ctrlKey || e.altKey || e.metaKey || e.key === 'Shift') {
      return;
    }

    const currentTime = Date.now();
    // Hardware scanners type very fast. If delay > 80ms, reset manual typing buffer
    if (currentTime - lastKeyTime > 80) {
      scannerBuffer = '';
    }
    lastKeyTime = currentTime;

    if (e.key.length === 1) {
      scannerBuffer += e.key;
    } else if (e.key === 'Enter') {
      const code = scannerBuffer.trim();
      if (code.length >= 3) {
        e.preventDefault();
        scannerBuffer = '';
        processScannerCode(code);
      }
    }
  });

  // Predictive Text Search
  const searchInput = document.getElementById('search-input');
  const dropdown = document.getElementById('autocomplete-results');

  searchInput.addEventListener('input', async () => {
    const val = searchInput.value.trim();
    if (val.length < 2) {
      dropdown.innerHTML = '';
      dropdown.classList.add('hidden');
      return;
    }

    try {
      const resp = await fetch(`/sales/api/products?q=${encodeURIComponent(val)}`);
      const results = await resp.json();

      if (results.length === 0) {
        dropdown.innerHTML = '<p class="text-xs text-neutral-500 p-3 text-center">No se encontraron artículos con stock.</p>';
      } else {
        dropdown.innerHTML = results.map(bp => `
          <button 
            type="button"
            onclick="selectDropdownItem(${bp.id}, '${bp.name.replace(/'/g, "\\'")}', ${bp.salePrice}, ${bp.totalStock}, ${bp.categoryId || 'null'})"
            class="w-full text-left px-4 py-3 hover:bg-neutral-950 flex justify-between items-center border-b border-neutral-800/40 cursor-pointer">
            <div>
              <span class="text-sm font-bold text-white block">${bp.name}</span>
              <span class="text-xs text-neutral-500">Cód: ${bp.barCode || 'N/A'}</span>
            </div>
            <div class="text-right">
              <span class="text-sm font-bold text-blue-400 block">$${parseFloat(bp.salePrice).toFixed(2)}</span>
              <span class="text-[10px] text-neutral-500">Stock: ${bp.totalStock}</span>
            </div>
          </button>
        `).join('');
      }
      dropdown.classList.remove('hidden');
    } catch (err) {
      console.error(err);
    }
  });

  // Hide autocomplete when clicking elsewhere
  document.addEventListener('click', (e) => {
    if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.classList.add('hidden');
    }
  });

  function selectDropdownItem(id, name, price, stock, categoryId) {
    addToCart(id, name, price, stock, categoryId);
    searchInput.value = '';
    dropdown.classList.add('hidden');
  }

  // Cart operations
  function addToCart(productId, name, price, stock, categoryId) {
    const existing = cart.find(i => i.productId === productId);
    if (existing) {
      if (existing.quantity >= stock) {
        showToast(`Stock insuficiente. Solo quedan ${stock} unidades de este artículo.`, 'warning');
        return;
      }
      existing.quantity += 1;
    } else {
      if (stock <= 0) {
        showToast('Producto agotado.', 'warning');
        return;
      }
      cart.push({ productId, name, price, quantity: 1, stock, categoryId });
    }
    renderCart();
  }

  function updateQty(productId, delta) {
    const item = cart.find(i => i.productId === productId);
    if (!item) return;

    if (delta > 0 && item.quantity >= item.stock) {
      showToast(`Límite de stock alcanzado (${item.stock} disponibles).`, 'warning');
      return;
    }

    item.quantity += delta;
    if (item.quantity <= 0) {
      cart = cart.filter(i => i.productId !== productId);
    }
    renderCart();
  }

  function updateQtyDirect(productId, val) {
    const item = cart.find(i => i.productId === productId);
    if (!item) return;

    let qty = parseInt(val);
    if (isNaN(qty) || qty < 0) {
      qty = 1;
    }

    if (qty === 0) {
      cart = cart.filter(i => i.productId !== productId);
    } else if (qty > item.stock) {
      showToast(`Stock insuficiente. Solo quedan ${item.stock} unidades de este artículo.`, 'warning');
      item.quantity = item.stock;
    } else {
      item.quantity = qty;
    }
    renderCart();
  }

  function clearCart() {
    cart = [];
    renderCart();
  }

  function renderCart() {
    const container = document.getElementById('cart-items-container');
    
    if (cart.length === 0) {
      container.innerHTML = `
        <div class="text-center py-12 text-neutral-500 text-sm" id="empty-cart-msg">
          <svg class="h-10 w-10 mx-auto text-neutral-700 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span>El carrito está vacío</span>
        </div>
      `;
      document.getElementById('cart-subtotal').innerText = '$0.00';
      document.getElementById('cart-total').innerText = '$0.00';
      return;
    }

    let totalGross = 0;
    let totalDiscount = 0;

    container.innerHTML = cart.map(item => {
      const price = parseFloat(item.price);
      
      // Buscar promoción aplicable
      let promo = promotions.find(p => p.productId === item.productId);
      if (!promo && item.categoryId) {
        promo = promotions.find(p => p.categoryId === item.categoryId);
      }

      let discount = 0;
      let promoText = '';

      if (promo) {
        if (promo.type === 'percentage') {
          const pct = parseFloat(promo.value);
          discount = price * (pct / 100) * item.quantity;
          promoText = `<span class="text-[10px] font-bold text-red-400 block">Desc. ${pct}% aplicado</span>`;
        } else if (promo.type === 'fixed_price') {
          const promoPrice = parseFloat(promo.value);
          if (promoPrice < price) {
            discount = (price - promoPrice) * item.quantity;
            promoText = `<span class="text-[10px] font-bold text-red-400 block">Precio promo: $${promoPrice.toFixed(2)}</span>`;
          }
        } else if (promo.type === 'bulk') {
          const buyQty = promo.buyQty;
          const payQty = promo.payQty;
          if (item.quantity >= buyQty) {
            const groups = Math.floor(item.quantity / buyQty);
            const freeUnits = groups * (buyQty - payQty);
            discount = freeUnits * price;
            promoText = `<span class="text-[10px] font-bold text-red-400 block">Promo ${buyQty}x${payQty} aplicada (-$${discount.toFixed(2)})</span>`;
          } else {
            promoText = `<span class="text-[9px] text-neutral-500 block">Lleva ${buyQty}x${payQty} disponible</span>`;
          }
        }
      }

      const itemGross = price * item.quantity;
      const itemNet = itemGross - discount;
      
      totalGross += itemGross;
      totalDiscount += discount;

      return `
      <div class="flex items-center justify-between p-3 bg-neutral-950 border border-neutral-800 rounded-xl hover:border-neutral-750 transition-colors">
        <div class="flex-grow max-w-[50%]">
          <span class="text-xs font-bold text-white block truncate">${item.name}</span>
          <span class="text-[10px] text-neutral-500">$${price.toFixed(2)} c/u</span>
          ${promoText}
        </div>
        <div class="flex items-center gap-2">
          <button onclick="updateQty(${item.productId}, -1)" class="h-6 w-6 rounded bg-neutral-800 hover:bg-neutral-700 flex items-center justify-center text-white text-xs cursor-pointer">-</button>
          <input type="number" min="0" max="${item.stock}" value="${item.quantity}" onchange="updateQtyDirect(${item.productId}, this.value)" class="w-12 text-center bg-neutral-900 border border-neutral-800 text-white text-xs rounded font-bold py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500">
          <button onclick="updateQty(${item.productId}, 1)" class="h-6 w-6 rounded bg-neutral-800 hover:bg-neutral-700 flex items-center justify-center text-white text-xs cursor-pointer">+</button>
        </div>
        <div class="text-right w-20 flex flex-col">
          <span class="text-xs font-bold text-white">$${itemNet.toFixed(2)}</span>
          ${discount > 0 ? `<span class="text-[9px] text-neutral-500 line-through">$${itemGross.toFixed(2)}</span>` : ''}
        </div>
      </div>
      `;
    }).join('');

    const totalNet = totalGross - totalDiscount;
    document.getElementById('cart-subtotal').innerText = `$${totalGross.toFixed(2)}`;

    const discountRow = document.getElementById('cart-discount-row');
    const discountSpan = document.getElementById('cart-discount');
    if (totalDiscount > 0) {
      discountSpan.innerText = `-$${totalDiscount.toFixed(2)}`;
      discountRow.classList.remove('hidden');
    } else {
      discountRow.classList.add('hidden');
    }

    document.getElementById('cart-total').innerText = `$${totalNet.toFixed(2)}`;

    if (paymentMethod === 'split') {
      document.getElementById('split-cash-input').value = totalNet.toFixed(2);
      document.getElementById('split-card-input').value = '0.00';
      document.getElementById('split-credit-input').value = '0.00';
      updateSplitBreakdownTotals();
    }
    updateChangeCalculation();
  }

  function setPaymentMethod(method) {
    paymentMethod = method;
    const btnCash = document.getElementById('btn-pay-cash');
    const btnCard = document.getElementById('btn-pay-card');
    const btnCredit = document.getElementById('btn-pay-credit');
    const btnSplit = document.getElementById('btn-pay-split');
    const clientSelect = document.getElementById('client-id-select');
    const splitBreakdown = document.getElementById('split-payment-breakdown');
    const cashReceivedContainer = document.getElementById('cash-received-container');

    // Reset styles
    const activeClass = "py-3 rounded-xl text-sm font-bold border border-blue-500 bg-blue-950/40 text-blue-400 transition-all cursor-pointer text-center";
    const inactiveClass = "py-3 rounded-xl text-sm font-bold border border-neutral-800 bg-neutral-950 text-neutral-400 transition-all cursor-pointer text-center";
    
    btnCash.className = inactiveClass;
    btnCard.className = inactiveClass;
    btnCredit.className = inactiveClass;
    btnSplit.className = inactiveClass;

    if (method === 'cash') {
      btnCash.className = activeClass;
      splitBreakdown.classList.add('hidden');
      if (cashReceivedContainer) cashReceivedContainer.classList.remove('hidden');
    } else if (method === 'card') {
      btnCard.className = activeClass;
      splitBreakdown.classList.add('hidden');
      if (cashReceivedContainer) cashReceivedContainer.classList.add('hidden');
    } else if (method === 'credit') {
      btnCredit.className = activeClass;
      splitBreakdown.classList.add('hidden');
      if (cashReceivedContainer) cashReceivedContainer.classList.add('hidden');
      const searchBtn = document.getElementById('btn-open-client-search');
      if (searchBtn) searchBtn.focus();
    } else if (method === 'split') {
      btnSplit.className = activeClass;
      splitBreakdown.classList.remove('hidden');
      if (cashReceivedContainer) cashReceivedContainer.classList.remove('hidden');
      
      const subtotal = cart.reduce((sum, item) => sum + (parseFloat(item.price) * item.quantity), 0);
      document.getElementById('split-cash-input').value = subtotal.toFixed(2);
      document.getElementById('split-card-input').value = '0.00';
      document.getElementById('split-credit-input').value = '0.00';
      updateSplitBreakdownTotals();
    }
    
    // Reset received cash on payment method change
    const cashReceivedInput = document.getElementById('cash-received-input');
    if (cashReceivedInput) cashReceivedInput.value = '0.00';
    updateChangeCalculation();
    
    checkClientCreditStatus();
  }

  function updateSplitBreakdownTotals() {
    const cashVal = parseFloat(document.getElementById('split-cash-input').value) || 0;
    const cardVal = parseFloat(document.getElementById('split-card-input').value) || 0;
    const creditVal = parseFloat(document.getElementById('split-credit-input').value) || 0;

    const subtotal = cart.reduce((sum, item) => sum + (parseFloat(item.price) * item.quantity), 0);
    const sum = cashVal + cardVal + creditVal;
    const remaining = subtotal - sum;

    document.getElementById('split-total-sum').innerText = `$${sum.toFixed(2)}`;
    
    const remainingSpan = document.getElementById('split-remaining');
    if (Math.abs(remaining) < 0.01) {
      remainingSpan.innerText = "$0.00 (Cuadrado)";
      remainingSpan.className = "font-bold text-emerald-400 font-mono text-[10px]";
    } else {
      remainingSpan.innerText = (remaining > 0 ? "Falta " : "Sobra ") + `$${Math.abs(remaining).toFixed(2)}`;
      remainingSpan.className = "font-bold text-red-400 font-mono text-[10px]";
    }
    updateChangeCalculation();
  }

  // Hook input events for split values
  ['split-cash-input', 'split-card-input', 'split-credit-input'].forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.addEventListener('input', updateSplitBreakdownTotals);
    }
  });

  function checkClientCreditStatus() {
    const select = document.getElementById('client-id-select');
    const selectedOpt = select.options[select.selectedIndex];
    const warningDiv = document.getElementById('client-overdue-warning');
    const daysSpan = document.getElementById('overdue-days-span');

    if (!selectedOpt || !selectedOpt.value) {
      warningDiv.classList.add('hidden');
      return;
    }

    const isOverdue = selectedOpt.dataset.isOverdue === 'true';
    const overdueDays = selectedOpt.dataset.overdueDays;

    if (isOverdue && (paymentMethod === 'credit' || paymentMethod === 'split')) {
      daysSpan.innerText = overdueDays;
      warningDiv.classList.remove('hidden');
    } else {
      warningDiv.classList.add('hidden');
    }
  }

  let clientSearchDebounce = null;

  function openClientSearchModal() {
    document.getElementById('client-search-modal').classList.remove('hidden');
    const queryInput = document.getElementById('client-search-query');
    queryInput.value = '';
    queryInput.focus();
    
    document.getElementById('client-search-results').innerHTML = '<div class="text-center py-6 text-neutral-500 text-xs">Escribe para empezar a buscar clientes...</div>';
    
    document.getElementById('quick-client-name').value = '';
    document.getElementById('quick-client-dui').value = '';
    document.getElementById('quick-client-phone').value = '';
    document.getElementById('quick-client-error').classList.add('hidden');
  }

  function closeClientSearchModal() {
    document.getElementById('client-search-modal').classList.add('hidden');
  }

  document.getElementById('client-search-query').addEventListener('input', (e) => {
    clearTimeout(clientSearchDebounce);
    const query = e.target.value.trim();
    
    if (query.length < 2) {
      document.getElementById('client-search-results').innerHTML = '<div class="text-center py-6 text-neutral-500 text-xs">Escribe para empezar a buscar clientes...</div>';
      return;
    }
    
    clientSearchDebounce = setTimeout(async () => {
      try {
        const resp = await fetch(`/clients/api/search?q=${encodeURIComponent(query)}`);
        const data = await resp.json();
        
        const resultsContainer = document.getElementById('client-search-results');
        resultsContainer.innerHTML = '';
        
        if (data.success && data.clients.length > 0) {
          data.clients.forEach(c => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = "w-full text-left bg-neutral-950 hover:bg-neutral-800 border border-neutral-800 hover:border-blue-500 p-3 rounded-xl flex items-center justify-between transition-all cursor-pointer";
            
            let creditBadge = '';
            if (c.isOverdue) {
              creditBadge = '<span class="text-[9px] font-bold bg-red-950/60 border border-red-900 text-red-400 px-1.5 py-0.5 rounded ml-2">⚠️ MORA</span>';
            } else if (c.creditLimit > 0) {
              creditBadge = `<span class="text-[9px] font-bold bg-blue-950/60 border border-blue-900 text-blue-400 px-1.5 py-0.5 rounded ml-2">CRÉDITO: $${(c.creditLimit - c.currentBalance).toFixed(2)}</span>`;
            }
            
            btn.innerHTML = `
              <div class="flex flex-col">
                <span class="font-bold text-white text-xs">${c.name}${creditBadge}</span>
                <span class="text-[10px] text-neutral-500 font-mono">DUI: ${c.dui || 'N/A'} | Tel: ${c.phone || 'N/A'}</span>
              </div>
              <span class="text-[10px] text-blue-400 font-semibold uppercase tracking-wider">Seleccionar</span>
            `;
            
            btn.onclick = () => {
              selectClient(c.id, c.name, c.dui, c.creditLimit, c.currentBalance, c.isOverdue, c.overdueDays);
              closeClientSearchModal();
            };
            resultsContainer.appendChild(btn);
          });
        } else {
          resultsContainer.innerHTML = '<div class="text-center py-6 text-neutral-500 text-xs">No se encontraron clientes que coincidan.</div>';
          
          // Autofill DUI if query looks like one
          if (/^\d{8}-?\d?$/.test(query)) {
            let formattedDui = query;
            if (query.length === 9 && !query.includes('-')) {
              formattedDui = query.slice(0, 8) + '-' + query.slice(8);
            }
            document.getElementById('quick-client-dui').value = formattedDui;
          }
        }
      } catch (err) {
        console.error('Error searching clients:', err);
      }
    }, 250);
  });

  async function handleQuickClientSubmit(event) {
    event.preventDefault();
    const errorDiv = document.getElementById('quick-client-error');
    errorDiv.classList.add('hidden');
    
    const name = document.getElementById('quick-client-name').value.trim();
    const dui = document.getElementById('quick-client-dui').value.trim();
    const phone = document.getElementById('quick-client-phone').value.trim();
    
    const submitBtn = document.getElementById('btn-quick-client-submit');
    submitBtn.disabled = true;
    submitBtn.innerText = 'Registrando...';
    
    try {
      const resp = await fetch('/clients/api/quick-create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, dui, phone })
      });
      const data = await resp.json();
      
      if (data.success) {
        const c = data.client;
        selectClient(c.id, c.name, c.dui, c.creditLimit, c.currentBalance, c.isOverdue, c.overdueDays);
        closeClientSearchModal();
      } else {
        errorDiv.innerText = data.message || 'Error al registrar el cliente.';
        errorDiv.classList.remove('hidden');
      }
    } catch (err) {
      console.error(err);
      errorDiv.innerText = 'Error de red al registrar el cliente.';
      errorDiv.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerText = 'Registrar y Seleccionar';
    }
  }

  function selectClient(clientId, clientName, clientDui, clientLimit = 0.00, clientBalance = 0.00, clientIsOverdue = false, clientOverdueDays = 0) {
    const select = document.getElementById('client-id-select');
    
    let option = select.querySelector(`option[value="${clientId}"]`);
    if (!option) {
      option = document.createElement('option');
      option.value = clientId;
      select.appendChild(option);
    }
    
    option.text = `${clientName} ${clientIsOverdue ? '⚠️ (MORA)' : ''} (Disp: $${(clientLimit - clientBalance).toFixed(2)})`;
    option.dataset.limit = clientLimit;
    option.dataset.balance = clientBalance;
    option.dataset.isOverdue = clientIsOverdue ? 'true' : 'false';
    option.dataset.overdueDays = clientOverdueDays;
    
    select.value = clientId;
    
    document.getElementById('selected-client-name').innerText = clientName;
    document.getElementById('selected-client-dui').innerText = clientDui ? `DUI: ${clientDui}` : 'Sin DUI';
    document.getElementById('btn-clear-client').classList.remove('hidden');
    
    checkClientCreditStatus();
  }

  function clearSelectedClient() {
    const select = document.getElementById('client-id-select');
    select.value = '';
    
    document.getElementById('selected-client-name').innerText = 'Consumidor Final';
    document.getElementById('selected-client-dui').innerText = 'Sin registrar';
    document.getElementById('btn-clear-client').classList.add('hidden');
    
    checkClientCreditStatus();
  }

  // Fast cash bills button additions & change (vuelto) calculations
  function addFastCash(amount) {
    const el = document.getElementById('cash-received-input');
    const current = parseFloat(el.value) || 0;
    el.value = (current + amount).toFixed(2);
    updateChangeCalculation();
  }

  function setExactAmount() {
    const totalNet = getCartTotals().net;
    let cashToPay = totalNet;
    if (paymentMethod === 'split') {
      cashToPay = parseFloat(document.getElementById('split-cash-input').value) || 0;
    }
    const el = document.getElementById('cash-received-input');
    el.value = cashToPay.toFixed(2);
    updateChangeCalculation();
  }

  function clearFastCash() {
    const el = document.getElementById('cash-received-input');
    el.value = '0.00';
    updateChangeCalculation();
  }

  function updateChangeCalculation() {
    const totalNet = getCartTotals().net;
    const el = document.getElementById('cash-received-input');
    if (!el) return;
    const cashReceived = parseFloat(el.value) || 0;
    
    let cashToPay = 0;
    if (paymentMethod === 'cash') {
      cashToPay = totalNet;
    } else if (paymentMethod === 'split') {
      cashToPay = parseFloat(document.getElementById('split-cash-input').value) || 0;
    }
    
    const change = cashReceived - cashToPay;
    const changeSpan = document.getElementById('change-to-give');
    if (changeSpan) {
      if (change > 0) {
        changeSpan.innerText = `$${change.toFixed(2)}`;
        changeSpan.className = "block text-lg font-black text-emerald-400 font-mono mt-1 animate-pulse";
      } else {
        changeSpan.innerText = "$0.00";
        changeSpan.className = "block text-lg font-black text-neutral-500 font-mono mt-1";
      }
    }
  }

  function sendTicketViaWhatsapp() {
    const phoneInput = document.getElementById('whatsapp-number');
    const phone = phoneInput.value.replace(/\D/g, ''); // strip non-digits
    if (phone.length !== 8) {
      showToast('El número de WhatsApp debe tener 8 dígitos.', 'warning');
      return;
    }

    if (!lastCompletedCart || lastCompletedCart.length === 0) {
      showToast('No hay detalles de venta cargados para enviar.', 'warning');
      return;
    }

    const totals = getLastCompletedCartTotals();
    const clientSelect = document.getElementById('client-id-select');
    const clientName = clientSelect.value ? clientSelect.options[clientSelect.selectedIndex].text.split('⚠️')[0].split('(')[0].trim() : 'Consumidor Final';

    let itemsText = lastCompletedCart.map(item => {
      // Buscar si el item tenía descuento
      let promo = promotions.find(p => p.productId === item.productId);
      if (!promo && item.categoryId) {
        promo = promotions.find(p => p.categoryId === item.categoryId);
      }
      let discount = 0;
      if (promo) {
        if (promo.type === 'percentage') {
          discount = parseFloat(item.price) * (parseFloat(promo.value) / 100) * item.quantity;
        } else if (promo.type === 'fixed_price') {
          const promoPrice = parseFloat(promo.value);
          if (promoPrice < parseFloat(item.price)) {
            discount = (parseFloat(item.price) - promoPrice) * item.quantity;
          }
        } else if (promo.type === 'bulk') {
          const buyQty = promo.buyQty;
          const payQty = promo.payQty;
          if (item.quantity >= buyQty) {
            const groups = Math.floor(item.quantity / buyQty);
            discount = groups * (buyQty - payQty) * parseFloat(item.price);
          }
        }
      }
      const net = (parseFloat(item.price) * item.quantity) - discount;
      return `* ${item.name} x ${item.quantity} - $${net.toFixed(2)}${discount > 0 ? ` (Ahorro: $${discount.toFixed(2)})` : ''}`;
    }).join('\n');
    
    let paymentLabel = 'Efectivo';
    if (lastCompletedPaymentMethod === 'card') paymentLabel = 'Tarjeta';
    if (lastCompletedPaymentMethod === 'credit') paymentLabel = 'Crédito';
    if (lastCompletedPaymentMethod === 'split') {
      const cashVal = parseFloat(document.getElementById('split-cash-input').value) || 0;
      const cardVal = parseFloat(document.getElementById('split-card-input').value) || 0;
      const creditVal = parseFloat(document.getElementById('split-credit-input').value) || 0;
      paymentLabel = `Dividido (Efec: $${cashVal.toFixed(2)}, Tarj: $${cardVal.toFixed(2)}, Créd: $${creditVal.toFixed(2)})`;
    }

    const dateStr = new Date().toLocaleString('es-SV');

    let totalsText = `*TOTAL:* $${totals.net.toFixed(2)}`;
    if (totals.discount > 0) {
      totalsText = `*Subtotal:* $${totals.gross.toFixed(2)}\n*Ahorro:* -$${totals.discount.toFixed(2)}\n*TOTAL NETO:* $${totals.net.toFixed(2)}`;
    }

    const messageText = `*RG SIMPLE POS* 🧾\n-----------------------------\n` +
      `*Cliente:* ${clientName}\n` +
      `*Fecha:* ${dateStr}\n` +
      `*Método de Pago:* ${paymentLabel}\n` +
      `-----------------------------\n` +
      `*Detalle:*\n${itemsText}\n` +
      `-----------------------------\n` +
      `${totalsText}\n\n` +
      `¡Gracias por su compra!`;

    const encodedText = encodeURIComponent(messageText);
    const waUrl = `https://wa.me/503${phone}?text=${encodedText}`;
    window.open(waUrl, '_blank');
  }

  // Hook change calculations
  document.getElementById('cash-received-input').addEventListener('input', updateChangeCalculation);
  document.getElementById('split-cash-input').addEventListener('input', updateChangeCalculation);

  // Focus barcode input and handle theme initialization on load
  window.addEventListener('DOMContentLoaded', () => {
    const barInput = document.getElementById('barcode-input');
    if (barInput) barInput.focus();
    
    // Initialize theme state from localStorage
    const currentTheme = localStorage.getItem('theme') || 'dark';
    if (currentTheme === 'light') {
      document.body.classList.add('light-mode');
      const sunIcon = document.getElementById('theme-sun-icon');
      const moonIcon = document.getElementById('theme-moon-icon');
      if (sunIcon) sunIcon.classList.add('hidden');
      if (moonIcon) moonIcon.classList.remove('hidden');
    }
  });

  function toggleTheme() {
    const isLight = document.body.classList.toggle('light-mode');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    
    const sunIcon = document.getElementById('theme-sun-icon');
    const moonIcon = document.getElementById('theme-moon-icon');
    
    if (isLight) {
      if (sunIcon) sunIcon.classList.add('hidden');
      if (moonIcon) moonIcon.classList.remove('hidden');
    } else {
      if (sunIcon) sunIcon.classList.remove('hidden');
      if (moonIcon) moonIcon.classList.add('hidden');
    }
  }

  // Submit sale to backend
  async function submitSale() {
    if (cart.length === 0) {
      showToast('El carrito está vacío.', 'warning');
      return;
    }

    const clientId = document.getElementById('client-id-select').value;
    const totalNet = getCartTotals().net;
    
    let splitCash = 0.00;
    let splitCard = 0.00;
    let splitCredit = 0.00;

    if (paymentMethod === 'credit' && !clientId) {
      showToast('Debe seleccionar un cliente registrado para la venta a crédito.', 'warning');
      return;
    }

    if (paymentMethod === 'split') {
      splitCash = parseFloat(document.getElementById('split-cash-input').value) || 0;
      splitCard = parseFloat(document.getElementById('split-card-input').value) || 0;
      splitCredit = parseFloat(document.getElementById('split-credit-input').value) || 0;

      const sum = splitCash + splitCard + splitCredit;
      if (Math.abs(sum - totalNet) > 0.01) {
        showToast(`El cobro dividido no está cuadrado. Diferencia: $${(totalNet - sum).toFixed(2)}`, 'error');
        return;
      }

      if (splitCredit > 0 && !clientId) {
        showToast('Debe seleccionar un cliente registrado si una parte de la venta es al crédito.', 'warning');
        return;
      }
    }

    // Check credit limits locally first
    const creditPortion = paymentMethod === 'credit' ? totalNet : (paymentMethod === 'split' ? splitCredit : 0.00);
    if (creditPortion > 0 && clientId) {
      const option = document.querySelector(`#client-id-select option[value="${clientId}"]`);
      const limit = parseFloat(option.dataset.limit);
      const balance = parseFloat(option.dataset.balance);
      
      if (balance + creditPortion > limit) {
        showToast(`Límite de crédito excedido. Disponible: $${(limit - balance).toFixed(2)}. Crédito solicitado: $${creditPortion.toFixed(2)}`, 'error');
        return;
      }
    }

    const checkoutBtn = document.getElementById('btn-checkout');
    checkoutBtn.disabled = true;
    checkoutBtn.innerText = 'Procesando...';

    try {
      const resp = await fetch('/sales', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          clientId: clientId || null,
          paymentMethod,
          items: cart.map(i => ({ productId: i.productId, quantity: i.quantity })),
          splitCash,
          splitCard,
          splitCredit
        })
      });

      const resData = await resp.json();

      if (resData.success) {
        showToast('Venta realizada con éxito.', 'success');
        buildPrintTicket(resData.ticketNumber, resData.saleId, splitCash, splitCard, splitCredit);
        
        // Save copy of completed transaction details for WhatsApp sending
        lastCompletedCart = JSON.parse(JSON.stringify(cart));
        lastCompletedPaymentMethod = paymentMethod;
        
        clearCart();
        
        // Reset WhatsApp input field
        const waNumInput = document.getElementById('whatsapp-number');
        if (waNumInput) waNumInput.value = '';
        
        document.getElementById('ticket-modal').classList.remove('hidden');
      } else {
        showToast('Error: ' + resData.message, 'error');
      }
    } catch (err) {
      console.error(err);
      showToast('Ocurrió un error de red al procesar la venta.', 'error');
    } finally {
      checkoutBtn.disabled = false;
      checkoutBtn.innerText = 'Procesar Venta';
    }
  }

  // Generate printable EJS ticket invoice HTML
  function buildPrintTicket(ticketNumber, saleId, cashPaid, cardPaid, creditPaid) {
    const container = document.getElementById('printable-ticket');
    const date = new Date().toLocaleString('es-SV');
    const totals = getCartTotals();
    const clientSelect = document.getElementById('client-id-select');
    const clientName = clientSelect.value ? clientSelect.options[clientSelect.selectedIndex].text.split('⚠️')[0].split('(')[0].trim() : 'Consumidor Final';

    let paymentLabel = 'Efectivo';
    if (paymentMethod === 'card') paymentLabel = 'Tarjeta';
    if (paymentMethod === 'credit') paymentLabel = 'Crédito';
    if (paymentMethod === 'split') {
      paymentLabel = `Dividido:<br>
      - Efec: $${cashPaid.toFixed(2)}<br>
      - Tarj: $${cardPaid.toFixed(2)}<br>
      - Créd: $${creditPaid.toFixed(2)}`;
    }

    container.innerHTML = `
      <div style="text-align: center; margin-bottom: 10px;">
        <h4 style="margin: 0; text-transform: uppercase;">RG Simple POS</h4>
        <p style="margin: 2px 0; font-size: 9px;">Casa Central - El Salvador</p>
        <p style="margin: 2px 0; font-size: 9px;">Telf: 2222-2222</p>
        <p style="margin: 2px 0; font-size: 9px;">IVA Incluido - Consumidor Final</p>
      </div>
      <div style="border-top: 1px dashed #000; border-bottom: 1px dashed #000; padding: 5px 0; margin-bottom: 10px;">
        <p style="margin: 2px 0;"><strong>Ticket:</strong> ${ticketNumber}</p>
        <p style="margin: 2px 0;"><strong>Fecha:</strong> ${date}</p>
        <p style="margin: 2px 0;"><strong>Cajero:</strong> <%= user.fullName %></p>
        <p style="margin: 2px 0;"><strong>Cliente:</strong> ${clientName}</p>
        <p style="margin: 2px 0;"><strong>Pago:</strong><br>${paymentLabel}</p>
      </div>
      <table style="width: 100%; font-size: 10px; border-collapse: collapse; margin-bottom: 10px;">
        <thead>
          <tr style="border-bottom: 1px solid #000;">
            <th style="text-align: left;">Art.</th>
            <th style="text-align: center;">Cant.</th>
            <th style="text-align: right;">Total</th>
          </tr>
        </thead>
        <tbody>
          ${cart.map(i => {
            const price = parseFloat(i.price);
            let promo = promotions.find(p => p.productId === i.productId);
            if (!promo && i.categoryId) {
              promo = promotions.find(p => p.categoryId === i.categoryId);
            }
            let discount = 0;
            if (promo) {
              if (promo.type === 'percentage') {
                discount = price * (parseFloat(promo.value) / 100) * i.quantity;
              } else if (promo.type === 'fixed_price') {
                const promoPrice = parseFloat(promo.value);
                if (promoPrice < price) discount = (price - promoPrice) * i.quantity;
              } else if (promo.type === 'bulk') {
                const buyQty = promo.buyQty;
                const payQty = promo.payQty;
                if (i.quantity >= buyQty) {
                  const groups = Math.floor(i.quantity / buyQty);
                  discount = groups * (buyQty - payQty) * price;
                }
              }
            }
            const net = (price * i.quantity) - discount;
            return `
              <tr>
                <td style="padding: 3px 0;">${i.name}${discount > 0 ? ' <small style="color:gray;">(desc)</small>' : ''}</td>
                <td style="text-align: center;">${i.quantity}</td>
                <td style="text-align: right;">$${net.toFixed(2)}</td>
              </tr>
            `;
          }).join('')}
        </tbody>
      </table>
      <div style="border-top: 1px dashed #000; padding-top: 5px; text-align: right; font-size: 9px;">
        Subtotal Bruto: $${totals.gross.toFixed(2)}
      </div>
      ${totals.discount > 0 ? `
      <div style="text-align: right; font-size: 9px; color: red;">
        Descuento: -$${totals.discount.toFixed(2)}
      </div>
      ` : ''}
      <div style="border-top: 1px dashed #000; padding-top: 3px; text-align: right; font-weight: bold; font-size: 11px;">
        TOTAL NETO: $${totals.net.toFixed(2)}
      </div>
      <div style="margin-top: 15px; text-align: center; font-size: 9px;">
        ¡Gracias por su compra!
      </div>
    `;
  }

  function closeTicketModal() {
    document.getElementById('ticket-modal').classList.add('hidden');
    // Refresh page to sync client credit balance dropdown stats
    window.location.reload();
  }

  function printTicket() {
    window.print();
  }
</script>

