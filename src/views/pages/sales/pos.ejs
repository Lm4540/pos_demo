<%- include('../../partials/head', { title: 'Punto de Venta (POS)' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Punto de Venta (POS)</span>
        <span class="text-xs block text-neutral-400 font-medium">Turno Activo: <strong class="text-indigo-400">#<%= turn.id %></strong> | Sucursal: <span class="text-neutral-300"><%= user.branch ? user.branch.name : 'N/A' %></span></span>
      </div>
    </div>
    
    <div class="flex items-center gap-3">
      <a href="/sales/history" class="bg-neutral-800 border border-neutral-700 hover:bg-neutral-750 px-4 py-2 rounded-xl text-xs font-semibold text-neutral-300 transition-all flex items-center gap-2">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        <span>Historial de Ventas</span>
      </a>
      <a href="/cashier/details" class="bg-indigo-950 border border-indigo-800 hover:bg-indigo-900 px-4 py-2 rounded-xl text-xs font-semibold text-indigo-300 transition-all">
        Ver Estado de Caja
      </a>
      <button 
        type="button" 
        id="btn-theme-toggle" 
        onclick="toggleTheme()" 
        class="bg-neutral-800 border border-neutral-700 hover:bg-neutral-750 p-2 rounded-xl text-neutral-300 transition-all cursor-pointer flex items-center justify-center">
        <!-- Sun icon (shown in dark mode) -->
        <svg id="theme-sun-icon" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="theme-moon-icon" class="h-4.5 w-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- POS Layout -->
  <main class="flex-grow p-6 max-w-[1600px] w-full mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 overflow-hidden h-[calc(100vh-80px)]">
    <!-- Left Column: Search & Cart (8/12) -->
    <div class="lg:col-span-7 xl:col-span-8 flex flex-col gap-6 h-full overflow-hidden">
      <!-- Search Inputs -->
      <div class="bg-neutral-900 border border-neutral-800 p-5 rounded-2xl shadow-sm flex flex-col md:flex-row gap-4 flex-shrink-0">
        <!-- Barcode Fast Scan -->
        <div class="md:w-1/3">
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Escáner Código de Barras</label>
          <div class="relative">
            <input 
              type="text" 
              id="barcode-input" 
              class="w-full pl-9 pr-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono text-sm" 
              placeholder="Escanear...">
            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-neutral-500">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          </div>
        </div>

        <!-- Predictive Name Search -->
        <div class="flex-grow relative">
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Buscador de Artículos</label>
          <div class="relative">
            <input 
              type="text" 
              id="search-input" 
              class="w-full pl-9 pr-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" 
              placeholder="Buscar por nombre..."
              autocomplete="off">
            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-neutral-500">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
          </div>

          <!-- Autocomplete results dropdown -->
          <div id="autocomplete-results" class="absolute left-0 right-0 mt-2 bg-neutral-900 border border-neutral-800 rounded-xl shadow-2xl max-h-80 overflow-y-auto hidden z-20">
            <!-- Results populated by JS -->
          </div>
        </div>
      </div>

      <!-- Carrito de Compra (Below search & scan, grows to take remaining space) -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl flex flex-col flex-grow overflow-hidden shadow-sm">
        <!-- Header -->
        <div class="p-4 border-b border-neutral-800 flex items-center justify-between bg-neutral-950/40 flex-shrink-0">
          <h2 class="text-lg font-bold text-white">Carrito de Compra</h2>
          <button onclick="clearCart()" class="text-xs bg-red-950/50 hover:bg-red-900 border border-red-900 text-red-300 font-bold px-3 py-1.5 rounded-lg transition-all cursor-pointer hover:scale-102">
            Vaciar Carrito
          </button>
        </div>

        <!-- Items List -->
        <div id="cart-items-container" class="flex-grow overflow-y-auto p-4 space-y-3">
          <!-- Rendered by JS -->
          <div class="text-center py-12 text-neutral-500 text-sm" id="empty-cart-msg">
            <svg class="h-10 w-10 mx-auto text-neutral-700 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <span>El carrito está vacío</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: High Rotation & Checkout (4/12) -->
    <div class="lg:col-span-5 xl:col-span-4 flex flex-col gap-6 h-full overflow-hidden">
      <!-- High Rotation (Frequent) Grid (Top) -->
      <div class="bg-neutral-900 border border-neutral-800 p-5 rounded-2xl max-h-[40%] flex flex-col flex-shrink-0 overflow-hidden shadow-sm">
        <h2 class="text-xs font-bold text-neutral-400 uppercase tracking-wider mb-3 flex-shrink-0">Productos de Alta Rotación</h2>
        
        <!-- Category filter tabs -->
        <div class="flex gap-2 overflow-x-auto pb-3 mb-3 flex-shrink-0 border-b border-neutral-800/60 scrollbar-none">
          <button type="button" onclick="filterFrequentByCategory('all')" id="tab-cat-all" class="cat-tab-btn py-1.5 px-3 rounded-lg text-xs font-bold bg-blue-600 text-white transition-all cursor-pointer whitespace-nowrap shadow-md">Todas</button>
          <% categories.forEach(cat => { %>
            <button type="button" onclick="filterFrequentByCategory(<%= cat.id %>)" id="tab-cat-<%= cat.id %>" class="cat-tab-btn py-1.5 px-3 rounded-lg text-xs font-bold bg-neutral-950 text-neutral-400 hover:text-white border border-neutral-850 hover:border-neutral-700 transition-all cursor-pointer whitespace-nowrap"><%= cat.name %></button>
          <% }) %>
        </div>

        <div class="overflow-y-auto flex-grow pr-1">
          <% if (frequentProducts.length === 0) { %>
            <p class="text-xs text-neutral-500 py-6 text-center">No hay productos marcados como frecuentes con stock en esta sucursal.</p>
          <% } else { %>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              <% frequentProducts.forEach(bp => { %>
                <button 
                  onclick="addToCart(<%= bp.productId %>, '<%= bp.product.name %>', <%= bp.salePrice %>, <%= bp.totalStock %>, <%= bp.product.categoryId || 'null' %>)"
                  data-category-id="<%= bp.product.categoryId || 'null' %>"
                  class="frequent-product-card group bg-neutral-950 border border-neutral-800 hover:border-blue-500 p-2.5 rounded-xl flex flex-col items-center text-center cursor-pointer transition-all hover:scale-102">
                  <div class="h-10 w-10 bg-neutral-900 rounded-lg overflow-hidden border border-neutral-800 flex items-center justify-center mb-1.5 flex-shrink-0">
                    <% if (bp.product.imagePath) { %>
                      <img src="<%= bp.product.imagePath %>" alt="<%= bp.product.name %>" class="h-full w-full object-cover">
                    <% } else { %>
                      <svg class="h-4 w-4 text-neutral-700 group-hover:text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                      </svg>
                    <% } %>
                  </div>
                  <span class="text-[10px] font-bold text-white line-clamp-1 leading-tight w-full" title="<%= bp.product.name %>"><%= bp.product.name %></span>
                  <span class="text-[10px] font-bold text-blue-400 mt-1">$<%= parseFloat(bp.salePrice).toFixed(2) %></span>
                  <span class="text-[8px] text-neutral-500 mt-0.5">Stock: <%= bp.totalStock %></span>
                </button>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Checkout Actions (Bottom, takes remaining height) -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl flex flex-col flex-grow overflow-y-auto p-5 space-y-4 shadow-sm">
        <!-- Payment details -->
        <div class="space-y-2">
          <div class="flex justify-between text-sm text-neutral-400">
            <span>Subtotal Bruto:</span>
            <span id="cart-subtotal">$0.00</span>
          </div>
          <div class="flex justify-between text-sm text-red-400 hidden" id="cart-discount-row">
            <span>Descuentos:</span>
            <span id="cart-discount">-$0.00</span>
          </div>
          <div class="flex justify-between text-lg font-black text-white">
            <span>Total a Pagar:</span>
            <span id="cart-total" class="text-blue-400">$0.00</span>
          </div>
        </div>

        <!-- Payment Selection -->
        <div class="space-y-4">
          <div>
            <label class="block text-[10px] font-semibold text-neutral-500 uppercase tracking-wider mb-1.5">Método de Pago</label>
            <div class="grid grid-cols-2 gap-2.5">
              <button 
                type="button"
                onclick="setPaymentMethod('cash')" 
                id="btn-pay-cash"
                class="py-3 rounded-xl text-sm font-bold border border-blue-500 bg-blue-950/40 text-blue-400 transition-all cursor-pointer text-center">
                Efectivo
              </button>
              <button 
                type="button"
                onclick="setPaymentMethod('card')" 
                id="btn-pay-card"
                class="py-3 rounded-xl text-sm font-bold border border-neutral-800 bg-neutral-950 text-neutral-400 transition-all cursor-pointer text-center">
                Tarjeta
              </button>
              <button 
                type="button"
                onclick="setPaymentMethod('credit')" 
                id="btn-pay-credit"
                class="py-3 rounded-xl text-sm font-bold border border-neutral-800 bg-neutral-950 text-neutral-400 transition-all cursor-pointer text-center">
                Crédito
              </button>
              <button 
                type="button"
                onclick="setPaymentMethod('split')" 
                id="btn-pay-split"
                class="py-3 rounded-xl text-sm font-bold border border-neutral-800 bg-neutral-950 text-neutral-400 transition-all cursor-pointer text-center">
                Dividido
              </button>
            </div>
          </div>

          <!-- Split Payment inputs breakdown -->
          <div id="split-payment-breakdown" class="mt-3 p-3.5 bg-neutral-950 border border-neutral-800 rounded-xl space-y-3.5 hidden">
            <span class="block text-[10px] font-bold text-neutral-500 uppercase tracking-wider">Desglose de Pago Dividido</span>
            <div class="grid grid-cols-3 gap-2.5">
              <div>
                <label class="block text-[9px] text-neutral-400 mb-0.5">Efectivo ($)</label>
                <input type="number" step="0.01" min="0" id="split-cash-input" value="0.00" class="w-full text-center px-1.5 py-2 bg-neutral-900 border border-neutral-800 text-white rounded-xl text-xs font-mono focus:ring-1 focus:ring-blue-500">
              </div>
              <div>
                <label class="block text-[9px] text-neutral-400 mb-0.5">Tarjeta ($)</label>
                <input type="number" step="0.01" min="0" id="split-card-input" value="0.00" class="w-full text-center px-1.5 py-2 bg-neutral-900 border border-neutral-800 text-white rounded-xl text-xs font-mono focus:ring-1 focus:ring-blue-500">
              </div>
              <div>
                <label class="block text-[9px] text-neutral-400 mb-0.5">Crédito ($)</label>
                <input type="number" step="0.01" min="0" id="split-credit-input" value="0.00" class="w-full text-center px-1.5 py-2 bg-neutral-900 border border-neutral-800 text-white rounded-xl text-xs font-mono focus:ring-1 focus:ring-blue-500">
              </div>
            </div>
            <div class="flex justify-between text-[10px]">
              <span class="text-neutral-500">Total Desglosado:</span>
              <span id="split-total-sum" class="font-bold text-white font-mono">$0.00</span>
            </div>
            <div class="flex justify-between text-[10px]">
              <span class="text-neutral-500">Diferencia:</span>
              <span id="split-remaining" class="font-bold text-red-400 font-mono">$0.00</span>
            </div>
          </div>

          <!-- Cash Received & Change (Visible only for cash or split payments) -->
          <div id="cash-received-container" class="p-3.5 bg-neutral-950 border border-neutral-800 rounded-xl space-y-3.5">
            <span class="block text-[10px] font-bold text-neutral-500 uppercase tracking-wider">Cálculo de Vuelto</span>
            
            <div class="flex flex-row gap-3 items-center">
              <div class="flex-grow w-full">
                <label class="block text-[9px] text-neutral-400 mb-0.5">Efectivo Recibido ($)</label>
                <input type="number" step="0.01" min="0" id="cash-received-input" value="0.00" class="w-full text-center px-2 py-2.5 bg-neutral-900 border border-neutral-800 text-white rounded-xl text-sm font-mono font-bold focus:ring-1 focus:ring-blue-500 focus:outline-none">
              </div>
              <div class="w-[45%] text-center border-l border-neutral-800 pl-3">
                <span class="block text-[9px] text-neutral-400 mb-0.5">Vuelto</span>
                <span id="change-to-give" class="block text-base font-black text-emerald-400 font-mono mt-1">$0.00</span>
              </div>
            </div>

            <!-- Fast cash buttons -->
            <div class="space-y-2">
              <label class="block text-[8px] text-neutral-500 uppercase tracking-wider">Billetes Rápidos</label>
              <div class="grid grid-cols-6 gap-1.5">
                <button type="button" onclick="addFastCash(1)" class="py-2.5 bg-neutral-900 border border-neutral-850 hover:border-blue-500 hover:bg-neutral-800 rounded text-xs font-bold text-neutral-300 cursor-pointer text-center">+$1</button>
                <button type="button" onclick="addFastCash(5)" class="py-2.5 bg-neutral-900 border border-neutral-850 hover:border-blue-500 hover:bg-neutral-800 rounded text-xs font-bold text-neutral-300 cursor-pointer text-center">+$5</button>
                <button type="button" onclick="addFastCash(10)" class="py-2.5 bg-neutral-900 border border-neutral-850 hover:border-blue-500 hover:bg-neutral-800 rounded text-xs font-bold text-neutral-300 cursor-pointer text-center">+$10</button>
                <button type="button" onclick="addFastCash(20)" class="py-2.5 bg-neutral-900 border border-neutral-850 hover:border-blue-500 hover:bg-neutral-800 rounded text-xs font-bold text-neutral-300 cursor-pointer text-center">+$20</button>
                <button type="button" onclick="addFastCash(50)" class="py-2.5 bg-neutral-900 border border-neutral-850 hover:border-blue-500 hover:bg-neutral-800 rounded text-xs font-bold text-neutral-300 cursor-pointer text-center">+$50</button>
                <button type="button" onclick="addFastCash(100)" class="py-2.5 bg-neutral-900 border border-neutral-850 hover:border-blue-500 hover:bg-neutral-800 rounded text-xs font-bold text-neutral-300 cursor-pointer text-center">+$100</button>
              </div>
              <div class="flex gap-2">
                <button type="button" onclick="setExactAmount()" class="w-1/2 py-2.5 text-xs font-bold text-neutral-450 hover:text-white bg-neutral-900 hover:bg-neutral-850 rounded-xl text-center border border-neutral-850 cursor-pointer">Monto Exacto</button>
                <button type="button" onclick="clearFastCash()" class="w-1/2 py-2.5 text-xs font-bold text-neutral-500 hover:text-red-400 bg-neutral-900 hover:bg-neutral-850 rounded-xl text-center border border-neutral-850 cursor-pointer">Limpiar</button>
              </div>
            </div>
          </div>

          <!-- Client Selection (Search modal trigger instead of dropdown) -->
          <div id="client-selection-container" class="space-y-1.5">
            <label class="block text-[10px] font-semibold text-neutral-500 uppercase tracking-wider mb-1">Cliente</label>
            <div class="flex items-center gap-2.5">
              <div id="selected-client-box" class="flex-grow bg-neutral-950 border border-neutral-800 rounded-xl px-3.5 py-3 flex items-center justify-between text-xs text-neutral-300">
                <div class="flex flex-col">
                  <span id="selected-client-name" class="font-bold text-white">Consumidor Final</span>
                  <span id="selected-client-dui" class="text-[10px] text-neutral-500 font-mono">Sin registrar</span>
                </div>
                <button type="button" id="btn-clear-client" onclick="clearSelectedClient()" class="text-neutral-500 hover:text-red-400 p-1 cursor-pointer hidden">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <button type="button" id="btn-open-client-search" onclick="openClientSearchModal()" class="bg-neutral-850 hover:bg-neutral-800 text-neutral-300 border border-neutral-700 px-4 py-3 rounded-xl text-xs font-semibold flex items-center gap-1.5 transition-all cursor-pointer">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <span>Buscar</span>
              </button>
            </div>
            
            <select id="client-id-select" class="hidden">
              <option value="">Consumidor Final (No registrado)</option>
              <% clients.forEach(c => { %>
                <option value="<%= c.id %>" data-limit="<%= c.creditLimit %>" data-balance="<%= c.currentBalance %>" data-is-overdue="<%= c.isOverdue %>" data-overdue-days="<%= c.overdueDays %>">
                  <%= c.name %> <%= c.isOverdue ? '⚠️ (MORA)' : '' %> (Disp: $<%= (c.creditLimit - c.currentBalance).toFixed(2) %>)
                </option>
              <% }) %>
            </select>
            
            <!-- Overdue Warning Banner -->
            <div id="client-overdue-warning" class="mt-2 p-2.5 bg-red-950/40 border border-red-800 text-red-400 text-xs rounded-xl hidden font-medium">
              <span class="font-bold text-red-200">⚠️ CRÉDITO VENCIDO:</span> Este cliente tiene deudas con una antigüedad de <span id="overdue-days-span" class="font-bold">0</span> días.
            </div>
          </div>
        </div>

        <button 
          onclick="submitSale()" 
          id="btn-checkout"
          class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-xl text-base transition-all shadow-lg shadow-blue-500/10 cursor-pointer text-center">
          Procesar Venta
        </button>
      </div>
    </div>
  </main>
</div>

<!-- Reprint Ticket Thermal Modal -->
<div id="ticket-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-sm rounded-2xl shadow-2xl p-6 relative">
    <button onclick="closeTicketModal()" class="absolute top-4 right-4 text-neutral-500 hover:text-white cursor-pointer">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <h3 class="text-lg font-bold text-white text-center mb-4">Venta Exitosa</h3>
    
    <!-- Printable Area -->
    <div id="printable-ticket" class="bg-white text-black p-4 font-mono text-xs border border-neutral-200 rounded-lg max-h-96 overflow-y-auto">
      <!-- Dynamic ticket content injected here -->
    </div>
    
    <!-- WhatsApp Send Container -->
    <div class="mt-4 pt-4 border-t border-neutral-800/80 space-y-2">
      <label class="block text-[10px] font-semibold text-neutral-500 uppercase tracking-wider">Enviar Comprobante por WhatsApp</label>
      <div class="flex gap-2">
        <div class="relative flex-grow">
          <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-xs text-neutral-500 font-mono">+503</span>
          <input type="tel" id="whatsapp-number" class="w-full pl-12 pr-3 py-2 bg-neutral-950 border border-neutral-800 text-white text-xs rounded-xl focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="7777-7777">
        </div>
        <button type="button" onclick="sendTicketViaWhatsapp()" class="bg-emerald-600 hover:bg-emerald-500 text-white font-bold px-3 py-2 rounded-xl text-xs flex items-center gap-1 cursor-pointer transition-colors shadow-sm whitespace-nowrap">
          <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
          <span>Enviar</span>
        </button>
      </div>
    </div>
    
    <div class="flex gap-3 mt-5">
      <button onclick="closeTicketModal()" class="w-1/2 py-2.5 text-xs font-semibold text-neutral-400 bg-neutral-850 hover:bg-neutral-800 border border-neutral-800 rounded-xl transition-all cursor-pointer text-center">
        Nueva Venta
      </button>
      <button onclick="printTicket()" class="w-1/2 py-2.5 text-xs font-bold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer text-center flex items-center justify-center gap-1 shadow-md shadow-blue-500/10">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
