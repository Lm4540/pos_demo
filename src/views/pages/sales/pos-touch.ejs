  // Tab filter trigger
  function filterFrequentByCategory(catId) {
    currentFilterCategory = String(catId);
    document.querySelectorAll('.cat-tab-btn').forEach(btn => {
      btn.className = "cat-tab-btn px-4 py-2 rounded-xl text-[11px] font-bold bg-neutral-950 border border-neutral-850 text-neutral-450 hover:text-white min-w-[80px] whitespace-nowrap cursor-pointer";
    });
    const active = document.getElementById(catId === 'all' ? 'tab-cat-all' : (catId === 'services' ? 'tab-cat-services' : `tab-cat-${catId}`));
    if (active) {
      active.className = "cat-tab-btn px-4 py-2 rounded-xl text-[11px] font-bold bg-blue-600 text-white shadow-md shadow-blue-500/10 min-w-[80px] whitespace-nowrap cursor-pointer";
    }

    document.querySelectorAll('.catalog-item-card').forEach(card => {
      const cardCatId = card.dataset.categoryId;
      const isService = cardCatId === 'services';

      const shouldShow = (catId === 'all' && !isService) ||
        (catId === 'services' && isService) ||
        (catId !== 'all' && catId !== 'services' && String(cardCatId) === String(catId));

      if (shouldShow) card.classList.remove('hidden');
      else card.classList.add('hidden');
    });
  }

  // Autocomplete predictive search inside modal
  document.getElementById('touch-search-input').addEventListener('input', async (e) => {
    const val = e.target.value.trim();
    if (val.length < 2) {
      renderCatalogItems(defaultCatalogItems);
      filterFrequentByCategory(currentFilterCategory);
      return;
    }
    try {
      const resp = await fetch(`/sales/api/products?q=${encodeURIComponent(val)}`);
