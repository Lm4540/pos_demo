      }));
      renderCatalogItems(searchItems);
    } catch (e) {}
  });

  // Barcode Scanning Keypress events
  document.getElementById('barcode-input').addEventListener('keypress', async (e) => {
    if (e.key === 'Enter') {
      const code = e.target.value.trim();
      if (code === '') return;
      e.target.value = '';
      await processScannerCode(code);
    }
  });

  // Global document-level barcode scanner interceptor
  let scannerBuffer = '';
  let lastKeyTime = Date.now();
  document.addEventListener('keydown', (e) => {
    const activeEl = document.activeElement;
    if (activeEl && (activeEl.tagName === 'INPUT' || activeEl.tagName === 'SELECT' || activeEl.tagName === 'TEXTAREA')) {
      return;
    }
    if (e.ctrlKey || e.altKey || e.metaKey || e.key === 'Shift') {
      return;
    }
    const currentTime = Date.now();
    if (currentTime - lastKeyTime > 80) {
      scannerBuffer = '';
    }
    lastKeyTime = currentTime;
    if (e.key.length === 1) {
      scannerBuffer += e.key;
    } else if (e.key === 'Enter') {
      const code = scannerBuffer.trim();
      if (code.length >= 3) {
        e.preventDefault();
        scannerBuffer = '';
        processScannerCode(code);
      }
    }
  });

  async function processScannerCode(code) {
    try {
      const resp = await fetch(`/sales/api/products?q=${encodeURIComponent(code)}`);
      const results = await resp.json();
      if (results && results.length > 0) {
        const bp = results[0];
        addToCart(bp.id, bp.name, bp.salePrice, bp.totalStock, bp.categoryId, bp.type);

      } else {
        showToast(`Código de barras "${code}" no encontrado o sin existencias.`, 'error');
      }
    } catch (err) {
      console.error(err);
      showToast('Error al procesar el código de barras.', 'error');
    }
  }

  function playScanSound() {
    try {
      const audioCtx = new(window.AudioContext || window.webkitAudioContext)();
      const osc = audioCtx.createOscillator();
      osc.type = "sine";
      osc.frequency.setValueAtTime(1000, audioCtx.currentTime);
      osc.connect(audioCtx.destination);
      osc.start();
      osc.stop(audioCtx.currentTime + 0.08);
    } catch (e) {}
  }

  // Submit Touch Sale
  async function submitSale() {
    if (cart.length === 0) {
      showToast('El carrito está vacío.', 'warning');
      return;
    }
    const clientId = document.getElementById('client-id-select').value;
    const totalNet = getCartTotals().net;
    let splitCash = 0.00;
    let splitCard = 0.00;
    let splitCredit = 0.00;

    if (paymentMethod === 'credit' && !clientId) {
      showToast('Seleccione un cliente registrado para crédito.', 'warning');
      return;
    }

    if (paymentMethod === 'split') {
      splitCash = parseFloat(document.getElementById('split-cash-input').value) || 0;
      splitCard = parseFloat(document.getElementById('split-card-input').value) || 0;
      splitCredit = parseFloat(document.getElementById('split-credit-input').value) || 0;
      const sum = splitCash + splitCard + splitCredit;
      if (Math.abs(sum - totalNet) > 0.01) {
        showToast('El pago dividido no cuadra.', 'error');
        return;
      }
    }

    const cardTransactionRef = document.getElementById('card-transaction-ref')?.value?.trim() || '';
    const hasCardPayment = paymentMethod === 'card' || (paymentMethod === 'split' && splitCard > 0);
    if (hasCardPayment && !cardTransactionRef) {
      showToast('Ingrese la referencia de la tarjeta.', 'warning');
      document.getElementById('card-transaction-ref')?.focus();
      return;
    }

    const cobraBtn = document.getElementById('touch-cobrar-btn');
    if (cobraBtn) {
      cobraBtn.disabled = true;
      cobraBtn.innerText = 'PROCESANDO...';
    }

    try {
      const resp = await fetch('/sales', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          clientId: clientId || null,
          paymentMethod,
          items: cart.map(i => ({
            productId: i.productId,
            quantity: i.quantity,
            customDescription: i.customDescription || null,
            unitPrice: i.type === 'service' ? i.price : undefined
          })),
          splitCash,
          splitCard,
          splitCredit,
          cardTransactionRef: hasCardPayment ? cardTransactionRef : null
        })
      });

      const resData = await resp.json();
      if (resData.success) {
        showToast('Venta procesada.', 'success');

        window.lastCompletedSaleData = {
          ticketNumber: resData.ticketNumber,
          saleId: resData.saleId,
          cashPaid: splitCash,
          cardPaid: splitCard,
          creditPaid: splitCredit,
          cardRef: hasCardPayment ? cardTransactionRef : null
        };
        handlePOSPrinting(resData.ticketNumber, resData.saleId, splitCash, splitCard, splitCredit, window.lastCompletedSaleData.cardRef);

        const cashReceived = parseFloat(document.getElementById('cash-received-input').value) || 0;
        const cashToPay = paymentMethod === 'cash' ? totalNet : (paymentMethod === 'split' ? splitCash : 0);
        const changeGiven = Math.max(0, cashReceived - cashToPay);

        posChannel.postMessage({
          type: 'sale_completed',
          data: {
            totalAmount: totalNet,
            changeAmount: paymentMethod === 'cash' ? changeGiven : 0,
            cashReceived: paymentMethod === 'cash' ? cashReceived : 0,
            paymentMethod
          }
        });

        setTimeout(() => {
            window.location.reload();
          }, 1200);


        // clearCart();
        // clearCashReceived();
        // if (cobraBtn) {
        //   cobraBtn.disabled = false;
        //   cobraBtn.innerText = 'COBRAR';
        // }

        // const isPrintEnabled = document.getElementById('print-ticket-switch')?.checked;
        // if (isPrintEnabled) {
        //   setTimeout(() => {
        //     window.location.reload();
        //   }, 1200);
        // } else {
        //   document.getElementById('ticket-modal').classList.remove('hidden');
        // }
      } else {
        showToast('Error: ' + resData.message, 'error');
        if (cobraBtn) {
          cobraBtn.disabled = false;
          cobraBtn.innerText = 'COBRAR';
        }
      }
    } catch (e) {
      showToast('Error de red.', 'error');
      if (cobraBtn) {
        cobraBtn.disabled = false;
        cobraBtn.innerText = 'COBRAR';
      }
    }
  }



  async function handlePOSPrinting(ticketNumber, saleId, cashPaid, cardPaid, creditPaid, cardRef) {
    const isPrintEnabled = document.getElementById('print-ticket-switch')?.checked;
    const sep = '----------------------------------------';

    if (!isPrintEnabled) {
      try {
        const builder = new ESCPOSBuilder();
        builder.initialize().cashDrawer().newLineN(2);
        await printerClient.sendCommands(builder.build());
      } catch (err) {
        console.error('Error al abrir cajón:', err);
      }
      return;
    }

    try {
      const builder = new ESCPOSBuilder();
      builder.initialize().cashDrawer().setFont('A');

      // ── Encabezado ──
      builder.align('center');
      builder.bold(true).doubleHeightWidth(true);
      builder.text('<%= user.branch ? user.branch.name : "RG SIMPLE POS" %>');
      builder.newLine();
      builder.doubleHeightWidth(false);
      builder.text(sep).newLine();

      // ── Info del ticket ──
      builder.align('left');
      builder.text(`Ticket #: ${ticketNumber}`).newLine();
      builder.text(`Fecha: ${new Date().toLocaleString('es-SV')}`).newLine();

      const clientSelect = document.getElementById('client-id-select');
      const clientName = clientSelect && clientSelect.value ?
        clientSelect.options[clientSelect.selectedIndex].text.split('(')[0].trim() :
        'Consumidor Final';
      builder.text(`Cliente: ${clientName}`).newLine();
      builder.text(sep).newLine();

      // ── Encabezado de artículos ──
      builder.bold(true);
      builder.itemLine('Articulo', 'Cant', 'Precio', 'Total');
      builder.bold(false);
      builder.newLine();

      // ── Líneas de artículos ──
      cart.forEach(item => {
        const price = parseFloat(item.price);
        let promo = typeof promotions !== 'undefined' ? promotions.find(p => p.productId === item.productId) : null;
        if (!promo && item.categoryId && typeof promotions !== 'undefined') {
          promo = promotions.find(p => p.categoryId === item.categoryId);
        }
        let discount = 0;
        if (promo) {
          if (promo.type === 'percentage') {
            discount = price * (parseFloat(promo.value) / 100) * item.quantity;
          } else if (promo.type === 'fixed_price') {
            const pp = parseFloat(promo.value);
            if (pp < price) discount = (price - pp) * item.quantity;
          } else if (promo.type === 'bulk' && item.quantity >= promo.buyQty) {
            discount = Math.floor(item.quantity / promo.buyQty) * (promo.buyQty - promo.payQty) * price;
          }
        }
        const net = (price * item.quantity) - discount;
        builder.itemLine(item.customDescription || item.name, item.quantity, price, net);
        builder.newLine();
        if (discount > 0) {
          builder.text(`  Desc: -$${discount.toFixed(2)}`).newLine();
        }
      });

      builder.text(sep).newLine();

      // ── Totales ──
      const totals = getCartTotals();
      builder.align('right');
      if (totals.discount > 0) {
        builder.text(`Subtotal: $${totals.gross.toFixed(2)}`).newLine();
        builder.text(`Descuento: -$${totals.discount.toFixed(2)}`).newLine();
      }
      builder.bold(true);
      builder.text(`TOTAL: $${totals.net.toFixed(2)}`);
      builder.bold(false).newLine();

      // ── Detalle de pago ──
      builder.text(sep).newLine();
      builder.align('left');
      let payLabel = 'Efectivo';
      if (paymentMethod === 'card') payLabel = 'Tarjeta';
      if (paymentMethod === 'credit') payLabel = 'Credito';
      if (paymentMethod === 'split') payLabel = 'Mixto';
      builder.text(`Forma de pago: ${payLabel}`).newLine();

      if (paymentMethod === 'split') {
        if (cashPaid > 0) builder.text(`  Efectivo: $${cashPaid.toFixed(2)}`).newLine();
        if (cardPaid > 0) builder.text(`  Tarjeta:  $${cardPaid.toFixed(2)}`).newLine();
        if (creditPaid > 0) builder.text(`  Credito:  $${creditPaid.toFixed(2)}`).newLine();
      }
      if (cardRef) {
        builder.text(`Ref. Tarjeta: ${cardRef}`).newLine();
      }
      if (paymentMethod === 'cash' || (paymentMethod === 'split' && cashPaid > 0)) {
        const totalPaid = paymentMethod === 'split' ? (cashPaid + cardPaid + creditPaid) : cashPaid;
        const change = totalPaid - totals.net;
        if (change > 0) {
          builder.text(`Recibido: $${totalPaid.toFixed(2)}`).newLine();
          builder.bold(true);
          builder.text(`Cambio:   $${change.toFixed(2)}`);
          builder.bold(false).newLine();
        }
      }

      // ── Pie ──
      builder.newLine();
      builder.align('center');
      builder.doubleHeightWidth(true);
      builder.text('Gracias por su compra').newLine();
      builder.newLineN(4);
      builder.doubleHeightWidth(false);
      builder.cut(false);

      await printerClient.sendCommands(builder.build());
      showToast('Ticket impreso con éxito.', 'success');
    } catch (err) {
      console.error('Error al imprimir ticket:', err);
      showToast('Error de conexión con la impresora.', 'error');
    }
  }

  async function triggerOpenCashDrawer() {
    try {
      if (printerClient.status !== 'connected') {
        showToast('La impresora no está conectada. No se puede abrir el cajón.', 'error');
        return;
      }
      await printerClient.openCashDrawer();
      showToast('Cajón de dinero abierto con éxito.', 'success');
    } catch (err) {
      console.error('Error al abrir el cajón de dinero:', err);
      showToast('Error al abrir el cajón de dinero.', 'error');
    }
  }
</script>

