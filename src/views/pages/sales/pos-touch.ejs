        <button type="button" id="touch-cobrar-btn" onclick="submitSale()" class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-2xl text-sm text-center shadow-lg shadow-blue-500/20 cursor-pointer transition-all">COBRAR</button>
      </div>

    </div>
  </main>
</div>

