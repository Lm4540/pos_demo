        <div class="space-y-1.5">
          <span class="text-[9px] font-bold text-neutral-500 uppercase tracking-wider block">Billetes Rápidos</span>
          <div class="grid grid-cols-6 gap-1.5">
            <button type="button" onclick="addQuickBill(1)" class="quick-bill-btn py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl font-bold text-xs text-center cursor-pointer transition-all hover:bg-neutral-850">+ $1</button>
            <button type="button" onclick="addQuickBill(5)" class="quick-bill-btn py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl font-bold text-xs text-center cursor-pointer transition-all hover:bg-neutral-850">+ $5</button>
            <button type="button" onclick="addQuickBill(10)" class="quick-bill-btn py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl font-bold text-xs text-center cursor-pointer transition-all hover:bg-neutral-850">+ $10</button>
            <button type="button" onclick="addQuickBill(20)" class="quick-bill-btn py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl font-bold text-xs text-center cursor-pointer transition-all hover:bg-neutral-850">+ $20</button>
            <button type="button" onclick="addQuickBill(50)" class="quick-bill-btn py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl font-bold text-xs text-center cursor-pointer transition-all hover:bg-neutral-850">+ $50</button>
            <button type="button" onclick="addQuickBill(100)" class="quick-bill-btn py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl font-bold text-xs text-center cursor-pointer transition-all hover:bg-neutral-850">+ $100</button>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <button type="button" onclick="setExactCash()" class="quick-bill-btn py-3 bg-neutral-950 border border-neutral-850 text-white rounded-2xl font-bold text-xs text-center cursor-pointer transition-all hover:bg-neutral-850">Monto Exacto</button>
          <button type="button" onclick="clearCashReceived()" class="quick-bill-btn py-3 bg-neutral-950 border border-neutral-850 text-white rounded-2xl font-bold text-xs text-center cursor-pointer transition-all hover:bg-neutral-850">Limpiar</button>
        </div>
      </div>

      <!-- Persistent Cobrar Button at the bottom -->
