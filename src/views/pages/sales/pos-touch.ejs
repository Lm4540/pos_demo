<%- include('../../partials/head', { title: 'POS Touch' }) %>

<style>
  /* Custom POS Touch theme styling overrides */
  .light-mode main {
    background-color: #f3f4f6 !important;
  }

  .light-mode main>div:first-child {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
  }

  .light-mode main>div:last-child {
    background-color: #f3f4f6 !important;
    border-color: #e5e7eb !important;
  }

  /* Text colors overrides in light mode */
  .light-mode #cart-total {
    color: #2563eb !important;
  }

  .light-mode #cart-subtotal {
    color: #1f2937 !important;
  }

  .light-mode #active-client-name {
    color: #111827 !important;
  }

  /* Light mode overrides for opacity background classes */
  .light-mode #totals-card {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
  }

  .light-mode #totals-card span {
    color: #1f2937 !important;
  }

  .light-mode #totals-card #cart-discount-row span {
    color: #ef4444 !important;
  }

  .light-mode #totals-card #cart-total {
    color: #2563eb !important;
  }

  .light-mode #customer-card {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
  }

  .light-mode #customer-card button {
    background-color: #ffffff !important;
    border-color: #d1d5db !important;
  }

  .light-mode #payment-methods-card {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
  }

  .light-mode #switches-card {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
  }

  .light-mode #switches-card>div {
    background-color: #f9fafb !important;
    border-color: #e5e7eb !important;
  }

  .light-mode #switches-card span {
    color: #4b5563 !important;
  }

  .light-mode #cart-header-title {
    background-color: #f9fafb !important;
    border-color: #e5e7eb !important;
  }

  .light-mode #cart-header-title h2 {
    color: #4b5563 !important;
  }

  /* Payment Selector active / inactive states in light mode */
  .light-mode #btn-pay-cash.active-cash {
    background-color: #d1fae5 !important;
    border-color: #10b981 !important;
    color: #065f46 !important;
  }

  .light-mode #btn-pay-card.active-card {
    background-color: #dbeafe !important;
    border-color: #3b82f6 !important;
    color: #1e3a8a !important;
  }

  .light-mode #btn-pay-credit.active-credit {
    background-color: #fef3c7 !important;
    border-color: #f59e0b !important;
    color: #78350f !important;
  }

  .light-mode #btn-pay-split.active-split {
    background-color: #ede9fe !important;
    border-color: #8b5cf6 !important;
    color: #4c1d95 !important;
  }

  .light-mode #btn-pay-cash:not(.active-cash),
  .light-mode #btn-pay-card:not(.active-card),
  .light-mode #btn-pay-credit:not(.active-credit),
  .light-mode #btn-pay-split:not(.active-split) {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
    color: #4b5563 !important;
  }

  /* Cálculo de vuelto card in light mode */
  .light-mode .vuelto-card {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
    color: #1f2937 !important;
  }

  .light-mode .vuelto-card input {
    background-color: #ffffff !important;
    color: #111827 !important;
    border-color: #e5e7eb !important;
  }

  .light-mode .vuelto-card .quick-bill-btn {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
    color: #1f2937 !important;
  }

  .light-mode .vuelto-card .quick-bill-btn:hover {
    border-color: #3b82f6 !important;
    background-color: #f9fafb !important;
  }

  /* Catalog list and dialog overrides in light mode */
  .light-mode #product-search-modal>div,
  .light-mode #custom-prompt-modal>div {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
    color: #1f2937 !important;
  }

  .light-mode #product-search-modal h3 span,
  .light-mode #custom-prompt-modal h3 {
    color: #111827 !important;
  }

  .light-mode #product-search-modal input,
  .light-mode #custom-prompt-modal input {
    background-color: #f9fafb !important;
    color: #111827 !important;
    border-color: #d1d5db !important;
  }

  .light-mode .cat-tab-btn:not(.bg-blue-600) {
    background-color: #f3f4f6 !important;
    border-color: #d1d5db !important;
    color: #4b5563 !important;
  }

  .light-mode .catalog-item-card {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
  }

  .light-mode .catalog-item-card span {
    color: #1f2937 !important;
  }

  .light-mode .catalog-item-card .text-white {
    color: #111827 !important;
  }

  /* Persistent Cobra button light mode overrides */
  .light-mode #touch-cobrar-btn {
    background-color: #2563eb !important;
    color: #ffffff !important;
    border: none !important;
  }

  .light-mode #touch-cobrar-btn:hover {
    background-color: #1d4ed8 !important;
  }

  /* Active states in dark mode */
  #btn-pay-cash.active-cash {
    background-color: rgba(16, 185, 129, 0.15) !important;
    border-color: #10b981 !important;
    color: #34d399 !important;
  }

  #btn-pay-card.active-card {
    background-color: rgba(59, 130, 246, 0.15) !important;
    border-color: #3b82f6 !important;
    color: #60a5fa !important;
  }

  #btn-pay-credit.active-credit {
    background-color: rgba(245, 158, 11, 0.15) !important;
    border-color: #f59e0b !important;
    color: #fbbf24 !important;
  }

  #btn-pay-split.active-split {
    background-color: rgba(139, 92, 246, 0.15) !important;
    border-color: #8b5cf6 !important;
    color: #a78bfa !important;
  }

  /* Default inactive styles in dark mode */
  #btn-pay-cash:not(.active-cash),
  #btn-pay-card:not(.active-card),
  #btn-pay-credit:not(.active-credit),
  #btn-pay-split:not(.active-split) {
    background-color: #0a0a0a !important;
    border-color: #262626 !important;
    color: #a3a3a3 !important;
  }

  /* Vibrant Green highlight for Vuelto/Change */
  #cash-change-display {
    color: #10b981 !important;
  }

  .light-mode #cash-change-display {
    color: #10b981 !important;
  }

  /* Switch coloring custom overrides */
  #print-ticket-switch+div,
  #voice-synthesis-switch+div {
    background-color: #4b5563 !important;
    /* dark gray when off in dark mode */
  }

  .light-mode #print-ticket-switch+div,
  .light-mode #voice-synthesis-switch+div {
    background-color: #d1d5db !important;
    /* light gray when off in light mode */
  }

  #print-ticket-switch:checked+div {
    background-color: #2563eb !important;
    /* blue when active */
  }

  #voice-synthesis-switch:checked+div {
    background-color: #4f46e5 !important;
    /* indigo/violet when active */
  }

  /* Scanner bar & celeste search button */
  #scanner-bar {
    background-color: transparent !important;
  }

  .light-mode #scanner-bar {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
  }

  #btn-search-product {
    background-color: #0ea5e9 !important;
    /* sky-500 celeste */
    color: #ffffff !important;
    border: none !important;
  }

  #btn-search-product:hover {
    background-color: #0284c7 !important;
    /* sky-600 */
  }
</style>

<div class="h-screen w-screen bg-neutral-950 flex flex-col overflow-hidden text-white select-none">
  <!-- Top bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-4 py-2 flex items-center justify-between shadow-md flex-shrink-0">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="h-10 w-10 bg-neutral-800 hover:bg-neutral-750 text-neutral-300 rounded-xl flex items-center justify-center transition-colors">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
      </a>
      <div>
        <span class="text-sm font-bold block text-white leading-tight">POS Touch</span>
        <span class="text-[10px] text-neutral-400">Turno: <strong class="text-indigo-400">#<%= turn.id %></strong> | Sucursal: <%= user.branch ? user.branch.name : 'N/A' %></span>
      </div>
    </div>

    <!-- Right Top actions -->
    <div class="flex items-center gap-2">
      <!-- Contenedor de estado de impresora -->
      <div id="printer-status-container" class="flex items-center gap-2 mr-1"></div>

      <% 
        const hasOpenDrawerPermission = 
          user.roleId === 'admin' || 
          (user.specialPermissions && user.specialPermissions['pos.open_drawer'] === true) || 
          (user.roleId === 'supervisor' && (!user.specialPermissions || user.specialPermissions['pos.open_drawer'] !== false));
      %>
      <% if (hasOpenDrawerPermission) { %>
      <button type="button" onclick="triggerOpenCashDrawer()" class="h-10 w-10 bg-amber-950/40 hover:bg-amber-900 border border-amber-900/60 text-amber-400 rounded-xl flex items-center justify-center transition-colors cursor-pointer" title="Abrir Cajón de Dinero">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
        </svg>
      </button>
      <% } %>



      <a href="/sales/history" class="h-10 w-10 bg-neutral-800 hover:bg-neutral-750 text-neutral-300 rounded-xl flex items-center justify-center transition-colors" title="Historial">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2" />
        </svg>
      </a>
      <button onclick="openCustomerDisplay()" class="h-10 w-10 bg-indigo-950/80 hover:bg-indigo-900 border border-indigo-900/60 text-indigo-400 rounded-xl flex items-center justify-center transition-colors" title="Pantalla Cliente">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </button>
      <button id="btn-theme-toggle" onclick="toggleTheme()" class="h-10 w-10 bg-neutral-800 hover:bg-neutral-750 text-neutral-350 rounded-xl flex items-center justify-center transition-colors">
        <svg id="theme-sun-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <svg id="theme-moon-icon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- POS Main workspace -->
  <main class="flex-grow flex overflow-hidden">

    <!-- Left Panel: Cart & Scanner Bar (60% width) -->
    <div class="w-[60%] flex flex-col bg-neutral-950 border-r border-neutral-900">

      <!-- Top Scanner Bar -->
      <div id="scanner-bar" class="p-3 bg-neutral-900/40 border-b border-neutral-900 flex gap-2 flex-shrink-0 items-center">
        <div class="relative flex-grow">
          <input type="text" id="barcode-input" class="w-full pl-10 pr-3 py-3.5 bg-neutral-950 border border-neutral-800 text-white rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono font-bold" placeholder="Escanear código de barras..." autofocus>
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center text-neutral-550 pointer-events-none">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        </div>
        <button id="btn-search-product" onclick="openProductSearchModal()" class="px-5 py-3.5 bg-blue-600 hover:bg-blue-500 text-white rounded-2xl font-extrabold text-sm flex items-center gap-1.5 transition-all shadow-md shadow-blue-500/10 cursor-pointer">
          <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span>Buscar Producto</span>
        </button>
      </div>

      <!-- Cart list -->
      <div class="flex-grow flex flex-col overflow-hidden">
        <div id="cart-header-title" class="p-3 border-b border-neutral-900 flex justify-between items-center bg-neutral-900/20 flex-shrink-0">
          <h2 class="text-xs font-bold text-neutral-400 uppercase tracking-wider">Detalles de la Venta</h2>
          <button onclick="clearCart()" class="px-3 py-1.5 text-xs font-bold bg-red-950/60 hover:bg-red-900 text-red-400 border border-red-900/60 rounded-xl cursor-pointer">Vaciar Todo</button>
        </div>

        <div id="cart-items-container" class="flex-grow overflow-y-auto p-3 space-y-2.5 no-scrollbar">
          <div class="text-center py-10 text-neutral-500 text-xs">El carrito está vacío</div>
        </div>
      </div>
    </div>

    <!-- Right Panel: Totals, Controls & Keypad (40% width) -->
    <div class="w-[40%] flex flex-col bg-neutral-900/30 overflow-hidden">

      <!-- Cart Totals Info -->
      <div id="totals-card" class="p-4 bg-neutral-900/80 space-y-2.5 flex-shrink-0 border-b border-neutral-900">
        <div class="flex justify-between items-center text-xs text-neutral-400">
          <span>Subtotal Bruto:</span>
          <span id="cart-subtotal" class="font-mono">$0.00</span>
        </div>
        <div id="cart-discount-row" class="hidden flex justify-between items-center text-xs text-red-450">
          <span>Descuento Aplicado:</span>
          <span id="cart-discount" class="font-mono font-bold">-$0.00</span>
        </div>
        <div class="flex justify-between items-center text-lg font-black border-t border-neutral-800/80 pt-2">
          <span>TOTAL COMPRA:</span>
          <span id="cart-total" class="text-2xl text-blue-400 font-mono font-black">$0.00</span>
        </div>
      </div>

      <!-- Customer Selector card -->
      <div id="customer-card" class="p-3 bg-neutral-900/30 border-b border-neutral-900 flex-shrink-0">
        <button onclick="openClientSearchModal()" class="w-full bg-neutral-950 border border-neutral-850 hover:border-amber-500/80 p-3 rounded-2xl flex items-center justify-between text-left hover:bg-neutral-900/30 transition-all cursor-pointer">
          <div>
            <span class="text-[9px] uppercase tracking-wider font-bold text-neutral-500 block">Cliente</span>
            <span id="active-client-name" class="text-xs font-bold text-white block">Consumidor Final</span>
          </div>
          <svg class="h-4 w-4 text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>

      <!-- Payment Method buttons selector (Colored & Large) -->
      <div id="payment-methods-card" class="p-3 bg-neutral-900/30 border-b border-neutral-900 grid grid-cols-4 gap-2 flex-shrink-0">
        <button onclick="setPaymentMethod('cash')" id="btn-pay-cash" class="flex flex-col items-center justify-center py-3 active-cash rounded-2xl transition-all cursor-pointer">
          <svg class="h-5 w-5 mb-1 text-emerald-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-[10px] font-black tracking-wide">EFECTIVO</span>
        </button>
        <button onclick="setPaymentMethod('card')" id="btn-pay-card" class="flex flex-col items-center justify-center py-3 rounded-2xl transition-all cursor-pointer">
          <svg class="h-5 w-5 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
          <span class="text-[10px] font-black tracking-wide">TARJETA</span>
        </button>
        <button onclick="setPaymentMethod('credit')" id="btn-pay-credit" class="flex flex-col items-center justify-center py-3 rounded-2xl transition-all cursor-pointer">
          <svg class="h-5 w-5 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-[10px] font-black tracking-wide">CRÉDITO</span>
        </button>
        <button onclick="setPaymentMethod('split')" id="btn-pay-split" class="flex flex-col items-center justify-center py-3 rounded-2xl transition-all cursor-pointer">
          <svg class="h-5 w-5 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          <span class="text-[10px] font-black tracking-wide">DIVIDIDO</span>
        </button>
      </div>

      <!-- Card transaction ref panel -->
      <div id="card-ref-container" class="p-3 bg-neutral-950 border-b border-neutral-900 flex items-center gap-2 hidden flex-shrink-0">
        <span class="text-[9px] text-neutral-450 font-bold uppercase whitespace-nowrap tracking-wider">Ref. Tarjeta:</span>
        <input type="text" id="card-transaction-ref" class="flex-grow px-3 py-2.5 bg-neutral-900 border border-neutral-800 text-white text-xs rounded-xl font-mono focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="# Transacción POS">
      </div>

      <!-- Split payment panel -->
      <div id="split-payment-breakdown" class="p-3 bg-neutral-950 border-b border-neutral-900 space-y-2 hidden flex-shrink-0">
        <div class="grid grid-cols-3 gap-2">
          <div>
            <label class="block text-[8px] text-neutral-400 uppercase mb-0.5">Efectivo ($)</label>
            <input type="number" step="0.01" min="0" id="split-cash-input" value="0.00" class="w-full text-center px-1.5 py-1.5 bg-neutral-900 border border-neutral-800 text-white rounded-xl text-xs font-mono focus:ring-1 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-[8px] text-neutral-400 uppercase mb-0.5">Tarjeta ($)</label>
            <input type="number" step="0.01" min="0" id="split-card-input" value="0.00" class="w-full text-center px-1.5 py-1.5 bg-neutral-900 border border-neutral-800 text-white rounded-xl text-xs font-mono focus:ring-1 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-[8px] text-neutral-400 uppercase mb-0.5">Crédito ($)</label>
            <input type="number" step="0.01" min="0" id="split-credit-input" value="0.00" class="w-full text-center px-1.5 py-1.5 bg-neutral-900 border border-neutral-800 text-white rounded-xl text-xs font-mono focus:ring-1 focus:ring-blue-500">
          </div>
        </div>
        <div class="flex justify-between items-center text-[10px]">
          <span class="text-neutral-500 font-bold uppercase tracking-wider">Diferencia:</span>
          <span id="split-remaining" class="font-bold font-mono text-red-400">$0.00</span>
        </div>
      </div>

      <!-- Control switches row -->
      <div id="switches-card" class="px-3 py-2 bg-neutral-950/20 border-b border-neutral-900 grid grid-cols-2 gap-2 flex-shrink-0">
        <!-- Print switch -->
        <div class="flex justify-between items-center px-2 py-1 bg-neutral-900/60 rounded-xl border border-neutral-850">
          <span class="text-[9px] font-bold text-neutral-450 uppercase tracking-wider">Imp. Ticket</span>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="print-ticket-switch" class="sr-only peer" checked>
            <div class="w-7 h-4 bg-neutral-850 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-blue-600"></div>
          </label>
        </div>
        <!-- Voice switch -->
        <div class="flex justify-between items-center px-2 py-1 bg-neutral-900/60 rounded-xl border border-neutral-850">
          <span class="text-[9px] font-bold text-neutral-450 uppercase tracking-wider">Voz Cliente</span>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="voice-synthesis-switch" class="sr-only peer" checked>
            <div class="w-7 h-4 bg-neutral-850 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-indigo-600"></div>
          </label>
        </div>
      </div>

      <!-- Vuelto & Billetes Rápidos card -->
      <div id="cash-payment-details" class="vuelto-card p-5 bg-neutral-900 border border-neutral-800 rounded-3xl space-y-4 m-3 flex-shrink-0">
        <div class="flex justify-between items-center">
          <span class="text-[11px] font-bold text-neutral-400 uppercase tracking-wider">Cálculo de Vuelto</span>
        </div>

        <div class="grid grid-cols-2 gap-3 items-center">
          <div class="bg-neutral-950 p-2.5 rounded-2xl border border-neutral-850">
            <label class="block text-[9px] text-neutral-500 font-bold uppercase tracking-wider mb-1">Efectivo Recibido ($)</label>
            <input type="number" step="0.01" min="0" id="cash-received-input" value="0.00" class="w-full text-center bg-transparent text-white rounded-xl text-2xl font-mono font-bold focus:outline-none" placeholder="0.00">
