<script src="/js/escpos-printer.js"></script>
<script>
  const printerClient = new WebPOSPrinterLocalServer('wss://localhost:4567');
  printerClient.connect();
  window.currentUserFullName = '<%= user.fullName %>';
  window.lastCompletedSaleData = null;

  const promotions = <%- JSON.stringify(promotions) %>;

  // Default combined items list
  const frequentItemsList = <%- JSON.stringify(frequentProducts.map(bp => ({
    productId: bp.productId,
    name: bp.product.name,
    salePrice: bp.salePrice,
    totalStock: bp.totalStock,
    categoryId: bp.product.categoryId,
    imagePath: bp.product.imagePath,
    type: 'physical'
  }))) %>;

  const serviceItemsList = <%- JSON.stringify(serviceProducts.map(sp => ({
    productId: sp.id,
    name: sp.name,
    salePrice: sp.branchProducts && sp.branchProducts[0] ? parseFloat(sp.branchProducts[0].salePrice) : 0,
    totalStock: 9999,
    categoryId: sp.categoryId,
    imagePath: sp.imagePath,
    type: 'service'
  }))) %>;

  const defaultCatalogItems = [...frequentItemsList, ...serviceItemsList];
  let currentFilterCategory = 'all';
  let cart = [];
  let paymentMethod = 'cash';
  let lastCompletedCart = [];
  let lastCompletedPaymentMethod = 'cash';

  // BroadcastChannel for customer display communication
  const posChannel = new BroadcastChannel('pos-customer-display');

  // Active virtual input for virtual keyboard focus binding
  let activeVirtualInput = null;

  function focusVirtualInput(inputEl) {
    activeVirtualInput = inputEl;
  }

  // Quick bills addition
  function addQuickBill(amount) {
    const input = document.getElementById('cash-received-input');
    if (!input) return;
    const current = parseFloat(input.value) || 0;
    input.value = (current + amount).toFixed(2);
    input.dispatchEvent(new Event('input', {
      bubbles: true
    }));
  }

  function setExactCash() {
    const input = document.getElementById('cash-received-input');
    if (!input) return;
    const totalNet = getCartTotals().net;
    input.value = totalNet.toFixed(2);
    input.dispatchEvent(new Event('input', {
      bubbles: true
    }));
  }

  function clearCashReceived() {
    const input = document.getElementById('cash-received-input');
    if (!input) return;
    input.value = '0.00';
    input.dispatchEvent(new Event('input', {
      bubbles: true
    }));
  }

  // Auto-open customer display window
  let customerDisplayWindow = null;

  function openCustomerDisplay() {
    if (customerDisplayWindow && !customerDisplayWindow.closed) return;
    const features = 'menubar=no,toolbar=no,location=no,status=no,scrollbars=no,resizable=yes';
    customerDisplayWindow = window.open('/sales/customer-display', 'CustomerDisplay', `${features},width=1024,height=768`);
  }

  function emitCartUpdate() {
    const totals = getCartTotals();
    const receivedEl = document.getElementById('cash-received-input');
    const cashReceived = receivedEl ? (parseFloat(receivedEl.value) || 0) : 0;
    const changeAmount = Math.max(0, cashReceived - totals.net);

    posChannel.postMessage({
      type: 'cart_update',
      data: {
        items: cart.map(i => ({
          name: i.name,
          price: i.price,
          quantity: i.quantity,
          type: i.type || 'physical',
          customDescription: i.customDescription || null
        })),
        totalGross: totals.gross,
        totalDiscount: totals.discount,
        totalNet: totals.net,
        paymentMethod: paymentMethod,
        cashReceived: cashReceived,
        changeAmount: changeAmount
      }
    });
  }

  function getCartTotals() {
    let totalGross = 0;
    let totalDiscount = 0;
    cart.forEach(item => {
      const price = parseFloat(item.price);
      let promo = promotions.find(p => p.productId === item.productId);
      if (!promo && item.categoryId) {
        promo = promotions.find(p => p.categoryId === item.categoryId);
      }
      let discount = 0;
      if (promo) {
        if (promo.type === 'percentage') {
          discount = price * (parseFloat(promo.value) / 100) * item.quantity;
        } else if (promo.type === 'fixed_price') {
          const promoPrice = parseFloat(promo.value);
          if (promoPrice < price) {
            discount = (price - promoPrice) * item.quantity;
          }
        } else if (promo.type === 'bulk') {
          const buyQty = promo.buyQty;
          const payQty = promo.payQty;
          if (item.quantity >= buyQty) {
            const groups = Math.floor(item.quantity / buyQty);
            const freeUnits = groups * (buyQty - payQty);
            discount = freeUnits * price;
          }
        }
      }
      totalGross += price * item.quantity;
      totalDiscount += discount;
    });
    return {
      gross: totalGross,
      discount: totalDiscount,
      net: totalGross - totalDiscount
    };
  }

  function addToCart(productId, name, price, stock, categoryId, type = 'physical') {
    if (type === 'service' && parseFloat(price) === 0) {
      showCustomPrompt(
        `Precio del Servicio`,
        `Ingrese el precio para el servicio "${name}":`,
        '0.00',
        (inputPrice) => {
          const parsed = parseFloat(inputPrice);
          if (isNaN(parsed) || parsed < 0) {
            showToast('Precio inválido.', 'warning');
            return;
          }
          addToCart(productId, name, parsed, stock, categoryId, type);
        }
      );
      return;
    }

    const existing = cart.find(i => i.productId === productId);
    if (existing) {
      if (type !== 'service' && existing.quantity >= stock) {
        showToast(`Stock insuficiente. Solo quedan ${stock} unidades.`, 'warning');
        return;
      }
      existing.quantity += 1;
      // showToast(`Agregado: ${name} (Cant: 1)`, 'success');
      playScanSound();
    } else {
      if (type !== 'service' && stock <= 0) {
        showToast('Producto agotado.', 'warning');
        return;
      }
      cart.push({
        productId,
        name,
        price,
        quantity: 1,
        stock,
        categoryId,
        type,
        customDescription: null
      });
      // showToast(`Agregado: ${name} (Cant: 1)`, 'success');
      playScanSound();
    }
    renderCart();

    // Auto-focus back to barcode scanner
    const barInput = document.getElementById('barcode-input');
    if (barInput) {
      barInput.focus();
      focusVirtualInput(barInput);
    }
  }

  function updateQty(productId, delta, idx) {
    const item = idx !== undefined ? cart[idx] : cart.find(i => i.productId === productId);
    if (!item) return;
    if (delta > 0 && item.type !== 'service' && item.quantity >= item.stock) {
      showToast('Existencia máxima alcanzada.', 'warning');
      return;
    }
    item.quantity += delta;
    if (item.quantity <= 0) {
      if (idx !== undefined) cart.splice(idx, 1);
      else cart = cart.filter(i => i.productId !== productId);
    }
    renderCart();
  }

  function removeCartItem(productId) {
    cart = cart.filter(i => i.productId !== productId);
    renderCart();
  }

  function editServiceDescription(productId, idx) {
    const item = cart[idx];
    if (!item) return;
    showCustomPrompt(
      `Editar Descripción`,
      `Descripción del servicio:`,
      item.customDescription || item.name,
      (desc) => {
        item.customDescription = desc.trim() || null;
        renderCart();
      }
    );
  }

  function editServicePrice(productId, idx) {
    const item = cart[idx];
    if (!item) return;
    showCustomPrompt(
      `Editar Precio`,
      `Nuevo precio del servicio:`,
      item.price.toString(),
      (newPrice) => {
        const parsed = parseFloat(newPrice);
        if (!isNaN(parsed) && parsed >= 0) {
          item.price = parsed;
          renderCart();
        } else {
          showToast('Precio inválido.', 'warning');
        }
      }
    );
  }

  function showCustomPrompt(title, label, defaultValue, onSubmit) {
    document.getElementById('custom-prompt-title').innerText = title;
    document.getElementById('custom-prompt-label').innerText = label;
    const input = document.getElementById('custom-prompt-input');
    input.value = defaultValue;

    // Clear previous submit listener by replacing the button with a clone
    const submitBtn = document.getElementById('custom-prompt-submit-btn');
    const newSubmitBtn = submitBtn.cloneNode(true);
    submitBtn.parentNode.replaceChild(newSubmitBtn, submitBtn);

    newSubmitBtn.addEventListener('click', () => {
      const value = input.value.trim();
      onSubmit(value);
      closeCustomPrompt();
    });

    // Also support Enter key
    input.onkeypress = (e) => {
      if (e.key === 'Enter') {
        newSubmitBtn.click();
      }
    };

    document.getElementById('custom-prompt-modal').classList.remove('hidden');
    setTimeout(() => input.focus(), 50);
  }

  function closeCustomPrompt() {
    document.getElementById('custom-prompt-modal').classList.add('hidden');
  }

  function clearCart() {
    cart = [];
    renderCart();
  }

  function renderCart() {
    const container = document.getElementById('cart-items-container');
    if (cart.length === 0) {
      container.innerHTML = `<div class="text-center py-10 text-neutral-500 text-xs">El carrito está vacío</div>`;
      document.getElementById('cart-subtotal').innerText = '$0.00';
      document.getElementById('cart-total').innerText = '$0.00';
      updateChangeCalculation();
      emitCartUpdate();
      return;
    }

    let totalGross = 0;
    let totalDiscount = 0;

    container.innerHTML = cart.map((item, idx) => {
      const price = parseFloat(item.price);
      let promo = promotions.find(p => p.productId === item.productId);
      if (!promo && item.categoryId) {
        promo = promotions.find(p => p.categoryId === item.categoryId);
      }
      let discount = 0;
      let promoText = '';
      if (promo) {
        if (promo.type === 'percentage') {
          discount = price * (parseFloat(promo.value) / 100) * item.quantity;
          promoText = `<span class="text-[9px] font-bold text-red-400 block">Desc. ${promo.value}%</span>`;
        } else if (promo.type === 'fixed_price') {
          if (parseFloat(promo.value) < price) {
            discount = (price - parseFloat(promo.value)) * item.quantity;
            promoText = `<span class="text-[9px] font-bold text-red-400 block">Promo $${promo.value}</span>`;
          }
        } else if (promo.type === 'bulk') {
          if (item.quantity >= promo.buyQty) {
            const groups = Math.floor(item.quantity / promo.buyQty);
            discount = groups * (promo.buyQty - promo.payQty) * price;
            promoText = `<span class="text-[9px] font-bold text-red-400 block">Promo ${promo.buyQty}x${promo.payQty}</span>`;
          }
        }
      }
      const itemGross = price * item.quantity;
      const itemNet = itemGross - discount;
      totalGross += itemGross;
      totalDiscount += discount;

      const isService = item.type === 'service';
      const displayName = item.customDescription || item.name;

      return `
        <div class="flex items-center justify-between p-3 bg-neutral-950 border border-neutral-850 rounded-2xl">
          <div class="flex-grow max-w-[50%]">
            <span class="text-xs font-bold text-white block truncate">${displayName}</span>
            <span class="text-[10px] text-neutral-500">$${price.toFixed(2)} ${isService ? '✦ Servicio' : ''}</span>
            ${isService ? `<div class="flex gap-2 mt-1"><button onclick="editServiceDescription(${item.productId}, ${idx})" class="text-[9px] font-bold text-blue-400 hover:underline cursor-pointer">✏️ Desc.</button><button onclick="editServicePrice(${item.productId}, ${idx})" class="text-[9px] font-bold text-amber-400 hover:underline cursor-pointer">💲 Precio</button></div>` : ''}
            ${promoText}
          </div>
          <div class="flex items-center gap-2">
            <button onclick="updateQty(${item.productId}, -1, ${idx})" class="h-8 w-8 rounded-xl bg-neutral-850 hover:bg-neutral-800 flex items-center justify-center text-white text-xs cursor-pointer font-bold">-</button>
            <span class="w-6 text-center text-xs font-bold text-white">${item.quantity}</span>
            <button onclick="updateQty(${item.productId}, 1, ${idx})" class="h-8 w-8 rounded-xl bg-neutral-850 hover:bg-neutral-800 flex items-center justify-center text-white text-xs cursor-pointer font-bold">+</button>
            <button onclick="removeCartItem(${item.productId})" class="h-8 w-8 ml-2 text-red-500 hover:text-red-400 text-sm flex items-center justify-center cursor-pointer font-bold">✕</button>
          </div>
          <span class="text-xs font-bold text-white w-14 text-right font-mono">$${itemNet.toFixed(2)}</span>
        </div>
      `;
    }).join('');

    const totalNet = totalGross - totalDiscount;
    document.getElementById('cart-subtotal').innerText = `$${totalGross.toFixed(2)}`;
    document.getElementById('cart-total').innerText = `$${totalNet.toFixed(2)}`;

    const discountRow = document.getElementById('cart-discount-row');
    const discountSpan = document.getElementById('cart-discount');
    if (totalDiscount > 0) {
      discountSpan.innerText = `-$${totalDiscount.toFixed(2)}`;
      discountRow.classList.remove('hidden');
    } else {
      discountRow.classList.add('hidden');
    }

    if (paymentMethod === 'split') {
      document.getElementById('split-cash-input').value = totalNet.toFixed(2);
      document.getElementById('split-card-input').value = '0.00';
      document.getElementById('split-credit-input').value = '0.00';
      updateSplitBreakdownTotals();
    }

    updateChangeCalculation();
    emitCartUpdate();
  }

  function updateChangeCalculation() {
    const totalNet = getCartTotals().net;
    const received = parseFloat(document.getElementById('cash-received-input').value) || 0;
    const change = Math.max(0, received - totalNet);
    const display = document.getElementById('cash-change-display');
    if (display) {
      display.innerText = `$${change.toFixed(2)}`;
    }
    posChannel.postMessage({
      type: 'cash_received_update',
      data: {
        cashReceived: received,
        changeAmount: change
      }
    });
  }

  function setPaymentMethod(method) {
    paymentMethod = method;
    const btnCash = document.getElementById('btn-pay-cash');
    const btnCard = document.getElementById('btn-pay-card');
    const btnCredit = document.getElementById('btn-pay-credit');
    const btnSplit = document.getElementById('btn-pay-split');
    const splitBreakdown = document.getElementById('split-payment-breakdown');
    const cardRefContainer = document.getElementById('card-ref-container');
    const cashContainer = document.getElementById('cash-payment-details');

    // Remove active classes
    btnCash.classList.remove('active-cash');
    btnCard.classList.remove('active-card');
    btnCredit.classList.remove('active-credit');
    btnSplit.classList.remove('active-split');

    if (method === 'cash') {
      btnCash.classList.add('active-cash');
      splitBreakdown.classList.add('hidden');
      if (cardRefContainer) cardRefContainer.classList.add('hidden');
      if (cashContainer) cashContainer.classList.remove('hidden');
      // Autofocus cash received input
      const cashInput = document.getElementById('cash-received-input');
      if (cashInput) {
        cashInput.focus();
        focusVirtualInput(cashInput);
      }
    } else if (method === 'card') {
      btnCard.classList.add('active-card');
      splitBreakdown.classList.add('hidden');
      if (cashContainer) cashContainer.classList.add('hidden');
      if (cardRefContainer) cardRefContainer.classList.remove('hidden');
      const refInput = document.getElementById('card-transaction-ref');
      if (refInput) {
        refInput.focus();
        focusVirtualInput(refInput);
      }
    } else if (method === 'credit') {
      btnCredit.classList.add('active-credit');
      splitBreakdown.classList.add('hidden');
      if (cashContainer) cashContainer.classList.add('hidden');
      if (cardRefContainer) cardRefContainer.classList.add('hidden');
      openClientSearchModal();
    } else if (method === 'split') {
      btnSplit.classList.add('active-split');
      splitBreakdown.classList.remove('hidden');
      if (cashContainer) cashContainer.classList.add('hidden');
      if (cardRefContainer) cardRefContainer.classList.remove('hidden');

      const totalNet = getCartTotals().net;
      document.getElementById('split-cash-input').value = totalNet.toFixed(2);
      document.getElementById('split-card-input').value = '0.00';
      document.getElementById('split-credit-input').value = '0.00';
      updateSplitBreakdownTotals();

      const splitCashInput = document.getElementById('split-cash-input');
      if (splitCashInput) {
        splitCashInput.focus();
        focusVirtualInput(splitCashInput);
      }
    }
    emitCartUpdate();
  }

  function updateSplitBreakdownTotals() {
    const cashVal = parseFloat(document.getElementById('split-cash-input').value) || 0;
    const cardVal = parseFloat(document.getElementById('split-card-input').value) || 0;
    const creditVal = parseFloat(document.getElementById('split-credit-input').value) || 0;
    const totalNet = getCartTotals().net;
    const sum = cashVal + cardVal + creditVal;
    const remaining = totalNet - sum;
    const remainingSpan = document.getElementById('split-remaining');
    if (Math.abs(remaining) < 0.01) {
      remainingSpan.innerText = "$0.00 (Cuadrado)";
      remainingSpan.className = "font-bold text-emerald-450 font-mono text-xs";
    } else {
      remainingSpan.innerText = (remaining > 0 ? "Falta " : "Sobra ") + `$${Math.abs(remaining).toFixed(2)}`;
      remainingSpan.className = "font-bold text-red-400 font-mono text-xs";
    }
  }

  // Bind inputs for cash received and split payments
  window.addEventListener('DOMContentLoaded', () => {
    // Set cash method by default
    setPaymentMethod('cash');

    const cashInput = document.getElementById('cash-received-input');
    if (cashInput) {
      cashInput.addEventListener('input', updateChangeCalculation);
      focusVirtualInput(cashInput);
    }

    ['split-cash-input', 'split-card-input', 'split-credit-input'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.addEventListener('input', updateSplitBreakdownTotals);
    });

    // Global focus tracking listener to bind virtual keypad to clicked inputs
    document.addEventListener('focusin', (e) => {
      if (e.target.tagName === 'INPUT') {
        activeVirtualInput = e.target;
      }
    });

    // Sync speech switch
    const voiceSwitch = document.getElementById('voice-synthesis-switch');
    if (voiceSwitch) {
      const isVoiceEnabled = localStorage.getItem('voice_customer_enabled') !== 'false';
      voiceSwitch.checked = isVoiceEnabled;
      voiceSwitch.addEventListener('change', (e) => {
        localStorage.setItem('voice_customer_enabled', e.target.checked ? 'true' : 'false');
        posChannel.postMessage({
          type: 'voice_update',
          data: {
            enabled: e.target.checked
          }
        });
      });
      posChannel.postMessage({
        type: 'voice_update',
        data: {
          enabled: isVoiceEnabled
        }
      });
    }

    // Intercept theme toggle to sync client display theme
    const originalToggleTheme = window.toggleTheme;
    window.toggleTheme = function() {
      if (originalToggleTheme) originalToggleTheme();
      setTimeout(syncCustomerDisplayTheme, 100);
    };

    // Close modals when clicking outside
    const productModal = document.getElementById('product-search-modal');
    if (productModal) {
      productModal.addEventListener('click', (e) => {
        if (e.target === productModal) {
          closeProductSearchModal();
        }
      });
    }

    const clientModal = document.getElementById('client-search-modal');
    if (clientModal) {
      clientModal.addEventListener('click', (e) => {
        if (e.target === clientModal) {
          closeClientSearchModal();
        }
      });
    }

    // Initial theme sync
    syncCustomerDisplayTheme();
  });

  function syncCustomerDisplayTheme() {
    const isLight = document.documentElement.classList.contains('light-mode');
    posChannel.postMessage({
      type: 'theme_update',
      data: {
        theme: isLight ? 'light' : 'dark'
      }
    });
  }

