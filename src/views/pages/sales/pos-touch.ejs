          <div class="flex flex-col justify-center text-center border-l border-neutral-800 pl-3">
            <span class="text-[9px] text-neutral-500 font-bold uppercase tracking-wider mb-1">Vuelto</span>
            <span id="cash-change-display" class="text-3xl font-black text-emerald-450 font-mono font-bold">$0.00</span>
