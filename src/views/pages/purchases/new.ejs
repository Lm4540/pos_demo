<%- include('../../partials/head', { title: 'Ingresar Compra' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/purchases" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Ingresar Factura de Compra</span>
        <span class="text-xs block text-neutral-400 font-medium">Abastecimiento de stock por lotes y caducidades</span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">
    <!-- Invoice Header & Add Items Form (5/12) -->
    <div class="lg:col-span-5 space-y-6">
      <!-- Invoice Header -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
        <h2 class="text-base font-bold text-white mb-4">Datos de Factura</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Número de Factura *</label>
            <input type="text" id="invoiceNumber" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" placeholder="FAC-00123">
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Proveedor *</label>
            <select id="supplierId" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
              <option value="">Seleccione un proveedor...</option>
              <% suppliers.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Condición de Pago</label>
              <select id="paymentMethod" onchange="toggleDueDate()" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
                <option value="cash">Contado (Pagado)</option>
                <option value="credit">Crédito (CxP)</option>
              </select>
            </div>
            <div id="due-date-container" class="hidden">
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fecha Vencimiento *</label>
              <input type="date" id="dueDate" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
            </div>
          </div>

          <!-- Cash Payment Details (caja vs deposit) -->
          <div id="cash-details-container" class="space-y-4 pt-2">
            <div class="border-t border-neutral-800 pt-3">
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Método de Pago (Contado)</label>
              <div class="grid grid-cols-2 gap-3">
                <label id="source-cashier-label" class="flex items-center gap-2 px-3 py-2 bg-neutral-950 border-2 border-blue-500 rounded-xl cursor-pointer transition-all">
                  <input type="radio" name="paymentSource" value="cashier" checked onchange="togglePaymentSource()" class="text-blue-600 focus:ring-blue-500 border-neutral-800 bg-neutral-900">
                  <div>
                    <span class="text-xs font-semibold text-white">💵 Caja Chica</span>
                  </div>
                </label>
                <label id="source-external-label" class="flex items-center gap-2 px-3 py-2 bg-neutral-950 border-2 border-neutral-800 rounded-xl cursor-pointer transition-all">
                  <input type="radio" name="paymentSource" value="external" onchange="togglePaymentSource()" class="text-blue-600 focus:ring-blue-500 border-neutral-800 bg-neutral-900">
                  <div>
                    <span class="text-xs font-semibold text-white">🏦 Banco / Depósito</span>
                  </div>
                </label>
              </div>
            </div>

            <!-- Cashier box selection -->
            <div id="purchase-caja-section" class="space-y-2">
              <label for="purchase-turnId" class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider">Caja Chica de Retiro *</label>
              <div id="purchase-turn-loading" class="flex items-center gap-2 text-neutral-500 text-sm">
                <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span>Cargando cajas...</span>
              </div>
              <select id="purchase-turnId" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm hidden">
              </select>
              <div id="purchase-turn-no-options" class="hidden bg-amber-950/30 border border-amber-800/40 text-amber-300 text-xs rounded-xl px-4 py-3">
                <span>No hay cajas abiertas. Registre el pago como banco o abra caja primero.</span>
              </div>
            </div>

            <!-- External bank voucher -->
            <div id="purchase-bank-section" class="hidden space-y-1">
              <label for="purchase-transactionRef" class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider">No. Autorización / Voucher *</label>
              <input type="text" id="purchase-transactionRef" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" placeholder="VOUCHER-12345">
            </div>
          </div>
        </div>
      </div>

      <!-- Add Item Panel -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
        <h2 class="text-base font-bold text-white mb-4">Agregar Producto</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Seleccionar Producto *</label>
            <div class="relative">
              <div class="flex gap-2">
                <div class="relative flex-grow">
                  <input type="text" id="productSearchInput" autocomplete="off" placeholder="Buscar por nombre o código..." class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
                  <!-- Search Results Dropdown -->
                  <div id="productSearchResults" class="absolute left-0 right-0 mt-1 max-h-60 overflow-y-auto bg-neutral-900 border border-neutral-800 rounded-xl shadow-xl z-50 hidden divide-y divide-neutral-850">
                  </div>
                </div>
                <button type="button" onclick="openQuickProductModal()" class="px-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl text-xs transition-all shadow-md shadow-blue-500/10 flex items-center gap-1 cursor-pointer whitespace-nowrap" title="Crear Nuevo Producto">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                  <span>Nuevo</span>
                </button>
              </div>
              <input type="hidden" id="productId">
              <input type="hidden" id="selectedProductBarcode">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Código de Lote *</label>
              <input type="text" id="batchCode" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" placeholder="LOTE-001">
            </div>
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fecha Vencimiento</label>
              <input type="date" id="expirationDate" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
            </div>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Cantidad *</label>
              <input type="number" id="quantity" min="1" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" placeholder="10">
            </div>
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Costo Unit. *</label>
              <input type="number" step="0.01" min="0.00" id="unitCost" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" placeholder="0.50">
            </div>
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">PVP Sugerido *</label>
              <input type="number" step="0.01" min="0.00" id="salePrice" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm" placeholder="1.00">
            </div>
          </div>
          <button type="button" onclick="addItem()" class="w-full py-2.5 bg-neutral-850 hover:bg-neutral-800 border border-neutral-750 text-neutral-200 font-semibold rounded-xl text-sm transition-all cursor-pointer">
            Añadir a la lista
          </button>
        </div>
      </div>
    </div>

    <!-- Items List Table (7/12) -->
    <div class="lg:col-span-7 space-y-6">
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex flex-col h-full justify-between">
        <div>
          <h2 class="text-lg font-bold text-white mb-4">Detalle de Artículos a Ingresar</h2>

          <div class="overflow-x-auto min-h-60">
            <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
              <thead>
                <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                  <th class="py-2.5 px-3">Producto</th>
                  <th class="py-2.5 px-3">Lote/Vence</th>
                  <th class="py-2.5 px-3 text-center">Cant.</th>
                  <th class="py-2.5 px-3 text-right">Costo U.</th>
                  <th class="py-2.5 px-3 text-right">PVP</th>
                  <th class="py-2.5 px-3 text-right">Total</th>
                  <th class="py-2.5 px-3 text-right">Acción</th>
                </tr>
              </thead>
              <tbody id="items-list-body" class="divide-y divide-neutral-800">
                <tr>
                  <td colspan="7" class="py-12 text-center text-neutral-500 text-xs">La lista de artículos está vacía.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="border-t border-neutral-800 pt-6 mt-6 flex items-center justify-between">
          <div class="text-left">
            <span class="text-xs text-neutral-500 block uppercase tracking-wider font-semibold">Total de la Factura:</span>
            <span id="invoice-total" class="text-2xl font-black text-emerald-400">$0.00</span>
          </div>
          <button type="button" onclick="submitPurchase()" id="btn-save-purchase" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl text-sm transition-all shadow-md shadow-blue-500/10 cursor-pointer">
            Procesar Factura y Stock
          </button>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
  let items = [];

  let selectedProductName = '';

  function addItem() {
    const productId = document.getElementById('productId').value;
    const productName = selectedProductName;
    const batchCode = document.getElementById('batchCode').value.trim();
    const expirationDate = document.getElementById('expirationDate').value;
    const qtyInput = document.getElementById('quantity');
    const quantity = parseInt(qtyInput.value, 10);
    const costInput = document.getElementById('unitCost');
    const unitCost = parseFloat(costInput.value);
    const priceInput = document.getElementById('salePrice');
    const salePrice = parseFloat(priceInput.value);

    if (!productId || batchCode === '' || isNaN(quantity) || quantity <= 0 || isNaN(unitCost) || unitCost < 0 || isNaN(salePrice) || salePrice < 0) {
      showToast('Por favor complete todos los campos requeridos con valores válidos.', 'warning');
      return;
    }

    items.push({
      productId: parseInt(productId, 10),
      productName,
      batchCode,
      expirationDate,
      quantity,
      unitCost,
      salePrice
    });

    // Reset item inputs but keep default/helpers if any
    document.getElementById('productId').value = '';
    document.getElementById('productSearchInput').value = '';
    document.getElementById('selectedProductBarcode').value = '';
    selectedProductName = '';
    document.getElementById('batchCode').value = '';
    document.getElementById('expirationDate').value = '';
    qtyInput.value = '';
    costInput.value = '';
    priceInput.value = '';

    renderItems();
  }

  function removeItem(index) {
    items.splice(index, 1);
    renderItems();
  }

  function renderItems() {
    const body = document.getElementById('items-list-body');
    const totalSpan = document.getElementById('invoice-total');

    if (items.length === 0) {
      body.innerHTML = `
        <tr>
          <td colspan="7" class="py-12 text-center text-neutral-500 text-xs">La lista de artículos está vacía.</td>
        </tr>
      `;
      totalSpan.innerText = '$0.00';
      return;
    }

    body.innerHTML = items.map((item, idx) => `
      <tr class="hover:bg-neutral-950/40">
        <td class="py-3 px-3">
          <span class="text-xs font-bold text-white block">${item.productName}</span>
        </td>
        <td class="py-3 px-3 font-mono text-xs">
          <span class="text-neutral-300 block">${item.batchCode}</span>
          <span class="text-[10px] text-neutral-500">${item.expirationDate || 'Sin caducidad'}</span>
        </td>
        <td class="py-3 px-3 text-center text-xs font-semibold text-neutral-300">${item.quantity}</td>
        <td class="py-3 px-3 text-right font-mono text-xs text-neutral-400">$${item.unitCost.toFixed(2)}</td>
        <td class="py-3 px-3 text-right font-mono text-xs text-blue-400">$${item.salePrice.toFixed(2)}</td>
        <td class="py-3 px-3 text-right font-mono text-xs font-bold text-white">$${(item.unitCost * item.quantity).toFixed(2)}</td>
        <td class="py-3 px-3 text-right">
          <button onclick="removeItem(${idx})" class="text-red-500 hover:text-red-400 text-xs font-semibold hover:underline cursor-pointer">
            Remover
          </button>
        </td>
      </tr>
    `).join('');

    const total = items.reduce((sum, item) => sum + (item.unitCost * item.quantity), 0);
    totalSpan.innerText = `$${total.toFixed(2)}`;
  }

  function toggleDueDate() {
    const method = document.getElementById('paymentMethod').value;
    const dueDateContainer = document.getElementById('due-date-container');
    const cashDetailsContainer = document.getElementById('cash-details-container');

    if (method === 'credit') {
      dueDateContainer.classList.remove('hidden');
      cashDetailsContainer.classList.add('hidden');
    } else {
      dueDateContainer.classList.add('hidden');
      cashDetailsContainer.classList.remove('hidden');
    }
  }

  function togglePaymentSource() {
    const paymentSource = document.querySelector('input[name="paymentSource"]:checked').value;
    const cajaSection = document.getElementById('purchase-caja-section');
    const bankSection = document.getElementById('purchase-bank-section');
    const cashierLabel = document.getElementById('source-cashier-label');
    const externalLabel = document.getElementById('source-external-label');
    const saveBtn = document.getElementById('btn-save-purchase');

    if (paymentSource === 'cashier') {
      cajaSection.classList.remove('hidden');
      bankSection.classList.add('hidden');
      cashierLabel.className = "flex items-center gap-2 px-3 py-2 bg-neutral-950 border-2 border-blue-500 rounded-xl cursor-pointer transition-all";
      externalLabel.className = "flex items-center gap-2 px-3 py-2 bg-neutral-950 border-2 border-neutral-800 rounded-xl cursor-pointer transition-all";

      // If cashier selected and no boxes available, disable save button
      const turnSelect = document.getElementById('purchase-turnId');
      if (turnSelect.classList.contains('hidden')) {
        saveBtn.disabled = true;
      } else {
        saveBtn.disabled = false;
      }
    } else {
      cajaSection.classList.add('hidden');
      bankSection.classList.remove('hidden');
      cashierLabel.className = "flex items-center gap-2 px-3 py-2 bg-neutral-950 border-2 border-neutral-800 rounded-xl cursor-pointer transition-all";
      externalLabel.className = "flex items-center gap-2 px-3 py-2 bg-neutral-950 border-2 border-blue-500 rounded-xl cursor-pointer transition-all";
      saveBtn.disabled = false;
    }
  }

  async function loadPurchaseTurns() {
    const turnSelect = document.getElementById('purchase-turnId');
    const turnLoading = document.getElementById('purchase-turn-loading');
    const turnNoOptions = document.getElementById('purchase-turn-no-options');
    const saveBtn = document.getElementById('btn-save-purchase');

    turnSelect.classList.add('hidden');
    turnNoOptions.classList.add('hidden');
    turnLoading.classList.remove('hidden');
    turnSelect.innerHTML = '';

    try {
      const resp = await fetch('/purchases/api/available-turns');
      const result = await resp.json();

      if (result.success && result.turns.length > 0) {
        result.turns.forEach(turn => {
          const opt = document.createElement('option');
          opt.value = turn.id;
          const ownLabel = turn.isOwn ? ' ★ Mi caja' : '';
          opt.textContent = `${turn.boxName} - ${turn.userName} ($${turn.balance.toFixed(2)})${ownLabel}`;
          turnSelect.appendChild(opt);
        });
        turnLoading.classList.add('hidden');
        turnSelect.classList.remove('hidden');
        saveBtn.disabled = false;
      } else {
        turnLoading.classList.add('hidden');
        turnNoOptions.classList.remove('hidden');
        // If cashier is selected method, disable save
        const paymentSource = document.querySelector('input[name="paymentSource"]:checked').value;
        if (paymentSource === 'cashier') {
          saveBtn.disabled = true;
        }
      }
    } catch (err) {
      console.error(err);
      turnLoading.classList.add('hidden');
      turnNoOptions.classList.remove('hidden');
    }
  }

  // Load turns on page ready
  window.addEventListener('DOMContentLoaded', () => {
    loadPurchaseTurns();
  });

  async function submitPurchase() {
    const invoiceNumber = document.getElementById('invoiceNumber').value.trim();
    const supplierId = document.getElementById('supplierId').value;
    const paymentMethod = document.getElementById('paymentMethod').value;
    const dueDate = document.getElementById('dueDate').value;

    const paymentSource = paymentMethod === 'cash' ? document.querySelector('input[name="paymentSource"]:checked').value : null;
    const turnId = paymentMethod === 'cash' && paymentSource === 'cashier' ? document.getElementById('purchase-turnId').value : null;
    const transactionRef = paymentMethod === 'cash' && paymentSource === 'external' ? document.getElementById('purchase-transactionRef').value.trim() : null;

    if (invoiceNumber === '' || !supplierId) {
      showToast('Por favor ingrese el número de factura y seleccione el proveedor.', 'warning');
      return;
    }

    if (paymentMethod === 'credit' && !dueDate) {
      showToast('Debe ingresar la fecha de vencimiento para la compra al crédito.', 'warning');
      return;
    }

    if (paymentMethod === 'cash') {
      if (paymentSource === 'cashier' && !turnId) {
        showToast('Debe seleccionar una caja activa para efectuar el pago en efectivo.', 'warning');
        return;
      }
      if (paymentSource === 'external' && transactionRef === '') {
        showToast('Debe ingresar el número de autorización o Voucher del pago bancario.', 'warning');
        return;
      }
    }

    if (items.length === 0) {
      showToast('Debe agregar al menos un artículo a la factura.', 'warning');
      return;
    }

    const saveBtn = document.getElementById('btn-save-purchase');
    saveBtn.disabled = true;
    saveBtn.innerText = 'Guardando...';

    try {
      const resp = await fetch('/purchases', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          invoiceNumber,
          supplierId,
          items,
          paymentMethod,
          dueDate: paymentMethod === 'credit' ? dueDate : null,
          paymentSource,
          turnId,
          transactionRef
        })
      });

      const resData = await resp.json();
      if (resData.success) {
        showToast('Compra registrada e inventario actualizado correctamente.', 'success');
        setTimeout(() => {
          window.location.href = '/purchases';
        }, 1500);
      } else {
        showToast('Error: ' + resData.message, 'error');
        saveBtn.disabled = false;
        saveBtn.innerText = 'Procesar Factura y Stock';
      }
    } catch (err) {
      console.error(err);
      showToast('Ocurrió un error al guardar la factura de compra.', 'error');
      saveBtn.disabled = false;
      saveBtn.innerText = 'Procesar Factura y Stock';
    }
  }

  // Autocomplete, Search & Modal logic wrapped in DOMContentLoaded
  window.addEventListener('DOMContentLoaded', () => {
    let searchTimeout = null;
    const searchInput = document.getElementById('productSearchInput');
    const searchResults = document.getElementById('productSearchResults');
    const hiddenProductId = document.getElementById('productId');
    const hiddenBarcode = document.getElementById('selectedProductBarcode');
    const quickProductForm = document.getElementById('quick-product-form');

    searchInput.addEventListener('focus', () => {
      if (searchInput.value.trim() === '') {
        performSearch('');
      } else {
        searchResults.classList.remove('hidden');
      }
    });

    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
      }
    });

    searchInput.addEventListener('input', () => {
      clearTimeout(searchTimeout);
      const query = searchInput.value.trim();
      searchTimeout = setTimeout(() => {
        performSearch(query);
      }, 200);
    });

    async function performSearch(query) {
      try {
        const resp = await fetch(`/products/api/search?q=${encodeURIComponent(query)}`);
        const data = await resp.json();
        if (data.success) {
          renderSearchResults(data.products);
        }
      } catch (err) {
        console.error('Error searching products:', err);
      }
    }

    function renderSearchResults(products) {
      if (products.length === 0) {
        searchResults.innerHTML = '<div class="p-3 text-neutral-500 text-xs text-center">No se encontraron productos.</div>';
        searchResults.classList.remove('hidden');
        return;
      }

      searchResults.innerHTML = products.map(p => `
        <div onclick="window.selectProduct(${p.id}, '${escapeHtml(p.name)}', '${p.barCode || ''}')" class="p-3 hover:bg-neutral-850 cursor-pointer transition-colors text-xs flex justify-between items-center border-b border-neutral-800 last:border-0">
          <div>
            <span class="font-bold text-white block">${escapeHtml(p.name)}</span>
            <span class="text-neutral-500 text-[10px] font-mono">${p.barCode || 'Sin código de barra'}</span>
          </div>
          <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-neutral-850 text-neutral-400 capitalize">${p.type === 'service' ? 'Servicio' : 'Físico'}</span>
        </div>
      `).join('');
      searchResults.classList.remove('hidden');
    }

    window.selectProduct = function(id, name, barcode) {
      hiddenProductId.value = id;
      selectedProductName = name;
      searchInput.value = name;
      hiddenBarcode.value = barcode;
      searchResults.classList.add('hidden');
      document.getElementById('batchCode').focus();
    };

    function escapeHtml(text) {
      return text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    const maxPx = <%= typeof maxPx !== 'undefined' ? maxPx : 1200 %>;
    const quality = <%= typeof quality !== 'undefined' ? quality : 0.8 %>;
    let compressedCreateFile = null;

    // Setup worker
    const compressionWorker = new Worker('/js/compression-worker.js');
    compressionWorker.onmessage = (event) => {
      const { success, blob, filename, error } = event.data;
      if (success) {
        const file = new File([blob], filename, {
          type: 'image/jpeg'
        });
        compressedCreateFile = file;
        document.getElementById('compression-status').classList.add('hidden');
        const preview = document.getElementById('image-preview');
        preview.src = URL.createObjectURL(file);
        document.getElementById('preview-container').classList.remove('hidden');
        const submitBtn = document.querySelector('#quick-product-form button[type="submit"]');
        if (submitBtn) submitBtn.disabled = false;
      } else {
        showToast('Error en la compresión: ' + error, 'error');
        document.getElementById('compression-status').classList.add('hidden');
      }
    };

    // File input listener
    const createImgInput = document.getElementById('product-image-input');
    if (createImgInput) {
      createImgInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;

        document.getElementById('compression-status').classList.remove('hidden');
        const submitBtn = document.querySelector('#quick-product-form button[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;
        compressedCreateFile = null;

        // Send to worker
        compressionWorker.postMessage({
          file,
          maxPx,
          quality
        });
      });
    }

    const setupPasteListener = (pasteInputId, urlHiddenId, base64HiddenId, previewContainerId, previewImgId) => {
      const input = document.getElementById(pasteInputId);
      if (!input) return;

      // Listen to typing (link/url)
      input.addEventListener('input', (e) => {
        const val = e.target.value.trim();
        if (val.startsWith('http://') || val.startsWith('https://')) {
          document.getElementById(urlHiddenId).value = val;
          document.getElementById(base64HiddenId).value = '';

          const preview = document.getElementById(previewImgId);
          preview.src = val;
          document.getElementById(previewContainerId).classList.remove('hidden');
        } else {
          document.getElementById(urlHiddenId).value = '';
          document.getElementById(previewContainerId).classList.add('hidden');
        }
      });

      // Listen to paste (images from clipboard)
      input.addEventListener('paste', (e) => {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        for (const item of items) {
          if (item.type.indexOf('image') === 0) {
            const blob = item.getAsFile();
            const img = new Image();
            img.src = URL.createObjectURL(blob);
            img.onload = function() {
              // Calculate square crop (1:1 / 4:4 aspect ratio)
              const minSide = Math.min(img.width, img.height);
              const sx = (img.width - minSide) / 2;
              const sy = (img.height - minSide) / 2;
              
              // Define optimized size
              const size = Math.min(minSide, maxPx);
              
              const canvas = document.createElement('canvas');
              canvas.width = size;
              canvas.height = size;
              const ctx = canvas.getContext('2d');
              ctx.drawImage(img, sx, sy, minSide, minSide, 0, 0, size, size);
              
              // Convert to compressed jpeg base64
              const base64Data = canvas.toDataURL('image/jpeg', 0.85);
              document.getElementById(base64HiddenId).value = base64Data;
              document.getElementById(urlHiddenId).value = '';

              const preview = document.getElementById(previewImgId);
              preview.src = base64Data;
              document.getElementById(previewContainerId).classList.remove('hidden');
              input.value = '[Imagen del portapapeles optimizada 4:4]';
              
              URL.revokeObjectURL(img.src);
            };
            e.preventDefault();
            break;
          }
        }
      });
    };

    setupPasteListener('create-image-paste-input', 'create-image-pasted-url', 'create-image-base64', 'create-pasted-preview-container', 'create-pasted-preview');

    quickProductForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const fileInput = document.getElementById('product-image-input');
      if (fileInput && fileInput.files.length > 0 && !compressedCreateFile) {
        showToast('Por favor espera a que finalice la optimización de la imagen.', 'warning');
        return;
      }

      const submitBtn = e.target.querySelector('button[type="submit"]');
      submitBtn.disabled = true;
      submitBtn.innerText = 'Guardando...';

      try {
        const formData = new FormData(quickProductForm);
        if (compressedCreateFile) {
          formData.set('image', compressedCreateFile, compressedCreateFile.name);
        }

        const resp = await fetch('/products/api/quick-create', {
          method: 'POST',
          headers: {
            'Accept': 'application/json'
          },
          body: formData
        });

        const result = await resp.json();
        if (resp.ok && result.success) {
          showToast(result.message, 'success');
          closeQuickProductModal();
          // Select newly created product
          window.selectProduct(result.product.id, result.product.name, result.product.barCode);
        } else {
          showToast(result.message || 'Error al crear el producto.', 'error');
          submitBtn.disabled = false;
          submitBtn.innerText = 'Guardar Producto';
        }
      } catch (err) {
        console.error(err);
        showToast('Error de red al intentar crear el producto.', 'error');
        submitBtn.disabled = false;
        submitBtn.innerText = 'Guardar Producto';
      }
    });
  });

  // Modal helper functions (exposed globally for inline onclick attributes)
  window.openQuickProductModal = function() {
    document.getElementById('quick-product-modal').classList.remove('hidden');
    document.getElementById('quick-prod-name').focus();
  };

  window.closeQuickProductModal = function() {
    document.getElementById('quick-product-modal').classList.add('hidden');
    document.getElementById('quick-product-form').reset();
    
    // Clear images & previews
    compressedCreateFile = null;
    const previewContainer = document.getElementById('preview-container');
    if (previewContainer) previewContainer.classList.add('hidden');
    const imagePreview = document.getElementById('image-preview');
    if (imagePreview) imagePreview.src = '#';
    
    const pasteInput = document.getElementById('create-image-paste-input');
    if (pasteInput) pasteInput.value = '';
    const pastedUrl = document.getElementById('create-image-pasted-url');
    if (pastedUrl) pastedUrl.value = '';
    const base64Input = document.getElementById('create-image-base64');
    if (base64Input) base64Input.value = '';
    
    const pastePreviewContainer = document.getElementById('create-pasted-preview-container');
    if (pastePreviewContainer) pastePreviewContainer.classList.add('hidden');
    const pastePreview = document.getElementById('create-pasted-preview');
    if (pastePreview) pastePreview.src = '#';
    
    const submitBtn = document.querySelector('#quick-product-form button[type="submit"]');
    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.innerText = 'Guardar Producto';
    }
  };
</script>

<!-- Quick Product Modal -->
<div id="quick-product-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-md p-6 rounded-2xl shadow-2xl relative max-h-[90vh] flex flex-col">
    <div class="flex justify-between items-center pb-3 border-b border-neutral-800 mb-4">
      <h2 class="text-lg font-bold text-white">Crear Producto Rápido</h2>
      <button type="button" onclick="closeQuickProductModal()" class="text-neutral-500 hover:text-white cursor-pointer transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <form id="quick-product-form" enctype="multipart/form-data" class="space-y-4 overflow-y-auto flex-grow pr-1">
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Nombre del Artículo *</label>
        <input type="text" id="quick-prod-name" name="name" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="Coca Cola 1.5L">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Código de Barras</label>
        <input type="text" id="quick-prod-barcode" name="barCode" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="7501055300075">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Categoría</label>
        <select id="quick-prod-categoryId" name="categoryId" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
          <option value="">-- Sin categoría --</option>
          <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>"><%= cat.name %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">¿Producto Frecuente?</label>
        <select id="quick-prod-isFrequent" name="isFrequent" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
          <option value="false">No (Estándar)</option>
          <option value="true">Sí (Mostrar en acceso rápido POS)</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Tipo de Artículo *</label>
        <select id="quick-prod-type" name="type" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
          <option value="physical">Físico (Controla Stock)</option>
          <option value="service">Servicio (Sin Stock / Intangible)</option>
        </select>
      </div>

      <!-- Image with worker compression status -->
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fotografía del Producto</label>
        <input type="file" id="product-image-input" accept="image/*" class="w-full text-xs text-neutral-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-neutral-800 file:text-white hover:file:bg-neutral-750 file:cursor-pointer mb-2">

        <label class="block text-[10px] font-semibold text-neutral-500 uppercase tracking-wider mb-1">O Pegar Link de Imagen / Captura de Pantalla</label>
        <input type="text" id="create-image-paste-input" placeholder="Pegar link de imagen aquí o Ctrl+V para capturas..." class="w-full px-3 py-2 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-xs transition-all mb-2">
        <input type="hidden" name="imageUrl" id="create-image-pasted-url">
        <input type="hidden" name="imageBase64" id="create-image-base64">

        <!-- Compression feedback -->
        <div id="compression-status" class="mt-2 text-xs hidden">
          <span class="text-blue-400 animate-pulse">Comprimiendo imagen con Web Worker...</span>
        </div>

        <!-- Preview thumbnail -->
        <div class="mt-3 hidden" id="preview-container">
          <img id="image-preview" src="#" class="h-24 w-24 object-cover border border-neutral-800 rounded-xl">
          <span class="text-[10px] text-emerald-400 block mt-1">✓ Imagen optimizada</span>
        </div>

        <!-- Paste preview thumbnail -->
        <div class="mt-3 hidden" id="create-pasted-preview-container">
          <img id="create-pasted-preview" src="#" class="h-24 w-24 object-cover border border-neutral-800 rounded-xl">
          <span class="text-[10px] text-blue-400 block mt-1">✓ Imagen de portapapeles/enlace lista</span>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-3 border-t border-neutral-800">
        <button type="button" onclick="closeQuickProductModal()" class="px-4 py-2.5 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer shadow-md shadow-blue-500/10">
          Guardar Producto
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('../../partials/foot') %>