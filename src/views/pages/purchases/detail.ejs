<%- include('../../partials/head', { title: title }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/purchases" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Detalle de Compra</span>
        <span class="text-xs block text-neutral-400 font-medium">Factura No. <strong class="text-indigo-400"><%= purchase.invoiceNumber %></strong></span>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <button onclick="window.print()" class="bg-neutral-800 border border-neutral-700 hover:bg-neutral-750 px-4 py-2 rounded-xl text-xs font-semibold text-neutral-300 transition-all flex items-center gap-2">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        <span>Imprimir</span>
      </button>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left 2 columns: General and items -->
    <div class="lg:col-span-2 space-y-6">
      <!-- General Info -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
        <h2 class="text-lg font-bold text-white mb-4">Información General</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-neutral-300">
          <div>
            <p class="text-neutral-500 font-medium text-xs uppercase tracking-wider">Factura No.</p>
            <p class="text-base font-bold text-white mt-0.5"><%= purchase.invoiceNumber %></p>
          </div>
          <div>
            <p class="text-neutral-500 font-medium text-xs uppercase tracking-wider">Proveedor</p>
            <p class="text-base font-semibold mt-0.5"><%= purchase.supplier ? purchase.supplier.name : 'N/A' %></p>
          </div>
          <div>
            <p class="text-neutral-500 font-medium text-xs uppercase tracking-wider">Sucursal Recibidora</p>
            <p class="text-base mt-0.5"><%= purchase.branch ? purchase.branch.name : 'N/A' %></p>
          </div>
          <div>
            <p class="text-neutral-500 font-medium text-xs uppercase tracking-wider">Fecha de Registro</p>
            <p class="text-base font-mono mt-0.5"><%= new Date(purchase.createdAt).toLocaleString('es-SV') %></p>
          </div>
        </div>
      </div>

      <!-- Items Details Table -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm overflow-hidden">
        <h2 class="text-lg font-bold text-white mb-4">Productos Ingresados</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
            <thead>
              <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                <th class="py-3 px-4">Producto</th>
                <th class="py-3 px-4">Código Lote</th>
                <th class="py-3 px-4">Fecha Venc.</th>
                <th class="py-3 px-4 text-center">Cantidad</th>
                <th class="py-3 px-4 text-right">Costo Unit.</th>
                <th class="py-3 px-4 text-right">Subtotal</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-800">
              <% purchase.details.forEach(d => { %>
                <tr class="hover:bg-neutral-950/40 transition-colors">
                  <td class="py-4 px-4 font-bold text-white"><%= d.product ? d.product.name : 'N/A' %></td>
                  <td class="py-4 px-4 font-mono text-xs text-neutral-350"><%= d.batchCode %></td>
                  <td class="py-4 px-4 font-mono text-xs text-neutral-400">
                    <%= d.expirationDate ? new Date(d.expirationDate + 'T00:00:00').toLocaleDateString('es-SV') : 'Sin Vencimiento' %>
                  </td>
                  <td class="py-4 px-4 text-center font-bold text-white"><%= d.quantity %></td>
                  <td class="py-4 px-4 text-right font-mono">$<%= parseFloat(d.unitCost).toFixed(2) %></td>
                  <td class="py-4 px-4 text-right font-bold text-white font-mono">
                    $<%= (parseInt(d.quantity) * parseFloat(d.unitCost)).toFixed(2) %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Right column: Financial Summary and Payments -->
    <div class="space-y-6">
      <!-- Totals & Payment Conditions -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm space-y-4">
        <h2 class="text-lg font-bold text-white">Resumen de Cuenta</h2>
        
        <div class="space-y-3 border-b border-neutral-800 pb-4 text-sm text-neutral-300">
          <div class="flex justify-between">
            <span class="text-neutral-500">Monto Total Factura:</span>
            <span class="font-bold text-white font-mono">$<%= parseFloat(purchase.totalAmount).toFixed(2) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-neutral-500">Monto Pagado:</span>
            <span class="font-bold text-emerald-400 font-mono">$<%= parseFloat(purchase.amountPaid || 0).toFixed(2) %></span>
          </div>
          <div class="flex justify-between text-base font-bold">
            <span class="text-neutral-400">Saldo Pendiente:</span>
            <span class="text-red-400 font-mono">$<%= (parseFloat(purchase.totalAmount) - parseFloat(purchase.amountPaid || 0)).toFixed(2) %></span>
          </div>
        </div>

        <div class="space-y-2 text-xs">
          <div class="flex justify-between">
            <span class="text-neutral-500 uppercase tracking-wider font-semibold">Condición:</span>
            <span class="px-2 py-0.5 rounded font-bold uppercase <%= purchase.paymentMethod === 'credit' ? 'bg-amber-950 text-amber-400 border border-amber-900/60' : 'bg-neutral-800 text-neutral-400 border border-neutral-700/60' %>">
              <%= purchase.paymentMethod === 'credit' ? 'Crédito (CxP)' : 'Contado' %>
            </span>
          </div>
          <div class="flex justify-between mt-2">
            <span class="text-neutral-500 uppercase tracking-wider font-semibold">Estado de Pago:</span>
            <span class="px-2 py-0.5 rounded font-bold uppercase <%= purchase.paymentStatus === 'paid' ? 'bg-emerald-950 text-emerald-400 border border-emerald-900/60' : 'bg-red-950 text-red-400 border border-red-900/60 animate-pulse' %>">
              <%= purchase.paymentStatus === 'paid' ? 'Completamente Pagado' : 'Pago Pendiente' %>
            </span>
          </div>
          <% if (purchase.dueDate) { %>
            <div class="flex justify-between mt-2">
              <span class="text-neutral-500 uppercase tracking-wider font-semibold">Fecha Límite:</span>
              <span class="font-mono font-bold text-neutral-300"><%= new Date(purchase.dueDate + 'T00:00:00').toLocaleDateString('es-SV') %></span>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Abonos / Pagos Realizados -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
        <h2 class="text-lg font-bold text-white mb-4">Abonos / Pagos</h2>
        
        <% if (!purchase.payments || purchase.payments.length === 0) { %>
          <p class="text-xs text-neutral-500 py-4 text-center">No se han registrado abonos para esta compra.</p>
        <% } else { %>
          <div class="space-y-3">
            <% purchase.payments.forEach(pay => { %>
              <div class="bg-neutral-950 border border-neutral-850 p-3 rounded-xl flex items-center justify-between text-xs text-neutral-300">
                <div class="flex flex-col">
                  <span class="font-bold text-emerald-400 font-mono">$<%= parseFloat(pay.amountPaid).toFixed(2) %></span>
                  <span class="text-[10px] text-neutral-500 mt-0.5"><%= pay.notes ? pay.notes : 'Abono de cuenta' %></span>
                </div>
                <span class="font-mono text-neutral-455 text-[10px]"><%= new Date(pay.paymentDate).toLocaleString('es-SV') %></span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</div>

<%- include('../../partials/foot') %>
