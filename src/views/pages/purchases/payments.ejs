<%- include('../../partials/head', { title: 'Cuentas por Pagar (CxP)' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/purchases" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Cuentas por Pagar (CxP)</span>
        <span class="text-xs block text-neutral-400 font-medium">Gestión de créditos de proveedores y abonos</span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <!-- Summary Header Cards -->
    <% 
      let totalDebt = 0; 
      let overdueDebt = 0; 
      let paidCount = 0; 
      let pendingCount = 0; 
      const today = new Date().setHours(0,0,0,0);

      purchases.forEach(p => {
        const pending = parseFloat(p.totalAmount) - parseFloat(p.amountPaid);
        if (p.paymentStatus === 'pending') {
          totalDebt += pending;
          pendingCount++;
          if (p.dueDate && new Date(p.dueDate + 'T00:00:00') < today) {
            overdueDebt += pending;
          }
        } else {
          paidCount++;
        }
      });
    %>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="bg-neutral-900 border border-neutral-800 p-5 rounded-2xl flex flex-col justify-between shadow-sm">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Deuda Total Pendiente</span>
        <span class="text-2xl font-black text-white mt-2">$<%= totalDebt.toFixed(2) %> USD</span>
      </div>
      <div class="bg-neutral-900 border border-red-950/60 p-5 rounded-2xl flex flex-col justify-between shadow-sm">
        <span class="text-xs font-semibold text-red-400 uppercase tracking-wider flex items-center gap-1">
          <span class="h-2 w-2 rounded-full bg-red-500 animate-ping"></span>
          <span>Deuda Vencida (Mora)</span>
        </span>
        <span class="text-2xl font-black text-red-400 mt-2">$<%= overdueDebt.toFixed(2) %> USD</span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-5 rounded-2xl flex flex-col justify-between shadow-sm">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Facturas Pendientes</span>
        <span class="text-2xl font-black text-white mt-2"><%= pendingCount %></span>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-5 rounded-2xl flex flex-col justify-between shadow-sm">
        <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Facturas Liquidadas</span>
        <span class="text-2xl font-black text-emerald-400 mt-2"><%= paidCount %></span>
      </div>
    </div>

    <!-- Purchases Credit Table -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-white mb-4">Créditos de Proveedores</h2>

      <% if (purchases.length === 0) { %>
        <p class="text-sm text-neutral-500 py-8 text-center">No se han registrado compras al crédito en esta sucursal.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
            <thead>
              <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                <th class="py-3 px-4">Fecha Compra</th>
                <th class="py-3 px-4">Factura No.</th>
                <th class="py-3 px-4">Proveedor</th>
                <th class="py-3 px-4 text-right">Total</th>
                <th class="py-3 px-4 text-right">Abonado</th>
                <th class="py-3 px-4 text-right">Saldo Pendiente</th>
                <th class="py-3 px-4">Vencimiento</th>
                <th class="py-3 px-4 text-center">Estado</th>
                <th class="py-3 px-4 text-right">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-800">
              <% purchases.forEach(p => { %>
                <% 
                  const pending = parseFloat(p.totalAmount) - parseFloat(p.amountPaid);
                  const isOverdue = p.paymentStatus === 'pending' && p.dueDate && new Date(p.dueDate + 'T00:00:00') < today;
                %>
                <tr class="hover:bg-neutral-950/40 transition-colors">
                  <td class="py-4 px-4 font-mono text-xs text-neutral-400"><%= new Date(p.createdAt).toLocaleDateString('es-SV') %></td>
                  <td class="py-4 px-4 font-bold text-white"><%= p.invoiceNumber %></td>
                  <td class="py-4 px-4 text-neutral-300 font-semibold"><%= p.supplier ? p.supplier.name : 'N/A' %></td>
                  <td class="py-4 px-4 text-right font-mono">$<%= parseFloat(p.totalAmount).toFixed(2) %></td>
                  <td class="py-4 px-4 text-right font-mono text-emerald-400">+$<%= parseFloat(p.amountPaid).toFixed(2) %></td>
                  <td class="py-4 px-4 text-right font-mono <%= pending > 0 ? 'text-amber-400 font-bold' : 'text-neutral-400' %>">
                    $<%= pending.toFixed(2) %>
                  </td>
                  <td class="py-4 px-4 font-mono text-xs <%= isOverdue ? 'text-red-500 font-bold' : 'text-neutral-400' %>">
                    <%= p.dueDate ? new Date(p.dueDate + 'T00:00:00').toLocaleDateString('es-SV') : '-' %>
                    <% if (isOverdue) { %> <span class="block text-[8px] uppercase tracking-wider text-red-500 font-black">Vencido</span> <% } %>
                  </td>
                  <td class="py-4 px-4 text-center">
                    <% if (p.paymentStatus === 'paid') { %>
                      <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase bg-emerald-950 text-emerald-400 border border-emerald-900/60">
                        Liquidado
                      </span>
                    <% } else { %>
                      <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase bg-red-950 text-red-400 border border-red-900/60">
                        Pendiente
                      </span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 text-right">
                    <% if (p.paymentStatus !== 'paid') { %>
                      <button 
                        onclick="openPaymentModal(<%= p.id %>, '<%= p.invoiceNumber %>', '<%= p.supplier ? p.supplier.name.replace(/'/g, "\\'") : 'N/A' %>', <%= pending %>)"
                        class="px-3 py-1 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-lg text-xs transition-all shadow-md shadow-emerald-500/10 cursor-pointer">
                        Abonar / Liquidar
                      </button>
                    <% } else { %>
                      <span class="text-xs text-neutral-500">-</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>
</div>

<!-- Pay Supplier Modal -->
<div id="supplier-pay-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-sm p-6 rounded-2xl shadow-2xl relative">
    <h2 class="text-xl font-bold text-white mb-4">Abonar a Factura</h2>
    
    <p class="text-xs text-neutral-400 mb-4">Factura: <strong id="pay-invoice-no" class="text-white"></strong> de <strong id="pay-supplier-name" class="text-neutral-300"></strong></p>
    
    <form id="pay-supplier-form" class="space-y-4">
      <input type="hidden" id="pay-purchase-id">
      
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Monto a Abonar ($ USD) *</label>
        <div class="relative">
          <input type="number" step="0.01" min="0.01" id="pay-amountPaid" required class="w-full pl-3 pr-20 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm font-mono" placeholder="0.00">
          <button type="button" onclick="setFullPayment()" class="absolute right-2 top-2 px-2.5 py-1 bg-neutral-850 hover:bg-neutral-800 text-[10px] font-bold text-neutral-300 border border-neutral-700 rounded-lg">
            Todo
          </button>
        </div>
        <span class="text-[10px] block text-neutral-500 mt-1">Saldo pendiente máximo: $<span id="pay-max-pending" class="font-mono">0.00</span></span>
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Notas / Referencia de Pago</label>
        <input type="text" id="pay-notes" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" placeholder="Ej. Transf. Banco Agrícola #44122">
      </div>
      
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closePaymentModal()" class="px-4 py-2.5 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" id="btn-submit-pay" class="px-5 py-2.5 text-sm font-bold text-white bg-emerald-600 hover:bg-emerald-500 rounded-xl transition-all cursor-pointer shadow-md shadow-emerald-500/10">
          Registrar Pago
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  let currentMaxPending = 0;

  function openPaymentModal(purchaseId, invoiceNo, supplierName, maxPending) {
    currentMaxPending = parseFloat(maxPending);
    
    document.getElementById('pay-purchase-id').value = purchaseId;
    document.getElementById('pay-invoice-no').innerText = invoiceNo;
    document.getElementById('pay-supplier-name').innerText = supplierName;
    document.getElementById('pay-max-pending').innerText = currentMaxPending.toFixed(2);
    
    const amountInput = document.getElementById('pay-amountPaid');
    amountInput.value = '';
    amountInput.max = currentMaxPending;
    
    document.getElementById('pay-notes').value = '';
    document.getElementById('supplier-pay-modal').classList.remove('hidden');
  }

  function setFullPayment() {
    document.getElementById('pay-amountPaid').value = currentMaxPending.toFixed(2);
  }

  function closePaymentModal() {
    document.getElementById('supplier-pay-modal').classList.add('hidden');
  }

  document.getElementById('pay-supplier-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    const purchaseId = parseInt(document.getElementById('pay-purchase-id').value, 10);
    const amountPaid = parseFloat(document.getElementById('pay-amountPaid').value);
    const notes = document.getElementById('pay-notes').value.trim();

    if (isNaN(amountPaid) || amountPaid <= 0) {
      showToast('Por favor ingrese un monto de pago válido.', 'warning');
      return;
    }

    if (amountPaid > currentMaxPending + 0.01) {
      showToast('El monto no puede superar al saldo pendiente.', 'error');
      return;
    }

    const btn = document.getElementById('btn-submit-pay');
    btn.disabled = true;
    btn.innerText = 'Registrando...';

    try {
      const resp = await fetch('/purchases/payments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ purchaseId, amountPaid, notes })
      });

      const resData = await resp.json();
      if (resp.ok && resData.success) {
        showToast(resData.message, 'success');
        closePaymentModal();
        setTimeout(() => {
          window.location.reload();
        }, 800);
      } else {
        showToast(resData.message || 'Error al procesar el pago.', 'error');
        btn.disabled = false;
        btn.innerText = 'Registrar Pago';
      }
    } catch (err) {
      console.error(err);
      showToast('Error de red al procesar el abono.', 'error');
      btn.disabled = false;
      btn.innerText = 'Registrar Pago';
    }
  });
</script>

<%- include('../../partials/foot') %>
