<%- include('../partials/head', { title: title || 'Error' }) %>

<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="max-w-md w-full bg-neutral-900 border border-neutral-800 p-8 rounded-2xl shadow-xl text-center space-y-6">
    <div class="flex justify-center">
      <div class="h-16 w-16 bg-red-950/60 border border-red-800 rounded-2xl flex items-center justify-center">
        <svg class="h-10 w-10 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
    </div>
    
    <div>
      <h2 class="text-2xl font-bold text-white"><%= title || 'Ha ocurrido un problema' %></h2>
      <p class="text-neutral-400 text-sm mt-3"><%= message || 'Lo sentimos, no se pudo procesar la solicitud.' %></p>
    </div>

    <div>
      <a href="/" class="inline-block py-2.5 px-6 border border-transparent text-sm font-semibold rounded-xl text-white bg-blue-600 hover:bg-blue-500 transition-all cursor-pointer shadow-md shadow-blue-500/10">
        Regresar al Inicio
      </a>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
