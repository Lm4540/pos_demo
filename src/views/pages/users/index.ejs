<%- include('../../partials/head', { title: 'Gestión de Usuarios' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Usuarios y Seguridad</span>
        <span class="text-xs block text-neutral-400 font-medium">Control de Accesos, Permisos por Rol y Excepciones</span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <!-- Tabs Navigation -->
    <div class="flex gap-2 border-b border-neutral-800 pb-4">
      <button id="tab-btn-users" onclick="switchTab('users')" class="px-5 py-2.5 text-sm font-semibold rounded-xl bg-blue-600 text-white cursor-pointer shadow-md shadow-blue-500/10 transition-all">
        Usuarios en Sistema
      </button>
      <button id="tab-btn-roles" onclick="switchTab('roles')" class="px-5 py-2.5 text-sm font-semibold rounded-xl text-neutral-400 hover:text-white hover:bg-neutral-900 cursor-pointer transition-all">
        Matriz de Permisos por Rol
      </button>
    </div>

    <!-- TAB 1: USERS & CREATION -->
    <div id="tab-users-content" class="space-y-6">
      <!-- List Area -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-lg font-bold text-white">Usuarios Registrados</h2>
          <button onclick="openCreateModal()" class="bg-blue-600 hover:bg-blue-500 px-4 py-2.5 rounded-xl text-xs font-bold text-white transition-all shadow-md shadow-blue-500/10 flex items-center gap-1.5 cursor-pointer">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            <span>Nuevo Usuario</span>
          </button>
        </div>
        
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
            <thead>
              <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                <th class="py-3 px-4">Usuario</th>
                <th class="py-3 px-4">Rol</th>
                <th class="py-3 px-4">Sucursal</th>
                <th class="py-3 px-4">Estado</th>
                <th class="py-3 px-4 text-right">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-800">
              <% users.forEach(u => { %>
                <tr class="hover:bg-neutral-950/40 transition-colors">
                  <td class="py-4 px-4">
                    <div class="font-bold text-white"><%= u.fullName %></div>
                    <div class="text-xs text-neutral-500 font-mono">@<%= u.username %></div>
                  </td>
                  <td class="py-4 px-4">
                    <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-neutral-800 text-neutral-300 capitalize">
                      <%= u.roleId %>
                    </span>
                  </td>
                  <td class="py-4 px-4 text-neutral-400">
                    <%= u.branch ? u.branch.name : 'Ninguna (Global)' %>
                  </td>
                  <td class="py-4 px-4">
                    <% if (u.status === 'active') { %>
                      <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-emerald-950/40 text-emerald-400 border border-emerald-800">Activo</span>
                    <% } else if (u.status === 'blocked') { %>
                      <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-red-950/40 text-red-400 border border-red-800/60">Bloqueado</span>
                    <% } else { %>
                      <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-neutral-800 text-neutral-500">Inactivo</span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 text-right space-x-2">
                    <button 
                      onclick="openEditModal(<%= JSON.stringify(u) %>)"
                      class="text-blue-500 hover:text-blue-400 text-xs font-semibold hover:underline cursor-pointer">
                      Editar / Permisos
                    </button>
                    <button 
                      onclick="deleteUser(<%= u.id %>)"
                      class="text-red-500 hover:text-red-400 text-xs font-semibold hover:underline cursor-pointer">
                      Eliminar
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Create Modal Overlay -->
    <div id="create-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
      <div class="bg-neutral-900 border border-neutral-800 w-full max-w-lg p-6 rounded-2xl shadow-2xl relative max-h-[90vh] flex flex-col">
        <div class="flex justify-between items-center pb-3 border-b border-neutral-800 mb-4">
          <h2 class="text-xl font-bold text-white">Registrar Nuevo Usuario</h2>
          <button onclick="closeCreateModal()" class="text-neutral-500 hover:text-white cursor-pointer transition-colors">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        
        <form action="/users" method="POST" class="space-y-4 overflow-y-auto flex-grow pr-1" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Registrando...';">
          <% if (error) { %>
            <div class="bg-red-950/40 border border-red-800 text-red-200 px-4 py-2 rounded-lg text-xs mb-4">
              <%= error %>
            </div>
          <% } %>

          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Nombre Completo *</label>
            <input type="text" name="fullName" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="Juan Pérez">
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Usuario *</label>
            <input type="text" name="username" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="jperez">
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Contraseña *</label>
            <input type="password" name="password" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="••••••••">
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Rol *</label>
              <select name="roleId" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                <option value="cashier">Cajero</option>
                <option value="supervisor">Supervisor</option>
                <option value="admin">Administrador</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Estado *</label>
              <select name="status" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                <option value="active">Activo</option>
                <option value="blocked">Bloqueado</option>
                <option value="inactive">Inactivo</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Sucursal</label>
            <select name="branchId" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
              <option value="">Ninguna (Acceso global de Administrador)</option>
              <% branches.forEach(b => { %>
                <option value="<%= b.id %>"><%= b.name %></option>
              <% }) %>
            </select>
          </div>

          <!-- Permisos especiales exceptions -->
          <div class="border-t border-neutral-800 pt-3">
            <span class="block text-xs font-bold text-neutral-400 uppercase tracking-wider mb-2">Excepciones de Permiso (Overrides)</span>
            
            <div class="max-h-60 overflow-y-auto border border-neutral-850 bg-neutral-950/60 rounded-xl p-3 space-y-3.5">
              <% Object.keys(permissionLabels).forEach(key => { %>
                <div class="flex flex-col gap-1 border-b border-neutral-900 pb-2 last:border-0 last:pb-0">
                  <span class="text-xs font-medium text-neutral-300"><%= permissionLabels[key] %></span>
                  <div class="flex gap-4 text-xs mt-1">
                    <label class="flex items-center gap-1.5 text-neutral-440 cursor-pointer">
                      <input type="radio" name="permissions[<%= key %>]" value="default" checked class="text-blue-600 focus:ring-blue-500 border-neutral-800 bg-neutral-900">
                      <span>Heredar</span>
                    </label>
                    <label class="flex items-center gap-1.5 text-emerald-500 cursor-pointer font-medium">
                      <input type="radio" name="permissions[<%= key %>]" value="allow" class="text-emerald-500 focus:ring-emerald-500 border-neutral-800 bg-neutral-900">
                      <span>Permitir</span>
                    </label>
                    <label class="flex items-center gap-1.5 text-red-400 cursor-pointer font-medium">
                      <input type="radio" name="permissions[<%= key %>]" value="deny" class="text-red-500 focus:ring-red-500 border-neutral-800 bg-neutral-900">
                      <span>Denegar</span>
                    </label>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>

          <div class="flex justify-end gap-3 pt-3 border-t border-neutral-800">
            <button type="button" onclick="closeCreateModal()" class="px-4 py-2.5 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
              Cancelar
            </button>
            <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer shadow-md shadow-blue-500/10">
              Registrar Usuario
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- TAB 2: ROLE PERMISSIONS -->
    <div id="tab-roles-content" class="hidden space-y-6">
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
        <div class="flex justify-between items-center mb-6">
          <div>
            <h2 class="text-lg font-bold text-white">Matriz de Permisos Base por Rol</h2>
            <p class="text-xs text-neutral-400">Define los permisos por defecto para los roles de Supervisor y Cajero en todo el sistema.</p>
          </div>
        </div>

        <form action="/users/role-permissions" method="POST" class="space-y-6" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Guardando...';">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
              <thead>
                <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
                  <th class="py-3 px-4">Permiso / Capacidad del Sistema</th>
                  <th class="py-3 px-4 text-center">Supervisor</th>
                  <th class="py-3 px-4 text-center">Cajero</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-800">
                <% Object.keys(permissionLabels).forEach(key => { %>
                  <tr class="hover:bg-neutral-950/40 transition-colors">
                    <td class="py-3.5 px-4">
                      <div class="font-semibold text-white"><%= permissionLabels[key] %></div>
                      <div class="text-[10px] text-neutral-500 font-mono"><%= key %></div>
                    </td>
                    <td class="py-3.5 px-4 text-center">
                      <input type="checkbox" name="supervisor[]" value="<%= key %>" <%= rolePermissions.supervisor.includes(key) ? 'checked' : '' %> class="h-4 w-4 rounded border-neutral-800 bg-neutral-950 text-blue-600 focus:ring-blue-500 cursor-pointer">
                    </td>
                    <td class="py-3.5 px-4 text-center">
                      <input type="checkbox" name="cashier[]" value="<%= key %>" <%= rolePermissions.cashier.includes(key) ? 'checked' : '' %> class="h-4 w-4 rounded border-neutral-800 bg-neutral-950 text-blue-600 focus:ring-blue-500 cursor-pointer">
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="flex justify-end pt-4 border-t border-neutral-800">
            <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl text-sm px-6 py-3 transition-all cursor-pointer shadow-md shadow-blue-500/10">
              Guardar Cambios de Matriz
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>

<!-- Edit Modal Overlay -->
<div id="edit-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-lg p-6 rounded-2xl shadow-2xl relative max-h-[90vh] flex flex-col">
    <div class="flex justify-between items-center pb-3 border-b border-neutral-800 mb-4">
      <h2 class="text-xl font-bold text-white">Editar Usuario y Excepciones</h2>
      <button onclick="closeEditModal()" class="text-neutral-500 hover:text-white cursor-pointer transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <form id="edit-form" method="POST" class="space-y-4 overflow-y-auto flex-grow pr-1" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Guardando...';">
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Nombre Completo</label>
        <input type="text" id="edit-fullName" name="fullName" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Usuario</label>
        <input type="text" id="edit-username" name="username" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Nueva Contraseña (dejar en blanco para no cambiar)</label>
        <input type="password" name="password" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="••••••••">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Rol</label>
          <select id="edit-roleId" name="roleId" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
            <option value="cashier">Cajero</option>
            <option value="supervisor">Supervisor</option>
            <option value="admin">Administrador</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Estado</label>
          <select id="edit-status" name="status" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
            <option value="active">Activo</option>
            <option value="blocked">Bloqueado</option>
            <option value="inactive">Inactivo</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Sucursal</label>
        <select id="edit-branchId" name="branchId" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
          <option value="">Ninguna (Acceso global de Administrador)</option>
          <% branches.forEach(b => { %>
            <option value="<%= b.id %>"><%= b.name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Permisos especiales exceptions -->
      <div class="border-t border-neutral-800 pt-3">
        <span class="block text-xs font-bold text-neutral-400 uppercase tracking-wider mb-2">Excepciones de Permiso (Overrides)</span>
        
        <div class="max-h-60 overflow-y-auto border border-neutral-850 bg-neutral-950/60 rounded-xl p-3 space-y-3.5">
          <% Object.keys(permissionLabels).forEach(key => { %>
            <div class="flex flex-col gap-1 border-b border-neutral-900 pb-2 last:border-0 last:pb-0">
              <span class="text-xs font-medium text-neutral-300"><%= permissionLabels[key] %></span>
              <div class="flex gap-4 text-xs mt-1">
                <label class="flex items-center gap-1.5 text-neutral-450 cursor-pointer">
                  <input type="radio" id="edit-perm-<%= key %>-default" name="permissions[<%= key %>]" value="default" class="text-blue-600 focus:ring-blue-500 border-neutral-800 bg-neutral-900">
                  <span>Heredar</span>
                </label>
                <label class="flex items-center gap-1.5 text-emerald-500 cursor-pointer font-medium">
                  <input type="radio" id="edit-perm-<%= key %>-allow" name="permissions[<%= key %>]" value="allow" class="text-emerald-500 focus:ring-emerald-500 border-neutral-800 bg-neutral-900">
                  <span>Permitir</span>
                </label>
                <label class="flex items-center gap-1.5 text-red-400 cursor-pointer font-medium">
                  <input type="radio" id="edit-perm-<%= key %>-deny" name="permissions[<%= key %>]" value="deny" class="text-red-500 focus:ring-red-500 border-neutral-800 bg-neutral-900">
                  <span>Denegar</span>
                </label>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-3 border-t border-neutral-800">
        <button type="button" onclick="closeEditModal()" class="px-4 py-2.5 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer shadow-md shadow-blue-500/10">
          Guardar Cambios
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function switchTab(tab) {
    const btnUsers = document.getElementById('tab-btn-users');
    const btnRoles = document.getElementById('tab-btn-roles');
    const contentUsers = document.getElementById('tab-users-content');
    const contentRoles = document.getElementById('tab-roles-content');

    if (tab === 'users') {
      btnUsers.className = "px-5 py-2.5 text-sm font-semibold rounded-xl bg-blue-600 text-white cursor-pointer shadow-md shadow-blue-500/10 transition-all";
      btnRoles.className = "px-5 py-2.5 text-sm font-semibold rounded-xl text-neutral-400 hover:text-white hover:bg-neutral-900 cursor-pointer transition-all";
      contentUsers.classList.remove('hidden');
      contentRoles.classList.add('hidden');
    } else {
      btnRoles.className = "px-5 py-2.5 text-sm font-semibold rounded-xl bg-blue-600 text-white cursor-pointer shadow-md shadow-blue-500/10 transition-all";
      btnUsers.className = "px-5 py-2.5 text-sm font-semibold rounded-xl text-neutral-400 hover:text-white hover:bg-neutral-900 cursor-pointer transition-all";
      contentUsers.classList.add('hidden');
      contentRoles.classList.remove('hidden');
    }
  }

  function openCreateModal() {
    document.getElementById('create-modal').classList.remove('hidden');
  }

  function closeCreateModal() {
    document.getElementById('create-modal').classList.add('hidden');
  }

  function openEditModal(user) {
    document.getElementById('edit-form').action = `/users/${user.id}/edit`;
    document.getElementById('edit-fullName').value = user.fullName;
    document.getElementById('edit-username').value = user.username;
    document.getElementById('edit-roleId').value = user.roleId;
    document.getElementById('edit-branchId').value = user.branchId || '';
    document.getElementById('edit-status').value = user.status;

    // Reset and select special override radios based on user.specialPermissions
    const perms = user.specialPermissions || {};
    
    const permissionKeys = <%- JSON.stringify(Object.keys(permissionLabels)) %>;
    permissionKeys.forEach(key => {
      const val = perms[key];
      if (val === true) {
        document.getElementById(`edit-perm-${key}-allow`).checked = true;
      } else if (val === false) {
        document.getElementById(`edit-perm-${key}-deny`).checked = true;
      } else {
        document.getElementById(`edit-perm-${key}-default`).checked = true;
      }
    });

    document.getElementById('edit-modal').classList.remove('hidden');
  }

  function closeEditModal() {
    document.getElementById('edit-modal').classList.add('hidden');
  }

  async function deleteUser(id) {
    showConfirm('¿Estás seguro de que deseas eliminar este usuario?', async () => {
      try {
        const resp = await fetch(`/users/${id}`, { method: 'DELETE' });
        const resData = await resp.json();
        if (resData.success) {
          window.location.reload();
        } else {
          showToast('Error: ' + resData.message, 'error');
        }
      } catch (err) {
        console.error(err);
        showToast('Ocurrió un error al eliminar el usuario.', 'error');
      }
    });
  }

  // Auto-open create modal if error exists
  <% if (error) { %>
    window.onload = function() {
      openCreateModal();
    }
  <% } %>

  // URL Query parameter success indicator handler
  window.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('success')) {
      showToast('Operación realizada con éxito.', 'success');
      window.history.replaceState({}, document.title, window.location.pathname);
    }
  });
</script>

<%- include('../../partials/foot') %>
