<%- include('../../partials/head', { title: 'Auditorías de Inventario' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Auditorías de Inventario</span>
        <span class="text-xs block text-neutral-400 font-medium">Control físico y conciliación de stock</span>
      </div>
    </div>
    
    <% if (user.roleId === 'admin' || user.roleId === 'supervisor') { %>
    <button onclick="openCreateModal()" class="flex items-center gap-2 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-500 hover:to-teal-500 text-white px-4 py-2.5 rounded-xl text-xs font-bold transition-all shadow-md cursor-pointer">
      <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
      </svg>
      <span>Nueva Auditoría</span>
    </button>
    <% } %>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <% if (successMessage) { %>
      <div class="bg-emerald-950/20 border border-emerald-900 text-emerald-450 p-4 rounded-xl text-xs font-semibold">
        <%= successMessage %>
      </div>
    <% } %>

    <!-- Filter Bar -->
    <% if (user.roleId === 'admin') { %>
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-4 flex flex-col md:flex-row md:items-center justify-between gap-4">
      <form action="/inventory/audits" method="GET" class="flex flex-wrap items-center gap-3 w-full">
        <div class="flex flex-col">
          <label class="text-[10px] font-bold text-neutral-500 uppercase mb-1">Filtrar por Sucursal</label>
          <select name="branchId" onchange="this.form.submit()" class="bg-neutral-950 border border-neutral-800 text-white text-xs rounded-xl px-3 py-2 w-64 focus:outline-none focus:ring-1 focus:ring-blue-500">
            <option value="">Todas las sucursales</option>
            <% branches.forEach(b => { %>
              <option value="<%= b.id %>" <%= selectedBranchId == b.id ? 'selected' : '' %>><%= b.name %></option>
            <% }) %>
          </select>
        </div>
      </form>
    </div>
    <% } %>

    <!-- List Area -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden shadow-sm">
      <div class="px-6 py-4 border-b border-neutral-800 flex items-center justify-between">
        <h2 class="text-sm font-bold text-white uppercase tracking-wider">Historial de Auditorías</h2>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-neutral-800 bg-neutral-950/50">
              <th class="px-6 py-3.5 text-[10px] font-bold text-neutral-500 uppercase">ID / Fecha</th>
              <th class="px-6 py-3.5 text-[10px] font-bold text-neutral-500 uppercase">Sucursal</th>
              <th class="px-6 py-3.5 text-[10px] font-bold text-neutral-500 uppercase">Sector / Bodega</th>
              <th class="px-6 py-3.5 text-[10px] font-bold text-neutral-500 uppercase">Auditor</th>
              <th class="px-6 py-3.5 text-[10px] font-bold text-neutral-500 uppercase">Estado</th>
              <th class="px-6 py-3.5 text-[10px] font-bold text-neutral-500 uppercase text-right">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-800/65">
            <% if (audits.length === 0) { %>
              <tr>
                <td colspan="6" class="px-6 py-12 text-center text-xs text-neutral-500">No se encontraron sesiones de auditoría física de inventario.</td>
              </tr>
            <% } %>
            <% audits.forEach(a => { %>
              <tr class="hover:bg-neutral-950/30 transition-colors">
                <td class="px-6 py-4">
                  <span class="text-xs font-mono font-bold text-white block">#AUD-<%= String(a.id).padStart(4, '0') %></span>
                  <span class="text-[10px] text-neutral-500 block"><%= new Date(a.createdAt).toLocaleString('es-SV') %></span>
                </td>
                <td class="px-6 py-4 text-xs font-semibold text-neutral-300">
                  <%= a.branch ? a.branch.name : 'N/A' %>
                </td>
                <td class="px-6 py-4 text-xs font-bold text-white">
                  <%= a.sector %>
                </td>
                <td class="px-6 py-4 text-xs text-neutral-400">
                  <%= a.user ? a.user.fullName : 'N/A' %>
                </td>
                <td class="px-6 py-4 text-xs">
                  <% if (a.status === 'draft') { %>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold bg-amber-950/40 text-amber-450 border border-amber-800">
                      Borrador / Conteo
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold bg-emerald-950/40 text-emerald-450 border border-emerald-800">
                      Completada
                    </span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-xs text-right whitespace-nowrap">
                  <% if (a.status === 'draft') { %>
                    <a href="/inventory/audits/<%= a.id %>" class="inline-flex items-center bg-amber-600 hover:bg-amber-500 text-neutral-950 font-bold px-3 py-1.5 rounded-lg cursor-pointer transition-colors shadow-sm">
                      Continuar Conteo
                    </a>
                  <% } else { %>
                    <a href="/inventory/audits/<%= a.id %>/report" class="inline-flex items-center bg-neutral-800 hover:bg-neutral-750 text-white font-bold px-3 py-1.5 rounded-lg cursor-pointer transition-colors border border-neutral-700">
                      Ver Reporte
                    </a>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- Create Audit Modal -->
<div id="create-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-md rounded-2xl shadow-2xl overflow-hidden relative">
    <div class="px-6 py-4 border-b border-neutral-800 flex items-center justify-between">
      <h3 class="text-sm font-bold text-white uppercase tracking-wider">Nueva Auditoría Física</h3>
      <button onclick="closeCreateModal()" class="text-neutral-500 hover:text-white cursor-pointer transition-colors">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <form id="create-audit-form" action="/inventory/audits" method="POST" class="p-6 space-y-4">
      <% if (user.roleId === 'admin') { %>
        <div class="flex flex-col">
          <label class="text-[10px] font-bold text-neutral-500 uppercase mb-1">Sucursal a Auditar</label>
          <select name="branchId" required class="bg-neutral-950 border border-neutral-800 text-white text-xs rounded-xl px-3 py-2.5 w-full focus:outline-none focus:ring-1 focus:ring-blue-500">
            <% branches.forEach(b => { %>
              <option value="<%= b.id %>"><%= b.name %></option>
            <% }) %>
          </select>
        </div>
      <% } else { %>
        <input type="hidden" name="branchId" value="<%= user.branchId %>">
      <% } %>

      <div class="flex flex-col">
        <label class="text-[10px] font-bold text-neutral-500 uppercase mb-1">Sector / Área / Pasillo</label>
        <input type="text" name="sector" required placeholder="Ej: Pasillo A, Bodega General, Aceites" class="bg-neutral-950 border border-neutral-800 text-white text-xs rounded-xl px-3 py-2.5 w-full focus:outline-none focus:ring-1 focus:ring-blue-500">
      </div>

      <div class="pt-4 flex gap-3">
        <button type="button" onclick="closeCreateModal()" class="w-1/2 py-2.5 text-xs font-semibold text-neutral-400 bg-neutral-850 hover:bg-neutral-800 border border-neutral-800 rounded-xl transition-all cursor-pointer text-center">
          Cancelar
        </button>
        <button type="submit" id="btn-submit" class="w-1/2 py-2.5 text-xs font-bold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer text-center shadow-md shadow-blue-500/10">
          Iniciar Auditoría
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function openCreateModal() {
    document.getElementById('create-modal').classList.remove('hidden');
  }

  function closeCreateModal() {
    document.getElementById('create-modal').classList.add('hidden');
  }

  // Anti-double click protection
  document.getElementById('create-audit-form').addEventListener('submit', (e) => {
    const btn = document.getElementById('btn-submit');
    btn.disabled = true;
    btn.innerText = 'Iniciando...';
  });

  // Floating Toast Query success listener
  window.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('success') === '1') {
      // Remove query parameter cleanly
      const newUrl = window.location.pathname;
      window.history.replaceState({}, document.title, newUrl);
    }
  });
</script>

<%- include('../../partials/foot') %>
