<%- include('../../partials/head', { title: title }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col overflow-x-hidden text-white select-none">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Levantamiento Inicial</span>
        <span class="text-xs block text-neutral-400 font-medium">Auditoría e ingreso de existencias de apertura</span>
      </div>
    </div>

    <!-- Quick action buttons -->
    <div class="flex items-center gap-2">
      <button onclick="triggerScanner()" class="px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl text-xs flex items-center gap-1.5 transition-all shadow-md shadow-blue-500/10">
        <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2 2V9z" />
        </svg>
        <span>Escanear Código</span>
      </button>
      <button onclick="openQuickCreateModal()" class="px-4 py-2 bg-neutral-800 hover:bg-neutral-750 border border-neutral-750 text-neutral-200 font-bold rounded-xl text-xs flex items-center gap-1.5 transition-all">
        <span>+ Crear Producto</span>
      </button>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6 flex flex-col md:flex-row gap-6 items-stretch">
    <!-- Left column: Product search list and scanned items builder -->
    <div class="flex-grow bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex flex-col overflow-hidden min-h-[60vh] md:w-[65%]">
      <div class="flex justify-between items-center mb-4 flex-shrink-0">
        <h2 class="text-base font-bold text-white uppercase tracking-wider">Artículos en Auditoría Inicial</h2>
        <span class="text-xs text-neutral-450" id="items-count-badge">0 artículos</span>
      </div>

      <!-- Live Search / Auto-add bar -->
      <div class="relative mb-5 flex-shrink-0">
        <input type="text" id="initial-search" class="w-full pl-10 pr-4 py-3 bg-neutral-950 border border-neutral-800 text-white rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 font-medium" placeholder="Escribe el nombre o código de barra de un producto...">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center text-neutral-500 pointer-events-none">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <div id="search-dropdown" class="absolute left-0 right-0 mt-2 bg-neutral-950 border border-neutral-800 rounded-2xl shadow-2xl max-h-60 overflow-y-auto hidden z-30 divide-y divide-neutral-900"></div>
      </div>

      <!-- Main load list -->
      <div id="load-list-container" class="flex-grow overflow-y-auto space-y-3 pr-1 no-scrollbar">
        <div class="flex flex-col items-center justify-center py-16 text-neutral-500 space-y-3" id="empty-state">
          <svg class="h-12 w-12 text-neutral-700 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0l-3-3m3 3l3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
          </svg>
          <span class="text-sm font-semibold">El listado de levantamiento está vacío</span>
          <span class="text-xs text-neutral-600">Escanee códigos o búsquelos arriba para iniciar</span>
        </div>
      </div>
    </div>

    <!-- Right column: Save execution action -->
    <div class="md:w-[35%] bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm flex flex-col justify-between flex-shrink-0">
      <div class="space-y-4">
        <h2 class="text-base font-bold text-white uppercase tracking-wider">Resumen de Carga</h2>
        
        <div class="space-y-3 text-sm text-neutral-300 border-b border-neutral-800 pb-4">
          <div class="flex justify-between">
            <span class="text-neutral-500">Items Únicos:</span>
            <span id="summary-unique-items" class="font-bold text-white">0</span>
          </div>
          <div class="flex justify-between">
            <span class="text-neutral-500">Unidades Totales:</span>
            <span id="summary-total-qty" class="font-bold text-white">0</span>
          </div>
          <div class="flex justify-between">
            <span class="text-neutral-500">Inversión Estimada:</span>
            <span id="summary-total-cost" class="font-bold text-emerald-400 font-mono">$0.00</span>
          </div>
        </div>

        <div class="bg-neutral-950 p-4 rounded-xl border border-neutral-850 space-y-2">
          <h3 class="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-1">
            <span class="text-blue-400">ℹ️</span> Reglas de Carga Inicial
          </h3>
          <ul class="text-[10px] text-neutral-450 list-disc list-inside space-y-1.5">
            <li>Se creará un lote tipo "apertura" para cada artículo físico.</li>
            <li>El costo unitario promedio ponderado se actualizará en la sucursal.</li>
            <li>El precio de venta ingresado sobreescribirá el precio actual en la sucursal.</li>
          </ul>
        </div>
      </div>

      <div class="pt-6">
        <button onclick="submitAuditLoad()" id="btn-submit-load" class="w-full py-3.5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-2xl text-sm transition-all shadow-md shadow-emerald-500/10 cursor-pointer text-center">
          Guardar y Aplicar Inventario
        </button>
      </div>
    </div>
  </main>
</div>

<!-- Webcam Scanner Modal Overlay -->
<div id="scanner-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-md p-6 rounded-3xl shadow-2xl relative flex flex-col">
    <div class="flex justify-between items-center pb-3 border-b border-neutral-800 mb-4">
      <h3 class="text-sm font-bold text-white uppercase tracking-wider">Escanear Código de Barras</h3>
      <button onclick="closeScanner()" class="text-neutral-500 hover:text-white">✕</button>
    </div>
    <div class="bg-black rounded-2xl overflow-hidden aspect-video border border-neutral-800 relative">
      <div id="qr-interactive" class="viewport h-full w-full"></div>
      <div class="absolute inset-0 border-2 border-dashed border-blue-500/30 m-6 pointer-events-none rounded-xl flex items-center justify-center">
        <div class="w-full h-0.5 bg-red-500 animate-pulse"></div>
      </div>
    </div>
    <p class="text-neutral-500 text-center text-xs mt-3">Coloque el código de barras frente a la cámara web</p>
  </div>
</div>

<!-- Quick Create Product Modal Overlay -->
<div id="quick-create-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-md p-6 rounded-3xl shadow-2xl relative flex flex-col max-h-[90vh]">
    <div class="flex justify-between items-center pb-3 border-b border-neutral-800 mb-4 flex-shrink-0">
      <h3 class="text-sm font-bold text-white uppercase tracking-wider">Creación Rápida de Producto</h3>
      <button onclick="closeQuickCreateModal()" class="text-neutral-500 hover:text-white">✕</button>
    </div>
    
    <form id="quick-create-form" class="space-y-4 flex-grow overflow-y-auto pr-1 no-scrollbar">
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Nombre del Producto *</label>
        <input type="text" id="qc-name" required class="w-full px-3 py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl focus:ring-1 focus:ring-blue-500 text-sm">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Código de Barras</label>
        <input type="text" id="qc-barcode" class="w-full px-3 py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl focus:ring-1 focus:ring-blue-500 text-sm font-mono">
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Categoría</label>
          <select id="qc-categoryId" class="w-full px-3 py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl text-sm">
            <option value="">Ninguna</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Tipo</label>
          <select id="qc-type" class="w-full px-3 py-2.5 bg-neutral-950 border border-neutral-850 text-white rounded-xl text-sm">
            <option value="physical">Físico (Con Stock)</option>
            <option value="service">Servicio (Sin Stock)</option>
          </select>
        </div>
      </div>

      <!-- Photo capturing with Web Cam -->
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Fotografía del Producto</label>
        <div class="flex gap-2">
          <!-- Hidden standard file input -->
          <input type="file" id="qc-image-file" class="hidden" accept="image/*" onchange="handleImageFileSelect(this)">
          <button type="button" onclick="document.getElementById('qc-image-file').click()" class="flex-grow py-3 bg-neutral-950 border border-neutral-850 hover:bg-neutral-800 text-xs font-semibold rounded-xl text-center">
            Seleccionar Archivo
          </button>
          <button type="button" onclick="startCameraCapture()" class="py-3 px-4 bg-indigo-950/80 hover:bg-indigo-900 border border-indigo-900/60 text-indigo-400 text-xs font-bold rounded-xl flex items-center justify-center">
            📷 Capturar
          </button>
        </div>
        <div id="qc-photo-preview-container" class="mt-3 bg-neutral-950 border border-neutral-850 rounded-2xl overflow-hidden aspect-video hidden relative">
          <!-- Video preview or static photo snapshot preview -->
          <video id="capture-video" class="h-full w-full object-cover hidden" autoplay playsinline></video>
          <canvas id="capture-canvas" class="hidden"></canvas>
          <img id="capture-image" class="h-full w-full object-cover hidden">
          <button type="button" id="btn-snap-photo" onclick="snapPhoto()" class="absolute bottom-3 left-1/2 -translate-x-1/2 px-4 py-2 bg-indigo-650 hover:bg-indigo-600 text-white font-bold rounded-xl text-xs hidden shadow-lg shadow-indigo-500/20">
            Capturar Foto
          </button>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-3 border-t border-neutral-850">
        <button type="button" onclick="closeQuickCreateModal()" class="px-4 py-2.5 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all">
          Cancelar
        </button>
        <button type="submit" id="btn-quick-create-submit" class="px-5 py-2.5 text-sm font-bold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all shadow-md shadow-blue-500/10">
          Crear Producto
        </button>
      </div>
    </form>
  </div>
</div>

<script src="https://unpkg.com/html5-qrcode"></script>

<script>
  let scannerInstance = null;
  let auditItems = []; // Array of audit list items
  let dbProducts = <%- JSON.stringify(products.map(p => ({ id: p.id, name: p.name, barCode: p.barCode, imagePath: p.imagePath, type: p.type || 'physical', salePrice: p.branchProducts && p.branchProducts[0] ? p.branchProducts[0].salePrice : 0 }))) %>;

  // Search autocomplete mapping
  const searchInput = document.getElementById('initial-search');
  const dropdown = document.getElementById('search-dropdown');

  searchInput.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase().trim();
    if (q.length < 2) {
      dropdown.classList.add('hidden');
      return;
    }
    const matches = dbProducts.filter(p => p.name.toLowerCase().includes(q) || (p.barCode && p.barCode.includes(q)));
    dropdown.innerHTML = '';
    
    if (matches.length === 0) {
      dropdown.innerHTML = '<div class="text-neutral-500 text-xs text-center py-3">No se encontraron productos</div>';
    } else {
      matches.forEach(p => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = "w-full px-4 py-3 hover:bg-neutral-900 text-left text-xs flex justify-between items-center cursor-pointer";
        btn.innerHTML = `
          <div>
            <strong class="text-white block">${p.name}</strong>
            <span class="text-neutral-500">Cód: ${p.barCode || 'N/A'}</span>
          </div>
          <span class="text-blue-400 font-bold">$${parseFloat(p.salePrice).toFixed(2)}</span>
        `;
        btn.onclick = () => {
          addProductToAudit(p);
          searchInput.value = '';
          dropdown.classList.add('hidden');
        };
        dropdown.appendChild(btn);
      });
    }
    dropdown.classList.remove('hidden');
  });

  // Hide autocomplete when clicking elsewhere
  document.addEventListener('click', (e) => {
    if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.classList.add('hidden');
    }
  });

  function addProductToAudit(product) {
    const existing = auditItems.find(i => i.productId === product.id);
    if (existing) {
      showToast('El producto ya se encuentra en la lista.', 'info');
      return;
    }
    
    auditItems.push({
      productId: product.id,
      name: product.name,
      barCode: product.barCode || 'N/A',
      imagePath: product.imagePath || null,
      type: product.type || 'physical',
      quantity: 1,
      unitCost: 0.00,
      salePrice: parseFloat(product.salePrice) || 0.00,
      batchCode: 'LOTE-INICIAL',
      expirationDate: ''
    });
    
    renderAuditList();
  }

  function removeProductFromAudit(productId) {
    auditItems = auditItems.filter(i => i.productId !== productId);
    renderAuditList();
  }

  function updateItemField(productId, field, value) {
    const item = auditItems.find(i => i.productId === productId);
    if (!item) return;
    
    if (field === 'quantity') {
      item.quantity = parseInt(value) || 0;
    } else if (field === 'unitCost') {
      item.unitCost = parseFloat(value) || 0.00;
    } else if (field === 'salePrice') {
      item.salePrice = parseFloat(value) || 0.00;
    } else if (field === 'batchCode') {
      item.batchCode = value;
    } else if (field === 'expirationDate') {
      item.expirationDate = value;
    }
    
    recalculateSummary();
  }

  function renderAuditList() {
    const container = document.getElementById('load-list-container');
    const emptyState = document.getElementById('empty-state');
    
    if (auditItems.length === 0) {
      container.innerHTML = '';
      container.appendChild(emptyState);
      recalculateSummary();
      return;
    }
    
    container.innerHTML = auditItems.map(item => `
      <div class="bg-neutral-950 p-4 border border-neutral-850 rounded-2xl flex flex-col md:flex-row gap-4 items-center justify-between">
        <!-- Details thumbnail and info -->
        <div class="flex items-center gap-3 w-full md:max-w-[30%]">
          <div class="h-12 w-12 bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden flex items-center justify-center flex-shrink-0">
            ${item.imagePath ? `<img src="${item.imagePath}" class="h-full w-full object-cover">` : `
              <svg class="h-5 w-5 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            `}
          </div>
          <div class="min-w-0">
            <strong class="text-xs font-bold text-white block truncate">${item.name}</strong>
            <span class="text-[10px] text-neutral-500 font-mono block">Cód: ${item.barCode}</span>
            ${item.type === 'service' ? '<span class="text-[9px] font-bold text-violet-400 uppercase tracking-wider block mt-0.5">✦ Servicio</span>' : ''}
          </div>
        </div>

        <!-- Numeric fields (Qty, cost, price) -->
        <div class="grid grid-cols-3 gap-2 w-full md:flex-grow">
          <div>
            <label class="block text-[8px] font-semibold text-neutral-500 uppercase tracking-wider mb-0.5">Cant. Inicial</label>
            <input type="number" min="1" value="${item.quantity}" onchange="updateItemField(${item.productId}, 'quantity', this.value)" class="w-full text-center px-2 py-1.5 bg-neutral-900 border border-neutral-800 text-white rounded-lg text-xs font-mono font-bold">
          </div>
          <div>
            <label class="block text-[8px] font-semibold text-neutral-500 uppercase tracking-wider mb-0.5">Costo Unit ($)</label>
            <input type="number" step="0.01" min="0" value="${item.unitCost.toFixed(2)}" onchange="updateItemField(${item.productId}, 'unitCost', this.value)" class="w-full text-center px-2 py-1.5 bg-neutral-900 border border-neutral-800 text-white rounded-lg text-xs font-mono">
          </div>
          <div>
            <label class="block text-[8px] font-semibold text-neutral-500 uppercase tracking-wider mb-0.5">Precio Venta ($)</label>
            <input type="number" step="0.01" min="0" value="${item.salePrice.toFixed(2)}" onchange="updateItemField(${item.productId}, 'salePrice', this.value)" class="w-full text-center px-2 py-1.5 bg-neutral-900 border border-neutral-800 text-white rounded-lg text-xs font-mono font-bold">
          </div>
        </div>

        <!-- Batch info fields -->
        <div class="grid grid-cols-2 gap-2 w-full md:max-w-[30%]">
          <div>
            <label class="block text-[8px] font-semibold text-neutral-500 uppercase tracking-wider mb-0.5">Lote</label>
            <input type="text" value="${item.batchCode}" onchange="updateItemField(${item.productId}, 'batchCode', this.value)" class="w-full px-2 py-1.5 bg-neutral-900 border border-neutral-800 text-white rounded-lg text-xs font-mono" ${item.type === 'service' ? 'disabled' : ''}>
          </div>
          <div>
            <label class="block text-[8px] font-semibold text-neutral-500 uppercase tracking-wider mb-0.5">Vencimiento</label>
            <input type="date" value="${item.expirationDate}" onchange="updateItemField(${item.productId}, 'expirationDate', this.value)" class="w-full px-1.5 py-1 bg-neutral-900 border border-neutral-800 text-white rounded-lg text-xs font-mono" ${item.type === 'service' ? 'disabled' : ''}>
          </div>
        </div>

        <!-- Delete button -->
        <div class="flex-shrink-0 md:pl-2">
          <button onclick="removeProductFromAudit(${item.productId})" class="p-2.5 bg-red-950/40 hover:bg-red-900 border border-red-900/60 text-red-400 rounded-xl text-xs font-bold transition-all">
            ✕
          </button>
        </div>
      </div>
    `).join('');
    
    recalculateSummary();
  }

  function recalculateSummary() {
    const unique = auditItems.length;
    const totalQty = auditItems.reduce((sum, i) => sum + i.quantity, 0);
    const totalCost = auditItems.reduce((sum, i) => sum + (i.quantity * i.unitCost), 0);
    
    document.getElementById('items-count-badge').textContent = `${unique} artículos`;
    document.getElementById('summary-unique-items').textContent = unique;
    document.getElementById('summary-total-qty').textContent = totalQty;
    document.getElementById('summary-total-cost').textContent = `$${totalCost.toFixed(2)}`;
  }

  // Camera Barcode Scanner trigger
  function triggerScanner() {
    document.getElementById('scanner-modal').classList.remove('hidden');
    if (!scannerInstance) {
      scannerInstance = new Html5Qrcode("qr-interactive");
    }
    scannerInstance.start(
      { facingMode: "environment" },
      { fps: 10, qrbox: { width: 250, height: 250 } },
      (decodedText) => {
        // Scanned successfully!
        playFeedbackBeep();
        
        // Find scanned product
        const match = dbProducts.find(p => p.barCode === decodedText);
        if (match) {
          addProductToAudit(match);
          closeScanner();
        } else {
          // Open quick creation modal with barcode pre-filled
          closeScanner();
          openQuickCreateModal(decodedText);
        }
      },
      (error) => {}
    ).catch(() => {
      showToast('Error al encender cámara.', 'error');
    });
  }

  function playFeedbackBeep() {
    try {
      const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      const osc = audioCtx.createOscillator();
      osc.connect(audioCtx.destination);
      osc.start();
      osc.stop(audioCtx.currentTime + 0.1);
    } catch(e) {}
  }

  function closeScanner() {
    document.getElementById('scanner-modal').classList.add('hidden');
    if (scannerInstance) {
      scannerInstance.stop().catch(() => {});
    }
  }

  // Quick product creation modal
  function openQuickCreateModal(scannedBarcode = '') {
    document.getElementById('qc-name').value = '';
    document.getElementById('qc-barcode').value = scannedBarcode;
    document.getElementById('qc-categoryId').value = '';
    document.getElementById('qc-type').value = 'physical';
    
    // Clear photo snapshots preview
    stopCameraCapture();
    document.getElementById('qc-photo-preview-container').classList.add('hidden');
    
    document.getElementById('quick-create-modal').classList.remove('hidden');
  }

  function closeQuickCreateModal() {
    document.getElementById('quick-create-modal').classList.add('hidden');
    stopCameraCapture();
  }

  // Webcam photo capture logic
  let webcamStream = null;
  let selectedPhotoBlob = null;

  async function startCameraCapture() {
    const container = document.getElementById('qc-photo-preview-container');
    const video = document.getElementById('capture-video');
    const btnSnap = document.getElementById('btn-snap-photo');
    const imgSnap = document.getElementById('capture-image');
    
    imgSnap.classList.add('hidden');
    video.classList.remove('hidden');
    btnSnap.classList.remove('hidden');
    container.classList.remove('hidden');
    
    selectedPhotoBlob = null;
    
    try {
      webcamStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } });
      video.srcObject = webcamStream;
    } catch (err) {
      showToast('No se pudo acceder a la webcam para tomar la foto.', 'warning');
    }
  }

  function stopCameraCapture() {
    if (webcamStream) {
      webcamStream.getTracks().forEach(track => track.stop());
      webcamStream = null;
    }
  }

  function snapPhoto() {
    const video = document.getElementById('capture-video');
    const canvas = document.getElementById('capture-canvas');
    const imgSnap = document.getElementById('capture-image');
    const btnSnap = document.getElementById('btn-snap-photo');
    
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    
    const ctx = canvas.getContext('2d');
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
    
    canvas.toBlob(blob => {
      selectedPhotoBlob = blob;
      imgSnap.src = URL.createObjectURL(blob);
      
      // Stop video
      video.classList.add('hidden');
      btnSnap.classList.add('hidden');
      imgSnap.classList.remove('hidden');
      
      stopCameraCapture();
    }, 'image/jpeg', 0.8);
  }

  function handleImageFileSelect(input) {
    if (input.files.length === 0) return;
    const file = input.files[0];
    selectedPhotoBlob = file;
    
    const container = document.getElementById('qc-photo-preview-container');
    const video = document.getElementById('capture-video');
    const imgSnap = document.getElementById('capture-image');
    const btnSnap = document.getElementById('btn-snap-photo');
    
    video.classList.add('hidden');
    btnSnap.classList.add('hidden');
    imgSnap.classList.remove('hidden');
    container.classList.remove('hidden');
    
    imgSnap.src = URL.createObjectURL(file);
  }

  document.getElementById('quick-create-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('qc-name').value.trim();
    const barCode = document.getElementById('qc-barcode').value.trim();
    const categoryId = document.getElementById('qc-categoryId').value;
    const type = document.getElementById('qc-type').value;
    
    const formData = new FormData();
    formData.append('name', name);
    formData.append('barCode', barCode);
    formData.append('categoryId', categoryId);
    formData.append('type', type);
    
    if (selectedPhotoBlob) {
      formData.append('image', selectedPhotoBlob, 'photo.jpg');
    }
    
    const submitBtn = document.getElementById('btn-quick-create-submit');
    submitBtn.disabled = true;
    submitBtn.innerText = 'Guardando...';
    
    try {
      const resp = await fetch('/inventory/initial-load/product', {
        method: 'POST',
        body: formData
      });
      const data = await resp.json();
      
      if (data.success) {
        showToast('Producto creado con éxito.', 'success');
        
        // Add to autocomplete database list
        const newProduct = {
          id: data.product.id,
          name: data.product.name,
          barCode: data.product.barCode,
          imagePath: data.product.imagePath,
          type: data.product.type || 'physical',
          salePrice: 0.00
        };
        dbProducts.push(newProduct);
        
        // Auto-add to load list
        addProductToAudit(newProduct);
        closeQuickCreateModal();
      } else {
        showToast('Error: ' + data.message, 'error');
      }
    } catch(err) {
      showToast('Error de red al crear el producto.', 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerText = 'Crear Producto';
    }
  });

  // Submit Audit Load to backend
  async function submitAuditLoad() {
    if (auditItems.length === 0) {
      showToast('No hay productos en el listado para guardar.', 'warning');
      return;
    }
    
    // Validate quantities and costs
    let isValid = true;
    auditItems.forEach(item => {
      if (item.quantity <= 0) {
        showToast(`La cantidad inicial para ${item.name} debe ser mayor a cero.`, 'warning');
        isValid = false;
      }
    });
    if (!isValid) return;
    
    const submitBtn = document.getElementById('btn-submit-load');
    submitBtn.disabled = true;
    submitBtn.innerText = 'Procesando Carga...';
    
    try {
      const resp = await fetch('/inventory/initial-load/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: auditItems })
      });
      const data = await resp.json();
      
      if (data.success) {
        showToast('Inventario inicial cargado con éxito.', 'success');
        setTimeout(() => {
          window.location.href = '/dashboard';
        }, 1500);
      } else {
        showToast('Error: ' + data.message, 'error');
        submitBtn.disabled = false;
        submitBtn.innerText = 'Guardar y Aplicar Inventario';
      }
    } catch(err) {
      showToast('Error de red al guardar el levantamiento.', 'error');
      submitBtn.disabled = false;
      submitBtn.innerText = 'Guardar y Aplicar Inventario';
    }
  }
</script>

