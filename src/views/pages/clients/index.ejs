<%- include('../../partials/head', { title: 'Gestión de Clientes (CxC)' }) %>

<div class="min-h-screen bg-neutral-950 flex flex-col">
  <!-- Nav Bar -->
  <nav class="bg-neutral-900 border-b border-neutral-800 px-6 py-4 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <span class="text-xl font-bold text-white tracking-wide">Clientes (CxC)</span>
        <span class="text-xs block text-neutral-400 font-medium">Control de Créditos y Cobranzas</span>
      </div>
    </div>
  </nav>

  <main class="flex-grow p-6 max-w-7xl w-full mx-auto space-y-6">
    <!-- List Area -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 shadow-sm">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
        <h2 class="text-lg font-bold text-white">Clientes Registrados</h2>
        <div class="flex flex-wrap items-center gap-4">
          <label class="flex items-center gap-2 text-xs font-semibold text-neutral-400 cursor-pointer select-none">
            <input type="checkbox" id="filter-debtors" onchange="filterClients()" class="h-4 w-4 rounded border-neutral-800 bg-neutral-950 text-blue-600 focus:ring-blue-500 cursor-pointer">
            <span>Mostrar sólo clientes con deuda</span>
          </label>
          <button onclick="openCreateModal()" class="bg-blue-600 hover:bg-blue-500 px-4 py-2.5 rounded-xl text-xs font-bold text-white transition-all shadow-md shadow-blue-500/10 flex items-center gap-1.5 cursor-pointer">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            <span>Nuevo Cliente</span>
          </button>
        </div>
      </div>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-neutral-800 text-left text-sm text-neutral-300">
          <thead>
            <tr class="text-neutral-500 font-semibold uppercase tracking-wider text-xs">
              <th class="py-3 px-4">Nombre</th>
              <th class="py-3 px-4">DUI</th>
              <th class="py-3 px-4">Teléfono</th>
              <th class="py-3 px-4">Sucursal</th>
              <th class="py-3 px-4">Límite Crédito</th>
              <th class="py-3 px-4">Saldo Actual</th>
              <th class="py-3 px-4 text-right">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-800">
            <% clients.forEach(c => { %>
              <tr class="hover:bg-neutral-950/40 transition-colors client-row" data-balance="<%= c.currentBalance %>">
                <td class="py-4 px-4 font-bold text-white">
                  <div>
                    <span><%= c.name %></span>
                    <% if (c.isOverdue) { %>
                      <span class="block mt-1 text-[10px] font-bold uppercase text-red-400 bg-red-950/60 border border-red-900/60 px-2 py-0.5 rounded w-max">
                        ⚠️ Crédito Vencido (Antigüedad: <%= c.overdueDays %> días)
                      </span>
                    <% } %>
                  </div>
                </td>
                <td class="py-4 px-4 font-mono text-neutral-400 text-xs"><%= c.dui || 'N/A' %></td>
                <td class="py-4 px-4"><%= c.phone || 'N/A' %></td>
                <td class="py-4 px-4 text-neutral-400"><%= c.branch ? c.branch.name : 'N/A' %></td>
                <td class="py-4 px-4 text-blue-400 font-semibold">$<%= parseFloat(c.creditLimit).toFixed(2) %> (<%= c.creditDays %> días)</td>
                <td class="py-4 px-4 font-semibold <%= parseFloat(c.currentBalance) > 0 ? (c.isOverdue ? 'text-red-400' : 'text-amber-500') : 'text-neutral-500' %>">$<%= parseFloat(c.currentBalance).toFixed(2) %></td>
                <td class="py-4 px-4 text-right space-x-2">
                  <a href="/clients/<%= c.id %>/statement" class="text-emerald-500 hover:text-emerald-400 text-xs font-semibold hover:underline cursor-pointer">
                    Estado
                  </a>
                  <% if (parseFloat(c.currentBalance) > 0) { %>
                    <button 
                      onclick="openPaymentModal(<%= JSON.stringify(c) %>)"
                      class="text-amber-500 hover:text-amber-400 text-xs font-semibold hover:underline cursor-pointer">
                      Abonar
                    </button>
                  <% } %>
                  <button 
                    onclick="openEditModal(<%= JSON.stringify(c) %>)"
                    class="text-blue-500 hover:text-blue-400 text-xs font-semibold hover:underline cursor-pointer">
                    Editar
                  </button>
                  <button 
                    onclick="deleteClient(<%= c.id %>)"
                    class="text-red-500 hover:text-red-400 text-xs font-semibold hover:underline cursor-pointer">
                    Eliminar
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- Create Modal Overlay -->
<div id="create-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-md p-6 rounded-2xl shadow-2xl relative max-h-[90vh] flex flex-col">
    <div class="flex justify-between items-center pb-3 border-b border-neutral-800 mb-4">
      <h2 class="text-xl font-bold text-white">Registrar Nuevo Cliente</h2>
      <button onclick="closeCreateModal()" class="text-neutral-500 hover:text-white cursor-pointer transition-colors">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <% if (error) { %>
      <div class="bg-red-950/40 border border-red-800 text-red-200 px-4 py-2 rounded-lg text-xs mb-4">
        <%= error %>
      </div>
    <% } %>

    <form action="/clients" method="POST" class="space-y-4 overflow-y-auto flex-grow pr-1" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Registrando...';">
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Nombre Completo *</label>
        <input type="text" name="name" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="Juan Pérez">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">DUI (Documento Único de Identidad)</label>
        <input type="text" name="dui" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="00000000-0" pattern="^\d{8}-\d$" title="El DUI debe tener el formato 00000000-0">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Teléfono</label>
        <input type="text" name="phone" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="7777-7777">
      </div>

      <% if (user.roleId === 'admin') { %>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Sucursal asignada *</label>
          <select name="branchId" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
            <% branches.forEach(b => { %>
              <option value="<%= b.id %>" <%= b.id === user.branchId ? 'selected' : '' %>><%= b.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Límite de Crédito ($ USD) *</label>
          <input type="number" step="0.01" name="creditLimit" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="150.00" value="30.00">
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Días de Crédito *</label>
          <input type="number" name="creditDays" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="30" value="30">
        </div>
      <% } else { %>
        <div>
          <span class="block text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-1">Sucursal asignada</span>
          <span class="text-sm font-semibold text-neutral-300"><%= user.branch ? user.branch.name : 'Ninguna' %></span>
        </div>
        <div class="bg-neutral-950 border border-neutral-800 p-3 rounded-xl">
          <span class="text-xs text-neutral-500 block">Condiciones de Crédito:</span>
          <p class="text-xs text-amber-500 font-semibold mt-1">Sólo los Administradores globales pueden aprobar límites y plazos de crédito. Tu registro se guardará con límite de crédito en $0.00.</p>
        </div>
      <% } %>

      <div class="flex justify-end gap-3 pt-3 border-t border-neutral-800">
        <button type="button" onclick="closeCreateModal()" class="px-4 py-2.5 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer shadow-md shadow-blue-500/10">
          Registrar Cliente
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal Overlay -->
<div id="edit-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-md p-6 rounded-2xl shadow-2xl relative">
    <h2 class="text-xl font-bold text-white mb-4">Editar Cliente</h2>
    
    <form id="edit-form" method="POST" class="space-y-4" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Guardando...';">
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Nombre Completo</label>
        <input type="text" id="edit-name" name="name" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">DUI (Documento Único de Identidad)</label>
        <input type="text" id="edit-dui" name="dui" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm" placeholder="00000000-0" pattern="^\d{8}-\d$" title="El DUI debe tener el formato 00000000-0">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Teléfono</label>
        <input type="text" id="edit-phone" name="phone" class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
      </div>

      <% if (user.roleId === 'admin') { %>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Sucursal asignada</label>
          <select id="edit-branchId" name="branchId" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
            <% branches.forEach(b => { %>
              <option value="<%= b.id %>"><%= b.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Límite de Crédito ($ USD)</label>
          <input type="number" step="0.01" id="edit-creditLimit" name="creditLimit" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Días de Crédito</label>
          <input type="number" id="edit-creditDays" name="creditDays" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
        </div>
      <% } else { %>
        <div class="bg-neutral-950 border border-neutral-800 p-3 rounded-xl">
          <span class="text-xs text-neutral-500 block">Condiciones de Crédito:</span>
          <p class="text-xs text-neutral-400 mt-1">Sólo los Administradores globales pueden aprobar límites y plazos de crédito. Tu registro no puede alterar los límites de este cliente.</p>
        </div>
      <% } %>
      
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closeEditModal()" class="px-4 py-2 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" class="px-5 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer shadow-md shadow-blue-500/10">
          Guardar Cambios
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Payment Modal Overlay -->
<div id="payment-modal" class="fixed inset-0 bg-neutral-950/80 backdrop-blur-sm hidden flex items-center justify-center p-4 z-50">
  <div class="bg-neutral-900 border border-neutral-800 w-full max-w-md p-6 rounded-2xl shadow-2xl relative">
    <h2 class="text-xl font-bold text-white mb-4">Registrar Abono de Crédito</h2>
    
    <form id="payment-form" class="space-y-4">
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Cliente</label>
        <input type="text" id="payment-client-name" readonly class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950/50 text-neutral-400 rounded-xl focus:outline-none text-sm select-none">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Deuda Actual ($ USD)</label>
        <input type="text" id="payment-client-balance" readonly class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950/50 text-neutral-400 rounded-xl focus:outline-none text-sm select-none font-semibold">
      </div>
      <div>
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Monto a Abonar ($ USD) *</label>
        <input type="number" step="0.01" min="0.01" id="payment-amount" name="amountPaid" required class="w-full px-3 py-2.5 border border-neutral-800 bg-neutral-950 text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm font-mono" placeholder="0.00">
      </div>

      <!-- Payment Method Selector -->
      <div class="border-t border-neutral-800 pt-4">
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Método de Pago *</label>
        <div class="grid grid-cols-2 gap-3">
          <label id="method-cash-label" class="flex items-center gap-2 px-4 py-3 bg-neutral-950 border-2 border-blue-500 rounded-xl cursor-pointer transition-all">
            <input type="radio" name="paymentMethod" value="cash" id="method-cash" checked class="text-blue-600 focus:ring-blue-500 border-neutral-800 bg-neutral-900">
            <div>
              <span class="text-sm font-semibold text-white">💵 Efectivo</span>
              <span class="text-[10px] text-neutral-500 block">Ingresa a caja</span>
            </div>
          </label>
          <label id="method-bank-label" class="flex items-center gap-2 px-4 py-3 bg-neutral-950 border-2 border-neutral-800 rounded-xl cursor-pointer transition-all">
            <input type="radio" name="paymentMethod" value="bank_deposit" id="method-bank" class="text-blue-600 focus:ring-blue-500 border-neutral-800 bg-neutral-900">
            <div>
              <span class="text-sm font-semibold text-white">🏦 Depósito</span>
              <span class="text-[10px] text-neutral-500 block">Transferencia bancaria</span>
            </div>
          </label>
        </div>
      </div>

      <!-- Turn Selector (only visible for cash) -->
      <div id="payment-turn-section">
        <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-1">Ingresar Efectivo a Caja *</label>
        <div id="payment-turn-loading" class="flex items-center gap-2 text-neutral-500 text-sm py-2">
          <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Cargando cajas disponibles...
        </div>
        <select id="payment-turnId" name="turnId" class="w-full bg-neutral-950 border border-neutral-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-blue-500 focus:outline-none transition-all hidden">
        </select>
        <div id="payment-turn-no-options" class="hidden bg-red-950/30 border border-red-800/40 text-red-300 text-xs rounded-xl px-4 py-3 mt-1">
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.268 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
            <span>No hay cajas abiertas. Abra un turno de caja para recibir pagos en efectivo.</span>
          </div>
        </div>
        <p id="payment-turn-hint" class="text-[11px] text-neutral-500 mt-1.5 hidden">
          Saldo en caja: <span id="payment-turn-balance" class="font-mono font-semibold text-emerald-400">$0.00</span>
        </p>
      </div>
      
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closePaymentModal()" class="px-4 py-2 text-sm font-semibold text-neutral-400 bg-neutral-800 hover:bg-neutral-750 rounded-xl transition-all cursor-pointer">
          Cancelar
        </button>
        <button type="submit" id="payment-submit-btn" class="px-5 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-xl transition-all cursor-pointer shadow-md shadow-blue-500/10">
          Registrar Abono
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  let currentClientId = null;

  function openEditModal(client) {
    document.getElementById('edit-form').action = `/clients/${client.id}/edit`;
    document.getElementById('edit-name').value = client.name;
    document.getElementById('edit-dui').value = client.dui || '';
    document.getElementById('edit-phone').value = client.phone || '';
    
    const branchSelect = document.getElementById('edit-branchId');
    if (branchSelect) branchSelect.value = client.branchId;

    const limitInput = document.getElementById('edit-creditLimit');
    if (limitInput) limitInput.value = client.creditLimit;

    const daysInput = document.getElementById('edit-creditDays');
    if (daysInput) daysInput.value = client.creditDays;

    document.getElementById('edit-modal').classList.remove('hidden');
  }

  function closeEditModal() {
    document.getElementById('edit-modal').classList.add('hidden');
  }

  function openPaymentModal(client) {
    currentClientId = client.id;
    document.getElementById('payment-client-name').value = client.name;
    document.getElementById('payment-client-balance').value = `$${parseFloat(client.currentBalance).toFixed(2)}`;
    
    const amountInput = document.getElementById('payment-amount');
    amountInput.value = '';
    amountInput.max = parseFloat(client.currentBalance);

    // Reset to cash method
    document.getElementById('method-cash').checked = true;
    updatePaymentMethodUI();
    
    document.getElementById('payment-modal').classList.remove('hidden');

    // Load available turns for cash option
    loadPaymentTurns();
  }

  function closePaymentModal() {
    document.getElementById('payment-modal').classList.add('hidden');
    currentClientId = null;
  }

  // Payment method radio toggle UI
  const methodCash = document.getElementById('method-cash');
  const methodBank = document.getElementById('method-bank');
  const methodCashLabel = document.getElementById('method-cash-label');
  const methodBankLabel = document.getElementById('method-bank-label');
  const paymentTurnSection = document.getElementById('payment-turn-section');
  const paymentTurnSelect = document.getElementById('payment-turnId');
  const paymentTurnLoading = document.getElementById('payment-turn-loading');
  const paymentTurnNoOptions = document.getElementById('payment-turn-no-options');
  const paymentTurnHint = document.getElementById('payment-turn-hint');
  const paymentTurnBalance = document.getElementById('payment-turn-balance');
  const paymentSubmitBtn = document.getElementById('payment-submit-btn');

  function updatePaymentMethodUI() {
    if (methodCash.checked) {
      methodCashLabel.classList.remove('border-neutral-800');
      methodCashLabel.classList.add('border-blue-500');
      methodBankLabel.classList.remove('border-blue-500');
      methodBankLabel.classList.add('border-neutral-800');
      paymentTurnSection.classList.remove('hidden');
    } else {
      methodBankLabel.classList.remove('border-neutral-800');
      methodBankLabel.classList.add('border-blue-500');
      methodCashLabel.classList.remove('border-blue-500');
      methodCashLabel.classList.add('border-neutral-800');
      paymentTurnSection.classList.add('hidden');
      paymentSubmitBtn.disabled = false;
    }
  }

  methodCash.addEventListener('change', () => {
    updatePaymentMethodUI();
    loadPaymentTurns();
  });
  methodBank.addEventListener('change', updatePaymentMethodUI);

  let paymentTurnsLoaded = false;

  async function loadPaymentTurns() {
    paymentTurnSelect.classList.add('hidden');
    paymentTurnNoOptions.classList.add('hidden');
    paymentTurnHint.classList.add('hidden');
    paymentTurnLoading.classList.remove('hidden');
    paymentTurnSelect.innerHTML = '';

    try {
      const resp = await fetch('/clients/payment/available-turns', {
        headers: { 'Accept': 'application/json' }
      });
      const result = await resp.json();

      if (result.success && result.turns.length > 0) {
        result.turns.forEach(turn => {
          const opt = document.createElement('option');
          opt.value = turn.id;
          const ownLabel = turn.isOwn ? ' ★ Mi caja' : '';
          opt.textContent = `${turn.boxName} - ${turn.userName} (Saldo: $${turn.balance.toFixed(2)})${ownLabel}`;
          opt.dataset.balance = turn.balance;
          paymentTurnSelect.appendChild(opt);
        });

        paymentTurnLoading.classList.add('hidden');
        paymentTurnSelect.classList.remove('hidden');
        paymentSubmitBtn.disabled = false;
        paymentTurnsLoaded = true;
        updatePaymentTurnHint();
      } else {
        paymentTurnLoading.classList.add('hidden');
        paymentTurnNoOptions.classList.remove('hidden');
        paymentSubmitBtn.disabled = true;
        paymentTurnsLoaded = false;
      }
    } catch (err) {
      console.error('Error loading turns:', err);
      paymentTurnLoading.classList.add('hidden');
      paymentTurnNoOptions.classList.remove('hidden');
      paymentTurnNoOptions.querySelector('span').textContent = 'Error al cargar las cajas disponibles.';
      paymentSubmitBtn.disabled = true;
      paymentTurnsLoaded = false;
    }
  }

  function updatePaymentTurnHint() {
    const selectedOption = paymentTurnSelect.options[paymentTurnSelect.selectedIndex];
    if (selectedOption && selectedOption.dataset.balance !== undefined) {
      const balance = parseFloat(selectedOption.dataset.balance);
      paymentTurnBalance.textContent = `$${balance.toFixed(2)}`;
      paymentTurnHint.classList.remove('hidden');
      if (balance <= 0) {
        paymentTurnBalance.className = 'font-mono font-semibold text-red-400';
      } else {
        paymentTurnBalance.className = 'font-mono font-semibold text-emerald-400';
      }
    } else {
      paymentTurnHint.classList.add('hidden');
    }
  }

  paymentTurnSelect.addEventListener('change', updatePaymentTurnHint);

  document.getElementById('payment-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentClientId) return;

    const amountPaid = document.getElementById('payment-amount').value;
    const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
    const turnId = paymentMethod === 'cash' ? paymentTurnSelect.value : null;

    const submitBtn = paymentSubmitBtn;
    submitBtn.disabled = true;
    submitBtn.innerText = 'Procesando...';

    try {
      const resp = await fetch(`/clients/${currentClientId}/payment`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ amountPaid, paymentMethod, turnId })
      });

      const resData = await resp.json();

      if (resp.ok && resData.success) {
        showToast(resData.message, 'success');
        closePaymentModal();
        setTimeout(() => {
          window.location.reload();
        }, 1000);
      } else {
        showToast(resData.message || 'Error al registrar el abono.', 'error');
        submitBtn.disabled = false;
        submitBtn.innerText = 'Registrar Abono';
      }
    } catch (err) {
      console.error(err);
      showToast('Ocurrió un error al procesar el pago.', 'error');
      submitBtn.disabled = false;
      submitBtn.innerText = 'Registrar Abono';
    }
  });

  function filterClients() {
    const showOnlyDebtors = document.getElementById('filter-debtors').checked;
    const rows = document.querySelectorAll('.client-row');
    rows.forEach(row => {
      const balance = parseFloat(row.getAttribute('data-balance') || '0');
      if (showOnlyDebtors && balance <= 0) {
        row.classList.add('hidden');
      } else {
        row.classList.remove('hidden');
      }
    });
  }

  function openCreateModal() {
    document.getElementById('create-modal').classList.remove('hidden');
  }

  function closeCreateModal() {
    document.getElementById('create-modal').classList.add('hidden');
  }

  // Auto-open create modal if error exists
  <% if (error) { %>
    window.onload = function() {
      openCreateModal();
    }
  <% } %>

  // URL Query parameter success indicator handler
  window.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('success')) {
      showToast('Operación realizada con éxito.', 'success');
      window.history.replaceState({}, document.title, window.location.pathname);
    }
  });

  async function deleteClient(id) {
    showConfirm('¿Estás seguro de que deseas eliminar este cliente?', async () => {
      try {
        const resp = await fetch(`/clients/${id}`, { method: 'DELETE' });
        const resData = await resp.json();
        if (resData.success) {
          window.location.reload();
        } else {
          showToast('Error: ' + resData.message, 'error');
        }
      } catch (err) {
        console.error(err);
        showToast('Ocurrió un error al eliminar el cliente.', 'error');
      }
    });
  }
</script>

<%- include('../../partials/foot') %>
